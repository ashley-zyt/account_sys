<% content_for :page_title do %>
  会话中心
<% end %>
<% content_for :page_subtitle do %>
  管理KOL对话
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        会话列表
      </div>
      <div class="admin-card-subtitle">
        管理和筛选会话
      </div>
    </div>
    <div class="admin-card-header-right">
      <span class="admin-tag">
        共 <%= @conversations.total_count %> 条
      </span>
    </div>
  </div>

  <div class="admin-filter-form">
    <%= search_form_for @q, url: admin_conversations_path, class: "admin-filter-form" do |f| %>
      <div class="admin-filter-group">
        <label class="admin-filter-label">平台</label>
        <%= f.select :platform_eq, @platforms.map { |p| [p.humanize, p] }, { include_blank: "所有平台" }, class: "admin-input admin-filter-input" %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">状态</label>
        <%= f.select :status_eq, @statuses.map { |s| [s.humanize, s] }, { include_blank: "所有状态" }, class: "admin-input admin-filter-input" %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">KOL</label>
        <%= f.select :kol_id_eq, @kols.map { |k| [k.kol_name, k.id] }, { include_blank: "所有KOL" }, class: "admin-input admin-filter-input" %>
      </div>
      <div style="margin-left: auto;">
        <%= f.submit "筛选", class: "admin-button-primary" %>
        <%= link_to "重置", admin_conversations_path, class: "admin-button-secondary" %>
      </div>
    <% end %>
  </div>

  <% if @conversations.any? %>
    <div class="admin-table-wrapper admin-table-scroll">
      <table class="admin-table">
        <thead>
          <tr>
            <th>KOL</th>
            <th>平台</th>
            <th>账号</th>
            <th>状态</th>
            <th>最后消息</th>
            <th>创建时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @conversations.each do |conv| %>
            <tr>
              <td>
                <%= link_to conv.kol.kol_name, admin_kol_path(conv.kol), class: "admin-link-quiet", style: "color: var(--accent);" %>
              </td>
              <td>
                <span class="admin-label-muted"><%= conv.platform.humanize %></span>
              </td>
              <td>
                <span class="admin-label-muted">@<%= conv.kol_platform_account.nick_name %></span>
              </td>
              <td>
                <span class="admin-badge"><%= conv.status.humanize %></span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= conv.last_message_at&.strftime("%m-%d %H:%M") || "暂无" %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= conv.created_at.strftime("%Y-%m-%d") %>
                </span>
              </td>
              <td>
                <div style="display: flex; gap: 8px; align-items: center;">
                  <%= link_to "查看", admin_conversation_path(conv), class: "admin-link-quiet", style: "color: var(--accent);" %>
                  <% if conv.status != "已合作" && conv.status != "已拒绝" && conv.status != "已关闭" %>
                    <select onchange="changeConversationStatus(<%= conv.id %>, this.value)" style="padding: 4px 8px; font-size: 11px; border-radius: 4px; border: 1px solid #475569; background-color: #1e293b; color: white; cursor: pointer;">
                      <option value="">更改状态</option>
                      <option value="已合作">已合作</option>
                      <option value="已拒绝">已拒绝</option>
                      <option value="已关闭">关闭会话</option>
                    </select>
                  <% else %>
                    <span class="admin-label-muted" style="font-size: 11px; color: #64748b;">已结束</span>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="admin-pagination">
      <%= paginate @conversations %>
    </div>
  <% else %>
    <div class="admin-empty-state">
      暂无会话数据。
    </div>
  <% end %>
</div>

<script>
  function changeConversationStatus(conversationId, newStatus) {
    if (!newStatus) return;

    if (!confirm('确定要将该会话状态更改为「' + newStatus + '」吗？')) {
      location.reload();
      return;
    }

    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/admin/conversations/' + conversationId + '/update_status';

    const csrfInput = document.createElement('input');
    csrfInput.type = 'hidden';
    csrfInput.name = 'authenticity_token';
    csrfInput.value = '<%= form_authenticity_token %>';
    form.appendChild(csrfInput);

    const statusInput = document.createElement('input');
    statusInput.type = 'hidden';
    statusInput.name = 'status';
    statusInput.value = newStatus;
    form.appendChild(statusInput);

    document.body.appendChild(form);
    form.submit();
  }
</script>