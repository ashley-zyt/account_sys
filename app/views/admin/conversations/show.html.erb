<% content_for :page_title do %>
  会话详情
<% end %>
<% content_for :page_subtitle do %>
  <%= @conversation.kol.kol_name %> - <%= @conversation.platform.humanize %>
<% end %>

<div class="admin-grid">
  <div class="admin-card">
    <div class="admin-card-header">
      <div>
        <div class="admin-card-title">
          会话信息
        </div>
        <div class="admin-card-subtitle">
          会话基本信息和状态
        </div>
      </div>
      <div class="admin-card-header-right">
        <%= link_to "返回列表", admin_conversations_path, class: "admin-button-secondary" %>
      </div>
    </div>

    <div class="admin-two-column">
      <div>
        <div class="admin-field-label">KOL</div>
        <div class="admin-field-value">
          <%= link_to @conversation.kol.kol_name, admin_kol_path(@conversation.kol), class: "admin-link-quiet", style: "color: var(--accent);" %>
        </div>
      </div>
      <div>
        <div class="admin-field-label">平台</div>
        <div class="admin-field-value"><%= @conversation.platform.humanize %></div>
      </div>
      <div>
        <div class="admin-field-label">KOL账号</div>
        <div class="admin-field-value">@<%= @conversation.kol_platform_account.nick_name %></div>
      </div>
      <div>
        <div class="admin-field-label">状态</div>
        <div class="admin-field-value"><span class="admin-badge"><%= @conversation.status.humanize %></span></div>
      </div>
      <div>
        <div class="admin-field-label">创建时间</div>
        <div class="admin-field-value"><%= @conversation.created_at.strftime("%Y-%m-%d %H:%M") %></div>
      </div>
      <div>
        <div class="admin-field-label">最后消息</div>
        <div class="admin-field-value"><%= @conversation.last_message_at.present? ? @conversation.last_message_at.strftime("%Y-%m-%d %H:%M") : "暂无" %></div>
      </div>
    </div>

    <div style="margin-top: 12px;">
      <div class="admin-field-label">最新消息摘要</div>
      <div class="admin-field-value" style="background: rgba(15, 23, 42, 0.6); padding: 8px; border-radius: 6px; font-size: 12px;">
        <%= @conversation.latest_message.presence || "暂无消息" %>
      </div>
    </div>
  </div>

  <div class="admin-card">
    <div class="admin-card-header">
      <div>
        <div class="admin-card-title">
          消息记录
        </div>
        <div class="admin-card-subtitle">
          全部聊天消息
        </div>
      </div>
    </div>

    <% if @messages.any? %>
      <div style="max-height: 400px; overflow-y: auto;">
        <% @messages.each do |msg| %>
          <div style="margin-bottom: 12px; padding: 10px; border-radius: 8px; background: <%= msg.sender_type == 0 ? 'rgba(59, 130, 246, 0.1)' : 'rgba(34, 197, 94, 0.1)' %>; border: 1px solid <%= msg.sender_type == 0 ? 'rgba(59, 130, 246, 0.3)' : 'rgba(34, 197, 94, 0.3)' %>;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
              <span style="font-size: 11px; font-weight: 560; color: <%= msg.sender_type == 0 ? '#93c5fd' : '#86efac' %>;">
                <%= msg.sender_type == 0 ? 'KOL' : '运营' %>
              </span>
              <span style="font-size: 11px; color: var(--text-muted);">
                <%= msg.sent_at.strftime("%m-%d %H:%M") %>
              </span>
            </div>
            <div style="font-size: 13px; color: var(--text-primary);">
              <%= msg.content %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="admin-empty-state">暂无消息记录。</div>
    <% end %>
  </div>
</div>