<div class="admin-grid-full">
  <div class="admin-card">
    <div class="admin-card-header">
      <div>
        <div class="admin-card-title">
          近1周报错次数排行榜
        </div>
        <div class="admin-card-subtitle">
          正常状态账号的错误统计排行（按报错次数降序）
        </div>
      </div>
      <div class="admin-card-header-right">
        <span class="admin-tag admin-tag-danger">
          Top <%= @abnormal_accounts.size %>
        </span>
      </div>
    </div>

    <div class="admin-table-wrapper">
      <table class="admin-table">
        <thead>
          <tr>
            <th>排名</th>
            <th>账号名</th>
            <th>平台</th>
            <th>工作模式</th>
            <th>近1周报错次数</th>
            <th>最近报错时间</th>
            <th>最近报错信息</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% if @abnormal_accounts.any? %>
            <% @abnormal_accounts.each_with_index do |item, index| %>
              <tr>
                <td>
                  <span class="admin-pill-status" style="<%= index < 3 ? 'background: rgba(234, 179, 8, 0.1); color: #eab308; font-weight: 700;' : 'background: rgba(156, 163, 175, 0.1); color: #6b7280;' %>">
                    <%= index + 1 %>
                  </span>
                </td>
                <td>
                  <%= link_to item[:account].account_name, admin_account_path(item[:account]), class: "admin-link-quiet", style: "color: var(--accent);" %>
                </td>
                <td>
                  <span class="admin-label-muted"><%= item[:account].platform.to_s.titleize %></span>
                </td>
                <td>
                  <span class="admin-label-muted"><%= item[:account].work_type.to_s.titleize %></span>
                </td>
                <td>
                  <span class="admin-pill-status" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; font-weight: 600;">
                    <%= item[:error_count] %> 次
                  </span>
                </td>
                <td>
                  <span class="admin-label-muted"><%= item[:last_failure_time]&.strftime("%m-%d %H:%M") || '-' %></span>
                </td>
                <td>
                  <span class="admin-label-muted" style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= item[:last_error] %>">
                    <%= item[:last_error] || '-' %>
                  </span>
                </td>
                <td>
                  <div style="display: flex; gap: 8px;">
                    <%= link_to "详情", admin_account_path(item[:account]), class: "admin-link-quiet", style: "color: var(--accent);" %>
                    <%= link_to "日志", admin_task_logs_path(q: { account_id_eq: item[:account].id, status_eq: 1 }), class: "admin-link-quiet", style: "color: var(--danger);" %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="8" style="padding: 24px; text-align: center;" class="admin-label-muted">
                <div style="font-size: 32px; margin-bottom: 8px;">✓</div>
                近1周暂无报错的账号，系统运行正常
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="admin-grid-full">
  <div class="admin-card">
    <div class="admin-card-header">
      <div>
        <div class="admin-card-title">
          运行统计
        </div>
        <div class="admin-card-subtitle">
          今日运行数据概览
        </div>
      </div>
    </div>

    <div style="padding-top: 10px;">
      <div style="display: flex; gap: 40px; align-items: flex-start;">
        <div style="flex: 1;">
          <div class="admin-card-subtitle" style="margin-bottom: 12px;">
            今日运行
          </div>
          <div style="display: flex; gap: 20px;">
            <%= link_to admin_task_logs_path(q: { created_at_gteq: Time.zone.now.beginning_of_day }), class: "admin-link-card" do %>
              <div class="admin-label-muted" style="font-size: 11px;">
                产生日志
              </div>
              <div style="font-size: 18px; font-weight: 600;">
                <%= @today_logs_count %>
              </div>
            <% end %>
            <%= link_to admin_task_logs_path(q: { created_at_gteq: Time.zone.now.beginning_of_day, status_eq: 1 }), class: "admin-link-card" do %>
              <div class="admin-label-muted" style="font-size: 11px;">
                异常次数
              </div>
              <div style="font-size: 18px; font-weight: 600; color: var(--danger);">
                <%= @today_errors_count %>
              </div>
            <% end %>
            <div class="admin-link-card">
              <div class="admin-label-muted" style="font-size: 11px;">
                今日活跃账号
              </div>
              <div style="font-size: 18px; font-weight: 600; color: var(--success);">
                <%= @accounts_active_today %>
              </div>
            </div>
          </div>
        </div>

        <div style="flex: 1; border-left: 1px solid var(--border-subtle); padding-left: 40px;">
          <div class="admin-card-subtitle" style="margin-bottom: 12px;">
            浏览器健康
          </div>
          <div style="display: flex; gap: 20px;">
            <%= link_to admin_browsers_path, class: "admin-link-card" do %>
              <div class="admin-label-muted" style="font-size: 11px;">
                正常
              </div>
              <div style="font-size: 18px; font-weight: 600; color: var(--success);">
                <%= @browsers_normal %>
              </div>
            <% end %>
            <%= link_to admin_browsers_path(q: { status_eq: 1 }), class: "admin-link-card" do %>
              <div class="admin-label-muted" style="font-size: 11px;">
                网络问题
              </div>
              <div style="font-size: 18px; font-weight: 600; color: var(--warning);">
                <%= @browsers_network_error %>
              </div>
            <% end %>
            <%= link_to admin_browsers_path(q: { status_eq: 2 }), class: "admin-link-card" do %>
              <div class="admin-label-muted" style="font-size: 11px;">
                无效(账号失效)
              </div>
              <div style="font-size: 18px; font-weight: 600; color: var(--text-muted);">
                <%= @browsers_invalid %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>