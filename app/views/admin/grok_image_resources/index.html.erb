<% content_for :page_title do %>
  Grok 图片储备
<% end %>
<% content_for :page_subtitle do %>
  用于生成 Grok 视频的前置图片资源
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        图片列表
      </div>
      <div class="admin-card-subtitle">
        管理图片储备资源
      </div>
    </div>
    <div class="admin-card-header-right">
      <%= link_to '新增图片储备', new_admin_grok_image_resource_path, class: "admin-button-primary" %>
    </div>
  </div>

  <div class="admin-filter-form">
    <%= search_form_for [:admin, @q], class: "admin-filter-form" do |f| %>
      <div class="admin-filter-group">
        <label class="admin-filter-label">主题</label>
        <%= f.search_field :theme_cont, class: "admin-input admin-filter-input", placeholder: "搜索主题..." %>
      </div>
      <div style="margin-left: auto;">
        <%= f.submit "筛选", class: "admin-button-primary" %>
        <%= link_to "重置", admin_grok_image_resources_path, class: "admin-button-secondary" %>
      </div>
    <% end %>
  </div>

  <% if @grok_image_resources.any? %>
    <div class="admin-table-wrapper admin-table-scroll">
      <table class="admin-table">
        <thead>
          <tr>
            <th>主题</th>
            <th>图片名称</th>
            <th>图片预览</th>
            <th>视频生成</th>
            <th>创建时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @grok_image_resources.each do |resource| %>
            <tr>
              <td>
                <span class="admin-label-muted">
                  <%= resource.theme %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= resource.image_name || '-' %>
                </span>
              </td>
              <td>
                <img src="<%= resource.image_url %>" width="100" height="100" alt="图片" style="border-radius: 4px; object-fit: cover;" />
              </td>
              <td>
                <% count = resource.video_count %>
                <% if count > 0 %>
                  <% videos_data = resource.distinct_video_urls.map { |url| { url: url } }.to_json %>
                  <a href="javascript:void(0)"
                     class="video-count-badge"
                     data-videos="<%= videos_data.gsub('"', '&quot;') %>"
                     data-theme="<%= resource.theme %>">
                    <span style="width: 6px; height: 6px; border-radius: 50%; background: #22c55e;"></span>
                    已生成 <%= count %>
                  </a>
                <% else %>
                  <span style="display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px; background: rgba(100, 116, 139, 0.16); border: 1px solid rgba(100, 116, 139, 0.4); border-radius: 999px; color: #94a3b8; font-size: 12px; white-space: nowrap;">
                    <span style="width: 6px; height: 6px; border-radius: 50%; background: #64748b;"></span>
                    未生成
                  </span>
                <% end %>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= resource.created_at&.strftime('%Y-%m-%d %H:%M') %>
                </span>
              </td>
              <td>
                <%= link_to '删除', admin_grok_image_resource_path(resource), data: { turbo_method: :delete, turbo_confirm: '确定删除吗？' }, class: "admin-link-quiet", style: "color: #ef4444;" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="admin-pagination">
      <%= paginate @grok_image_resources %>
    </div>
  <% else %>
    <div class="admin-empty-state">
      暂无图片储备数据。
    </div>
  <% end %>
</div>

<!-- 视频生成结果弹窗 -->
<div id="video_list_modal" class="modal-overlay" style="display: none;">
  <div class="modal-content" style="max-width: 680px; width: 92%;">
    <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center;">
      <h3 id="video_list_title">视频生成结果</h3>
      <button type="button" id="video_list_close" style="background: transparent; border: none; color: #94a3b8; font-size: 22px; cursor: pointer; line-height: 1;">×</button>
    </div>
    <div class="modal-body" style="max-height: 70vh; overflow-y: auto;">
      <div id="video_list_body"></div>
    </div>
  </div>
</div>

<style>
  .video-count-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    background: rgba(34, 197, 94, 0.18);
    border: 1px solid rgba(34, 197, 94, 0.45);
    border-radius: 999px;
    color: #86efac;
    font-size: 12px;
    white-space: nowrap;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }
  .video-count-badge:hover {
    background: rgba(34, 197, 94, 0.3);
    border-color: rgba(34, 197, 94, 0.7);
    color: #bbf7d0;
  }

  .video-result-item {
    border: 1px solid #334155;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 12px;
    background: rgba(30, 41, 59, 0.5);
  }
  .video-result-item video {
    width: 100%;
    display: block;
    max-height: 360px;
    background: #000;
  }
  .video-result-item .video-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 12px;
    font-size: 12px;
    color: #94a3b8;
    gap: 8px;
  }
  .video-result-item .video-meta a {
    color: #60a5fa;
    text-decoration: none;
    word-break: break-all;
  }
</style>

<script>
// 用 turbo:load 替代 DOMContentLoaded，避免 Turbo 导航进入时点击无效
function initVideoListModal() {
  var modal = document.getElementById('video_list_modal');
  if (!modal || modal.dataset.videoListBound === '1') return; // 幂等保护
  modal.dataset.videoListBound = '1';

  var body = document.getElementById('video_list_body');
  var titleEl = document.getElementById('video_list_title');
  var closeBtn = document.getElementById('video_list_close');

  function openModal(theme, videos) {
    titleEl.textContent = '视频生成结果' + (theme ? ' - ' + theme : '');

    if (!videos || videos.length === 0) {
      body.innerHTML = '<div style="text-align: center; color: #94a3b8; padding: 24px;">暂无视频</div>';
    } else {
      body.innerHTML = videos.map(function(v, i) {
        return '' +
          '<div class="video-result-item">' +
            '<video src="' + v.url + '" controls preload="metadata"></video>' +
            '<div class="video-meta">' +
              '<span>视频 ' + (i + 1) + '</span>' +
              '<a href="' + v.url + '" target="_blank">在新窗口打开 ↗</a>' +
            '</div>' +
          '</div>';
      }).join('');
    }
    modal.style.display = 'flex';
  }

  function closeModal() {
    modal.style.display = 'none';
    // 暂停所有视频，避免关闭后仍在后台播放
    body.querySelectorAll('video').forEach(function(el) { el.pause(); });
  }

  document.querySelectorAll('.video-count-badge').forEach(function(badge) {
    badge.addEventListener('click', function() {
      var raw = badge.getAttribute('data-videos') || '';
      var videos = [];
      try { videos = JSON.parse(raw) || []; } catch (e) { videos = []; }
      openModal(badge.getAttribute('data-theme'), videos);
    });
  });

  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', function(e) {
    if (e.target === modal) closeModal(); // 点击遮罩关闭
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeModal();
  });
}

document.addEventListener('turbo:load', initVideoListModal);
</script>
