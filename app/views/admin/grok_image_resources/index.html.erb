<% content_for :page_title do %>
  Grok 图片储备
<% end %>
<% content_for :page_subtitle do %>
  用于生成 Grok 视频的前置图片资源
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        图片列表
      </div>
      <div class="admin-card-subtitle">
        管理图片储备资源
      </div>
    </div>
    <div class="admin-card-header-right">
      <%= link_to '新增图片储备', new_admin_grok_image_resource_path, class: "admin-button-primary" %>
    </div>
  </div>

  <div class="admin-filter-form">
    <%= search_form_for [:admin, @q], class: "admin-filter-form" do |f| %>
      <div class="admin-filter-group">
        <label class="admin-filter-label">主题</label>
        <%= f.search_field :theme_cont, class: "admin-input admin-filter-input", placeholder: "搜索主题..." %>
      </div>
      <div style="margin-left: auto;">
        <%= f.submit "筛选", class: "admin-button-primary" %>
        <%= link_to "重置", admin_grok_image_resources_path, class: "admin-button-secondary" %>
      </div>
    <% end %>
  </div>

  <% if @grok_image_resources.any? %>
    <div class="admin-table-wrapper admin-table-scroll">
      <table class="admin-table">
        <thead>
          <tr>
            <th>主题</th>
            <th>图片名称</th>
            <th>图片预览</th>
            <th>视频生成</th>
            <th>创建时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @grok_image_resources.each do |resource| %>
            <tr>
              <td>
                <span class="admin-label-muted">
                  <%= resource.theme %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= resource.image_name || '-' %>
                </span>
              </td>
              <td>
                <img src="<%= resource.image_url %>" width="100" height="100" alt="图片" style="border-radius: 4px; object-fit: cover;" />
              </td>
              <td>
                <% count = resource.video_count %>
                <% if count > 0 %>
                  <% videos_data = resource.video_task_list.to_json %>
                  <span class="video-count-badge"
                        data-videos="<%= videos_data.gsub('"', '&quot;') %>"
                        data-theme="<%= resource.theme %>"
                        role="button"
                        tabindex="0">
                    <span style="width: 6px; height: 6px; border-radius: 50%; background: #22c55e;"></span>
                    已生成 <%= count %>
                  </span>
                <% else %>
                  <span style="display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px; background: rgba(100, 116, 139, 0.16); border: 1px solid rgba(100, 116, 139, 0.4); border-radius: 999px; color: #94a3b8; font-size: 12px; white-space: nowrap;">
                    <span style="width: 6px; height: 6px; border-radius: 50%; background: #64748b;"></span>
                    未生成
                  </span>
                <% end %>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= resource.created_at&.strftime('%Y-%m-%d %H:%M') %>
                </span>
              </td>
              <td>
                <%= link_to '删除', admin_grok_image_resource_path(resource), data: { turbo_method: :delete, turbo_confirm: '确定删除吗？' }, class: "admin-link-quiet", style: "color: #ef4444;" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="admin-pagination">
      <%= paginate @grok_image_resources %>
    </div>
  <% else %>
    <div class="admin-empty-state">
      暂无图片储备数据。
    </div>
  <% end %>
</div>

<!-- 视频生成结果弹窗 -->
<div id="video_list_modal" class="modal-overlay" style="display: none;">
  <div class="modal-content" style="max-width: 800px; width: 94%;">
    <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center;">
      <h3 id="video_list_title">视频生成结果</h3>
      <button type="button" id="video_list_close" style="background: transparent; border: none; color: #94a3b8; font-size: 22px; cursor: pointer; line-height: 1;">×</button>
    </div>
    <div class="modal-body" style="max-height: 75vh; overflow-y: auto;">
      <div id="video_list_body"></div>
    </div>
  </div>
</div>

<style>
  /* 弹窗定位层 */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }
  .modal-content {
    background: #1e293b;
    border-radius: 12px;
    width: 90%;
    max-width: 400px;
  }
  .modal-header {
    padding: 16px 20px;
    border-bottom: 1px solid #334155;
  }
  .modal-header h3 {
    margin: 0;
    font-size: 15px;
    color: #f1f5f9;
  }
  .modal-body {
    padding: 24px 20px;
  }

  .video-count-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    background: rgba(34, 197, 94, 0.18);
    border: 1px solid rgba(34, 197, 94, 0.45);
    border-radius: 999px;
    color: #86efac;
    font-size: 12px;
    white-space: nowrap;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }
  .video-count-badge:hover {
    background: rgba(34, 197, 94, 0.3);
    border-color: rgba(34, 197, 94, 0.7);
    color: #bbf7d0;
  }

  /* 视频预览项 */
  .vl-item {
    border: 1px solid #334155;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 16px;
    background: rgba(30, 41, 59, 0.5);
  }
  .vl-item:last-child { margin-bottom: 0; }

  .vl-item video {
    width: 100%;
    display: block;
    max-height: 380px;
    background: #000;
  }

  .vl-item .vl-info {
    padding: 10px 14px;
  }

  /* 平台标签行 */
  .vl-platforms {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 6px;
  }

  .vl-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 11px;
    white-space: nowrap;
  }

  .vl-tag-platform {
    background: rgba(59, 130, 246, 0.15);
    border: 1px solid rgba(59, 130, 246, 0.35);
    color: #93c5fd;
  }

  .vl-tag-status-pending,
  .vl-tag-status-waiting_publish {
    background: rgba(100, 116, 139, 0.15);
    border: 1px solid rgba(100, 116, 139, 0.35);
    color: #94a3b8;
  }

  .vl-tag-status-executing {
    background: rgba(59, 130, 246, 0.15);
    border: 1px solid rgba(59, 130, 246, 0.35);
    color: #93c5fd;
  }

  .vl-tag-status-success {
    background: rgba(34, 197, 94, 0.15);
    border: 1px solid rgba(34, 197, 94, 0.35);
    color: #86efac;
  }

  .vl-tag-status-failed {
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.35);
    color: #fca5a5;
  }

  .vl-footer {
    display: flex;
    justify-content: flex-end;
    margin-top: 6px;
  }

  .vl-footer a {
    color: #60a5fa;
    text-decoration: none;
    font-size: 12px;
  }
  .vl-footer a:hover { text-decoration: underline; }

  /* 弹窗标题序号 */
  .vl-index {
    color: #64748b;
    font-size: 13px;
    margin-right: 4px;
  }
</style>

<script>
// 平台中文名映射
var PLATFORM_LABEL = {
  facebook: 'Facebook',
  twitter: 'Twitter',
  tiktok: 'TikTok',
  youtube: 'YouTube',
  instagram: 'Instagram'
};

// 状态中文名映射
var STATUS_LABEL = {
  pending: '待处理',
  waiting_publish: '待发布',
  executing: '执行中',
  success: '已完成',
  failed: '失败'
};

// 使用事件委托，把 click 监听绑在 document 上。
// 这样不管 Turbo 怎么刷新表格、换页，新渲染的 .video-count-badge 都能被捕获到，
// 不需要逐个 badge 绑定事件，也不需要幂等保护。
document.addEventListener('click', function(e) {
  var badge = e.target.closest('.video-count-badge');
  if (!badge) return;

  e.preventDefault();

  var modal = document.getElementById('video_list_modal');
  var body = document.getElementById('video_list_body');
  var titleEl = document.getElementById('video_list_title');
  if (!modal || !body || !titleEl) return;

  var raw = badge.getAttribute('data-videos') || '';
  var videos = [];
  try { videos = JSON.parse(raw) || []; } catch (err) { videos = []; }

  var theme = badge.getAttribute('data-theme') || '';
  titleEl.textContent = '视频生成结果' + (theme ? ' - ' + theme : '');

  if (!videos || videos.length === 0) {
    body.innerHTML = '<div style="text-align: center; color: #94a3b8; padding: 24px;">暂无视频</div>';
  } else {
    body.innerHTML = videos.map(function(v, i) {
      var tagsHtml = '';
      if (v.platforms && v.platforms.length > 0) {
        tagsHtml = '<div class="vl-platforms">' +
          v.platforms.map(function(p) {
            var pName = PLATFORM_LABEL[p.name] || p.name;
            var sName = STATUS_LABEL[p.status] || p.status;
            return '' +
              '<span class="vl-tag vl-tag-platform">' + pName + '</span>' +
              '<span class="vl-tag vl-tag-status-' + p.status + '">' + sName + '</span>';
          }).join('') +
        '</div>';
      }

      return '' +
        '<div class="vl-item">' +
          '<video src="' + v.url + '" controls preload="metadata"></video>' +
          '<div class="vl-info">' +
            '<span class="vl-index">视频 ' + (i + 1) + '</span>' +
            tagsHtml +
            '<div class="vl-footer">' +
              '<a href="' + v.url + '" target="_blank">在新窗口打开 ↗</a>' +
            '</div>' +
          '</div>' +
        '</div>';
    }).join('');
  }
  modal.style.display = 'flex';
});

// 关闭弹窗（事件委托，绑在 document 上，不受 Turbo 缓存影响）
document.addEventListener('click', function(e) {
  if (e.target.closest('#video_list_close')) {
    var modal = document.getElementById('video_list_modal');
    if (modal) {
      modal.style.display = 'none';
      modal.querySelectorAll('video').forEach(function(el) { el.pause(); });
    }
  }
  // 点击遮罩关闭
  if (e.target.id === 'video_list_modal') {
    e.target.style.display = 'none';
    e.target.querySelectorAll('video').forEach(function(el) { el.pause(); });
  }
});

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    var modal = document.getElementById('video_list_modal');
    if (modal) {
      modal.style.display = 'none';
      modal.querySelectorAll('video').forEach(function(el) { el.pause(); });
    }
  }
});
</script>
