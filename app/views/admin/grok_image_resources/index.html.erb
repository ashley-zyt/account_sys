<%= render 'admin/shared/search_form', q: @q %>

<div class="admin-table-container">
  <table class="admin-table">
    <thead>
      <tr>
        <th>主题</th>
        <th>图片预览</th>
        <th>创建时间</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @grok_image_resources.each do |resource| %>
        <tr>
          <td><%= resource.theme %></td>
          <td><img src="<%= resource.image_url %>" width="100" height="100" alt="图片" /></td>
          <td><%= resource.created_at.strftime('%Y-%m-%d %H:%M') %></td>
          <td>
            <%= link_to '删除', admin_grok_image_resource_path(resource), method: :delete, data: { confirm: '确定删除吗？' }, class: 'admin-button-danger' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= paginate @grok_image_resources %>

<div style="margin-top: 20px;">
  <%= link_to '新增图片储备', new_admin_grok_image_resource_path, class: 'admin-button' %>
</div>