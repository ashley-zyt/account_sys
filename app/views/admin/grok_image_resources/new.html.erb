<% content_for :page_title do %>
  添加图片储备
<% end %>
<% content_for :page_subtitle do %>
  上传图片到 OSS，作为 Grok 视频生成的前置素材
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        新增图片储备
      </div>
      <div class="admin-card-subtitle">
        选择主题并上传图片文件，提交后图片将先上传至 OSS，再将 OSS 链接存入 image_url 字段
      </div>
    </div>
  </div>

  <form id="upload_form" enctype="multipart/form-data">
    <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

    <div class="admin-form-group">
      <label class="admin-form-label">
        主题 <span style="color: #ef4444;">*</span>
      </label>
      <%= render 'admin/shared/searchable_theme_select',
        name: 'grok_image_resource[theme]',
        themes: @themes,
        selected: nil,
        placeholder: '请选择主题',
        include_blank: '请选择主题' %>
    </div>

    <div class="admin-form-group">
      <label class="admin-form-label">
        图片文件 <span style="color: #ef4444;">*</span>（支持多选）
      </label>
      <div class="file-upload-container">
        <label class="file-upload-label" id="upload_label" for="image_file">
          <div class="upload-icon">🖼️</div>
          <div class="upload-text" id="upload_text">点击选择图片文件（可多选）</div>
          <div class="upload-hint">支持 JPG、PNG、WebP、GIF 等格式，单张最大 50MB</div>
        </label>
        <input type="file" name="image_file" id="image_file" accept="image/*" multiple class="file-input">
        <div class="file-selected-info" id="file_info" style="display: none;">
          <span class="file-name" id="file_name"></span>
          <button type="button" class="clear-btn" id="clear_btn">×</button>
        </div>
        <div class="image-preview-container" id="image_preview_container" style="display: none;">
          <div class="image-preview-grid" id="image_preview_grid"></div>
        </div>
      </div>
    </div>

    <div class="admin-form-actions">
      <a href="/admin/grok_image_resources" class="admin-button-secondary">取消</a>
      <button type="submit" id="submit_btn" class="admin-button-primary">提交</button>
    </div>
  </form>
</div>

<div id="upload_modal" class="modal-overlay" style="display: none;">
  <div class="modal-content">
    <div class="modal-header">
      <h3>正在上传...</h3>
    </div>
    <div class="modal-body">
      <div class="upload-status">
        <div class="status-icon" id="status_icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
          </svg>
        </div>
        <div class="status-text" id="status_text">正在上传图片...</div>
      </div>
      <div class="progress-container">
        <div class="progress-bar">
          <div class="progress-fill" id="progress_fill"></div>
        </div>
        <div class="progress-percent" id="progress_percent">0%</div>
      </div>
      <div class="upload-info" id="upload_info"></div>
    </div>
  </div>
</div>

<style>
  .file-upload-container {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .file-input {
    display: none;
  }

  .file-upload-label {
    border: 2px dashed #475569;
    border-radius: 8px;
    padding: 32px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    background: rgba(30, 41, 59, 0.5);
  }

  .file-upload-label:hover {
    border-color: #3b82f6;
    background: rgba(59, 130, 246, 0.1);
  }

  .upload-icon {
    font-size: 36px;
    margin-bottom: 8px;
  }

  .upload-text {
    font-size: 14px;
    color: #cbd5e1;
    margin-bottom: 4px;
  }

  .upload-hint {
    font-size: 12px;
    color: #64748b;
  }

  .file-selected-info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 8px;
  }

  .file-name {
    color: #cbd5e1;
    font-size: 13px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .clear-btn {
    background: transparent;
    border: none;
    color: #64748b;
    font-size: 20px;
    cursor: pointer;
    padding: 0 8px;
    line-height: 1;
  }

  .clear-btn:hover {
    color: #ef4444;
  }

  .image-preview-container {
    border: 1px solid #334155;
    border-radius: 8px;
    padding: 12px;
    background: rgba(30, 41, 59, 0.5);
  }

  .image-preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 12px;
  }

  .image-preview-item {
    position: relative;
  }

  .image-preview-item img {
    width: 100%;
    height: 120px;
    border-radius: 6px;
    object-fit: cover;
    display: block;
  }

  .image-preview-item .preview-name {
    font-size: 11px;
    color: #94a3b8;
    margin-top: 4px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .image-preview-item .preview-remove {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(239, 68, 68, 0.9);
    color: #fff;
    border: none;
    cursor: pointer;
    font-size: 14px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .image-preview-item .preview-remove:hover {
    background: #ef4444;
  }

  .admin-form-group {
    margin-bottom: 16px;
  }

  .admin-form-label {
    display: block;
    margin-bottom: 6px;
    font-size: 13px;
    color: #94a3b8;
  }

  .admin-form-actions {
    display: flex;
    gap: 12px;
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid #334155;
  }

  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }

  .modal-content {
    background: #1e293b;
    border-radius: 12px;
    width: 90%;
    max-width: 400px;
  }

  .modal-header {
    padding: 16px 20px;
    border-bottom: 1px solid #334155;
  }

  .modal-header h3 {
    margin: 0;
    font-size: 15px;
    color: #f1f5f9;
  }

  .modal-body {
    padding: 24px 20px;
  }

  .upload-status {
    text-align: center;
    margin-bottom: 20px;
  }

  .status-icon {
    margin-bottom: 8px;
  }

  .status-icon svg {
    width: 40px;
    height: 40px;
    color: #3b82f6;
  }

  .status-icon.success svg {
    color: #22c55e;
  }

  .status-icon.error svg {
    color: #ef4444;
  }

  .status-icon.loading svg {
    animation: spin 1.5s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .status-text {
    font-size: 13px;
    color: #94a3b8;
  }

  .progress-container {
    margin-bottom: 16px;
  }

  .progress-bar {
    background: #334155;
    border-radius: 4px;
    height: 6px;
    overflow: hidden;
    margin-bottom: 6px;
  }

  .progress-fill {
    background: linear-gradient(90deg, #3b82f6, #22c55e);
    height: 100%;
    width: 0%;
    transition: width 0.3s;
  }

  .progress-fill.success {
    background: #22c55e;
  }

  .progress-fill.error {
    background: #ef4444;
  }

  .progress-percent {
    font-size: 12px;
    color: #64748b;
    text-align: center;
  }

  .upload-info {
    font-size: 12px;
    color: #64748b;
    text-align: center;
    padding: 10px;
    background: rgba(30, 41, 59, 0.8);
    border-radius: 6px;
    display: none;
  }

  .upload-info.success {
    color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
  }

  .upload-info.error {
    color: #ef4444;
    background: rgba(239, 68, 68, 0.1);
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var fileInput = document.getElementById('image_file');
  var fileInfo = document.getElementById('file_info');
  var fileName = document.getElementById('file_name');
  var clearBtn = document.getElementById('clear_btn');
  var form = document.getElementById('upload_form');
  var submitBtn = document.getElementById('submit_btn');
  var modal = document.getElementById('upload_modal');
  var statusIcon = document.getElementById('status_icon');
  var statusText = document.getElementById('status_text');
  var progressFill = document.getElementById('progress_fill');
  var progressPercent = document.getElementById('progress_percent');
  var uploadInfo = document.getElementById('upload_info');

  var previewContainer = document.getElementById('image_preview_container');
  var previewGrid = document.getElementById('image_preview_grid');

  if (!form) return;

  // 维护当前选中的文件列表（允许单个移除）
  var selectedFiles = [];

  function renderPreviews() {
    previewGrid.innerHTML = '';

    if (selectedFiles.length === 0) {
      previewContainer.style.display = 'none';
      fileInfo.style.display = 'none';
      fileInput.value = '';
      return;
    }

    // 顶部文件信息条
    fileName.textContent = selectedFiles.length + ' 张图片已选择 (' + formatSize(selectedFiles.reduce(function(s, f){ return s + f.size; }, 0)) + ')';
    fileInfo.style.display = 'flex';
    previewContainer.style.display = 'block';

    selectedFiles.forEach(function(file, index) {
      var item = document.createElement('div');
      item.className = 'image-preview-item';

      var img = document.createElement('img');
      var reader = new FileReader();
      reader.onload = function(e) { img.src = e.target.result; };
      reader.readAsDataURL(file);
      item.appendChild(img);

      var nameDiv = document.createElement('div');
      nameDiv.className = 'preview-name';
      nameDiv.textContent = file.name;
      item.appendChild(nameDiv);

      var removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.className = 'preview-remove';
      removeBtn.textContent = '×';
      removeBtn.title = '移除该图片';
      removeBtn.addEventListener('click', function(e) {
        e.preventDefault();
        selectedFiles.splice(index, 1);
        renderPreviews();
      });
      item.appendChild(removeBtn);

      previewGrid.appendChild(item);
    });
  }

  fileInput.addEventListener('change', function() {
    if (this.files && this.files.length > 0) {
      // 追加新选择的文件（避免重复）
      Array.prototype.forEach.call(this.files, function(file) {
        selectedFiles.push(file);
      });
      renderPreviews();
    }
  });

  clearBtn.addEventListener('click', function(e) {
    e.preventDefault();
    selectedFiles = [];
    renderPreviews();
  });

  form.addEventListener('submit', function(e) {
    e.preventDefault();

    var themeInput = document.querySelector('input[name="grok_image_resource[theme]"]');
    var theme = themeInput ? themeInput.value.trim() : '';

    if (!theme) { alert('请选择主题'); return; }
    if (selectedFiles.length === 0) { alert('请选择图片文件'); return; }

    submitBtn.disabled = true;
    submitBtn.textContent = '上传中...';
    showModal();
    resetProgress();

    var uploadedKeys = [];
    var totalFiles = selectedFiles.length;

    // 串行上传所有图片
    function uploadNext(index) {
      if (index >= totalFiles) {
        // 全部上传完成，提交 oss_keys
        updateProgress(95, '正在保存图片储备...');
        createGrokImageResources(uploadedKeys)
          .then(function() {
            updateProgress(100, '完成！');
            statusIcon.className = 'status-icon success';
            progressFill.classList.add('success');
            uploadInfo.textContent = '成功上传 ' + uploadedKeys.length + ' 张图片';
            uploadInfo.className = 'upload-info success';
            uploadInfo.style.display = 'block';
            setTimeout(function() {
              window.location.href = '/admin/grok_image_resources';
            }, 1500);
          })
          .catch(function(error) {
            showError('保存失败: ' + error.message);
          });
        return;
      }

      var file = selectedFiles[index];
      // 每张图占总进度的 90/total 份额
      var basePercent = (index / totalFiles) * 90;

      fetch('/admin/grok_image_resources/oss_signature?filename=' + encodeURIComponent(file.name))
        .then(function(response) {
          if (!response.ok) throw new Error('获取签名失败');
          return response.json();
        })
        .then(function(signatureData) {
          return uploadToOss(file, signatureData, basePercent, totalFiles, index);
        })
        .then(function(ossKey) {
          uploadedKeys.push(ossKey);
          uploadNext(index + 1);
        })
        .catch(function(error) {
          showError('第 ' + (index + 1) + ' 张上传失败: ' + error.message);
        });
    }

    uploadNext(0);
  });

  // 直传文件到 OSS（progressSpan: 当前文件占总进度的份额区间）
  function uploadToOss(file, signatureData, basePercent, totalFiles, currentIndex) {
    return new Promise(function(resolve, reject) {
      var formData = new FormData();
      formData.append('key', signatureData.key);
      formData.append('OSSAccessKeyId', signatureData.accessKeyId);
      formData.append('policy', signatureData.policy);
      formData.append('Signature', signatureData.signature);
      formData.append('file', file);

      var xhr = new XMLHttpRequest();
      xhr.open('POST', signatureData.endpoint, true);

      var span = 90 / totalFiles; // 每张图占的进度区间

      xhr.upload.addEventListener('progress', function(ev) {
        if (ev.lengthComputable) {
          var percent = Math.round(basePercent + (ev.loaded / ev.total) * span);
          updateProgress(percent, '正在上传第 ' + (currentIndex + 1) + ' 张图片 (' + uploadedKeys.length + '/' + totalFiles + ' 完成)...');
        }
      });

      xhr.addEventListener('load', function() {
        if (xhr.status === 204 || xhr.status === 200) {
          resolve(signatureData.key);
        } else {
          reject(new Error('OSS 上传失败: ' + xhr.statusText));
        }
      });

      xhr.addEventListener('error', function() {
        reject(new Error('网络错误'));
      });

      xhr.send(formData);
    });
  }

  // 提交表单，创建图片储备记录（支持多张）
  function createGrokImageResources(ossKeys) {
    return new Promise(function(resolve, reject) {
      var formData = new FormData(form);
      // 后端通过 oss_keys[] 接收数组
      ossKeys.forEach(function(key) {
        formData.append('oss_keys[]', key);
      });
      // 移除单个 oss_key（如有），避免歧义
      formData.delete('oss_key');

      var xhr = new XMLHttpRequest();
      xhr.open('POST', '/admin/grok_image_resources', true);

      xhr.addEventListener('load', function() {
        if (xhr.status === 302 || xhr.status === 200) {
          resolve();
        } else {
          reject(new Error('保存失败'));
        }
      });

      xhr.addEventListener('error', function() {
        reject(new Error('网络错误'));
      });

      xhr.send(formData);
    });
  }

  function showModal() {
    modal.style.display = 'flex';
    statusIcon.className = 'status-icon loading';
  }

  function resetProgress() {
    statusIcon.className = 'status-icon loading';
    statusText.textContent = '正在准备上传...';
    progressFill.className = 'progress-fill';
    progressFill.style.width = '0%';
    progressPercent.textContent = '0%';
    uploadInfo.className = 'upload-info';
    uploadInfo.style.display = 'none';
  }

  function updateProgress(percent, text) {
    progressFill.style.width = percent + '%';
    progressPercent.textContent = percent + '%';
    statusText.textContent = text;
  }

  function showError(msg) {
    statusIcon.className = 'status-icon error';
    progressFill.classList.add('error');
    uploadInfo.textContent = msg;
    uploadInfo.className = 'upload-info error';
    uploadInfo.style.display = 'block';
    submitBtn.disabled = false;
    submitBtn.textContent = '提交';
  }

  function formatSize(bytes) {
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / 1024 / 1024).toFixed(1) + ' MB';
  }
});
</script>
