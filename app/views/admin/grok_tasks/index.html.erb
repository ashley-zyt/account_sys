<% content_for :page_title do %>
  Grok 资源队列
<% end %>
<% content_for :page_subtitle do %>
  Grok 视频生成任务列表
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        任务列表
      </div>
      <div class="admin-card-subtitle">
        监控和筛选 Grok 任务队列
      </div>
    </div>
    <div class="admin-card-header-right">
      <%= link_to '新增 Grok 任务', new_admin_grok_task_path, class: "admin-button-primary" %>
    </div>
  </div>

  <div class="admin-filter-form">
    <%= search_form_for [:admin, @q], class: "admin-filter-form" do |f| %>
      <div class="admin-filter-group">
        <label class="admin-filter-label">主题</label>
        <%= f.search_field :theme_cont, class: "admin-input admin-filter-input", placeholder: "搜索主题..." %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">平台</label>
        <%= f.select :platform_eq, GrokTask.platforms.map { |k, v| [k.to_s.titleize, v] }, { include_blank: "所有平台" }, class: "admin-input admin-filter-input" %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">状态</label>
        <%= f.select :status_eq, GrokTask.statuses.map { |k, v| [k.to_s.titleize, v] }, { include_blank: "所有状态" }, class: "admin-input admin-filter-input" %>
      </div>
      <div style="margin-left: auto;">
        <%= f.submit "筛选", class: "admin-button-primary" %>
        <%= link_to "重置", admin_grok_tasks_path, class: "admin-button-secondary" %>
      </div>
    <% end %>
  </div>

  <% if @grok_tasks.any? %>
    <div class="admin-table-wrapper admin-table-scroll">
      <table class="admin-table">
        <thead>
          <tr>
            <th>主题</th>
            <th>平台</th>
            <th>状态</th>
            <th>标题</th>
            <th>创建时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @grok_tasks.each do |task| %>
            <tr>
              <td>
                <span class="admin-label-muted">
                  <%= task.theme %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= task.platform %>
                </span>
              </td>
              <td>
                <% case task.status %>
                <% when "pending" %>
                  <span class="admin-pill-status admin-pill-status-pending">
                    <span class="admin-pill-status-dot"></span>
                    待分配
                  </span>
                <% when "waiting_publish", "executing" %>
                  <span class="admin-pill-status admin-pill-status-pending">
                    <span class="admin-pill-status-dot"></span>
                    队列中
                  </span>
                <% when "success" %>
                  <span class="admin-pill-status admin-pill-status-success">
                    <span class="admin-pill-status-dot"></span>
                    成功
                  </span>
                <% when "failed" %>
                  <span class="admin-pill-status admin-pill-status-failed">
                    <span class="admin-pill-status-dot"></span>
                    失败
                  </span>
                <% end %>
              </td>
              <td>
                <%= task.title.presence || '-' %>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= task.created_at&.strftime('%Y-%m-%d %H:%M') %>
                </span>
              </td>
              <td>
                <%= link_to '编辑', edit_admin_grok_task_path(task), class: "admin-link-quiet", style: "color: var(--accent);" %>
                <%= link_to '删除', admin_grok_task_path(task), method: :delete, data: { confirm: '确定删除吗？' }, class: "admin-link-quiet", style: "color: #ef4444;" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="admin-pagination">
      <%= paginate @grok_tasks %>
    </div>
  <% else %>
    <div class="admin-empty-state">
      暂无 Grok 任务数据。
    </div>
  <% end %>
</div>
