<%= render 'admin/shared/search_form', q: @q %>

<div class="admin-table-container">
  <table class="admin-table">
    <thead>
      <tr>
        <th>主题</th>
        <th>平台</th>
        <th>状态</th>
        <th>标题</th>
        <th>创建时间</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @grok_video_resources.each do |resource| %>
        <tr>
          <td><%= resource.theme %></td>
          <td><%= resource.platform %></td>
          <td><%= resource.status %></td>
          <td><%= resource.title.presence || '-' %></td>
          <td><%= resource.created_at.strftime('%Y-%m-%d %H:%M') %></td>
          <td>
            <%= link_to '编辑', edit_admin_grok_video_resource_path(resource), class: 'admin-button-secondary' %>
            <%= link_to '删除', admin_grok_video_resource_path(resource), method: :delete, data: { confirm: '确定删除吗？' }, class: 'admin-button-danger' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= paginate @grok_video_resources %>

<div style="margin-top: 20px;">
  <%= link_to '新增视频储备', new_admin_grok_video_resource_path, class: 'admin-button' %>
</div>