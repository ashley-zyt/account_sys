<% content_for :page_title do %>
  Heygen 资源队列
<% end %>
<% content_for :page_subtitle do %>
  Heygen 视频生成任务列表
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        任务列表
      </div>
      <div class="admin-card-subtitle">
        监控和筛选 Heygen 任务队列
      </div>
    </div>
    <div class="admin-card-header-right">
      <span class="admin-tag">
        共 <%= @heygen_tasks.total_count %> 条
      </span>
    </div>
  </div>

  <div class="admin-filter-form">
    <%= search_form_for [:admin, @q], class: "admin-filter-form" do |f| %>
      <div class="admin-filter-group">
        <label class="admin-filter-label">主题</label>
        <%= f.search_field :theme_cont, class: "admin-input admin-filter-input", placeholder: "搜索主题..." %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">平台</label>
        <%= f.select :platform_eq, HeygenTask.platforms.map { |k, v| [k.to_s.titleize, v] }, { include_blank: "所有平台" }, class: "admin-input admin-filter-input" %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">状态</label>
        <% status_labels = { "pending" => "待分配", "waiting_publish" => "等待发布", "executing" => "执行中", "success" => "成功", "failed" => "失败" } %>
        <%= f.select :status_eq, HeygenTask.statuses.map { |k, v| [status_labels[k.to_s] || k.to_s.titleize, v] }, { include_blank: "所有状态" }, class: "admin-input admin-filter-input" %>
      </div>
      <div style="margin-left: auto;">
        <%= f.submit "筛选", class: "admin-button-primary" %>
        <%= link_to "重置", admin_heygen_tasks_path, class: "admin-button-secondary" %>
      </div>
    <% end %>
  </div>

  <% if @heygen_tasks.any? %>
    <div class="admin-table-wrapper admin-table-scroll">
      <table class="admin-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>标题</th>
            <th>描述</th>
            <th>内容主题</th>
            <th>平台</th>
            <th>状态</th>
            <th>账号</th>
            <th>浏览器</th>
            <th>创建时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @heygen_tasks.each do |task| %>
            <tr>
              <td>
                <span class="admin-label-muted">
                  <%= task.id %>
                </span>
              </td>
              <td>
                <%= link_to truncate(task.title.presence || '-', length: 30), admin_heygen_task_path(task), class: "admin-link-quiet" %>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= truncate(task.description.to_s, length: 30) %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= task.theme %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= task.platform %>
                </span>
              </td>
              <td>
                <% case task.status %>
                <% when "pending" %>
                  <span class="admin-pill-status admin-pill-status-pending">
                    <span class="admin-pill-status-dot"></span>
                    待分配
                  </span>
                <% when "waiting_publish" %>
                  <span class="admin-pill-status admin-pill-status-pending">
                    <span class="admin-pill-status-dot"></span>
                    等待发布
                  </span>
                <% when "executing" %>
                  <span class="admin-pill-status admin-pill-status-pending">
                    <span class="admin-pill-status-dot"></span>
                    执行中
                  </span>
                <% when "success" %>
                  <span class="admin-pill-status admin-pill-status-success">
                    <span class="admin-pill-status-dot"></span>
                    成功
                  </span>
                <% when "failed" %>
                  <span class="admin-pill-status admin-pill-status-failed">
                    <span class="admin-pill-status-dot"></span>
                    失败
                  </span>
                <% end %>
              </td>
              <td>
                <% if task.account %>
                  <%= link_to truncate(task.account.account_name, length: 20), admin_account_path(task.account), class: "admin-link-quiet", title: task.account.account_name %>
                <% else %>
                  <span class="admin-label-muted">
                    未分配
                  </span>
                <% end %>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= task.browser&.profile_name || "未绑定" %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= task.created_at&.strftime('%m-%d %H:%M') %>
                </span>
              </td>
              <td>
                <div style="display: flex; gap: 8px;">
                  <%= link_to "详情", admin_heygen_task_path(task), class: "admin-link-quiet", style: "color: var(--accent);" %>
                  <%= link_to "日志", admin_task_logs_path(q: { task_uuid_eq: task.task_uuid }), class: "admin-link-quiet", style: "color: var(--accent);" %>
                  <% if task.pending? %>
                    <%= link_to "删除", admin_heygen_task_path(task), data: { turbo_method: :delete, turbo_confirm: "确定要删除该 pending 任务吗？" }, class: "admin-link-quiet", style: "color: var(--danger);" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="admin-pagination">
      <%= paginate @heygen_tasks %>
    </div>
  <% else %>
    <div class="admin-empty-state">
      暂无 Heygen 任务数据。
    </div>
  <% end %>
</div>