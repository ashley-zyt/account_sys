<%= form_with model: [:admin, jianying_task], class: "admin-form" do |f| %>
  <% if jianying_task.errors.any? %>
    <div class="admin-empty-state" style="margin-bottom: 12px; border-color: var(--danger);">
      <ul class="admin-list">
        <% jianying_task.errors.full_messages.each do |msg| %>
          <li class="admin-list-item">
            <div class="admin-list-title" style="color: var(--danger);">
              <%= msg %>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="admin-card">
    <div class="admin-card-header">
      <div class="admin-card-title">基本信息</div>
    </div>
    <div class="admin-two-column">
      <div>
        <div class="admin-field-label">内容主题</div>
        <%= f.text_field :theme, class: "admin-input", placeholder: "从 API 传入或手动输入" %>
      </div>
      <div>
        <div class="admin-field-label">发布平台</div>
        <%= f.select :platform, JianyingTask.platforms.keys.map { |k| [k.to_s.titleize, k] }, {}, class: "admin-input" %>
      </div>
      <div>
        <div class="admin-field-label">任务状态</div>
        <%= f.select :status, JianyingTask.statuses.keys.map { |k| [k.to_s.titleize, k] }, {}, class: "admin-input" %>
      </div>
      <div>
        <div class="admin-field-label">任务组 ID (Group ID)</div>
        <%= f.text_field :group_id, class: "admin-input" %>
      </div>
    </div>

    <div style="margin-top: 16px;">
      <div class="admin-field-label">OSS 视频地址</div>
      <%= f.text_area :oss_url, class: "admin-input", rows: 2 %>
    </div>

    <div style="margin-top: 16px;">
      <div class="admin-field-label">发布标题</div>
      <%= f.text_area :title, class: "admin-input", rows: 2 %>
    </div>
  </div>

  <div class="admin-card" style="margin-top: 20px;">
    <div class="admin-card-header">
      <div class="admin-card-title">分配信息</div>
    </div>
    <div class="admin-two-column">
      <div>
        <div class="admin-field-label">执行账号</div>
        <%= f.collection_select :account_id, Account.order(:account_name), :id, :account_name, { include_blank: "未分配" }, class: "admin-input" %>
      </div>
      <div>
        <div class="admin-field-label">浏览器</div>
        <%= f.collection_select :browser_id, Browser.order(:profile_name), :id, :profile_name, { include_blank: "未绑定" }, class: "admin-input" %>
      </div>
    </div>
  </div>

  <div style="margin-top: 20px;">
    <button type="submit" class="admin-button-primary">
      保存任务
    </button>
    <%= link_to "取消", admin_jianying_tasks_path, class: "admin-button-secondary" %>
  </div>
<% end %>
