<% content_for :page_title do %>
  剪映任务详情
<% end %>
<% content_for :page_subtitle do %>
  任务 <%= @jianying_task.id %> · <%= @jianying_task.keyword_code %>
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">基本信息</div>
      <div class="admin-card-subtitle">任务配置与状态</div>
    </div>
    <div class="admin-card-header-right">
      <%= link_to "返回列表", admin_jianying_tasks_path, class: "admin-button-secondary" %>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px 40px; padding-bottom: 16px;">
    <div class="info-item">
      <span class="info-label">主题</span>
      <span class="info-value"><%= @jianying_task.theme %></span>
    </div>
    <div class="info-item">
      <span class="info-label">平台</span>
      <span class="info-value"><%= @jianying_task.platform %></span>
    </div>
    <div class="info-item">
      <span class="info-label">关键词</span>
      <span class="info-value"><%= @jianying_task.keyword.presence || "-" %></span>
    </div>
    <div class="info-item">
      <span class="info-label">关键词编码</span>
      <span class="info-value">
        <code style="background: rgba(59,130,246,0.1); padding: 3px 10px; border-radius: 4px; color: #93c5fd; font-size: 13px;">
          <%= @jianying_task.keyword_code.presence || "-" %>
        </code>
      </span>
    </div>
    <div class="info-item">
      <span class="info-label">状态</span>
      <span class="info-value">
        <% case @jianying_task.status %>
        <% when "pending" %>
          <span class="admin-pill-status admin-pill-status-pending"><span class="admin-pill-status-dot"></span>待分配</span>
        <% when "waiting_publish", "executing" %>
          <span class="admin-pill-status admin-pill-status-pending"><span class="admin-pill-status-dot"></span>队列中</span>
        <% when "success" %>
          <span class="admin-pill-status admin-pill-status-success"><span class="admin-pill-status-dot"></span>成功</span>
        <% when "failed" %>
          <span class="admin-pill-status admin-pill-status-failed"><span class="admin-pill-status-dot"></span>失败</span>
        <% end %>
      </span>
    </div>
    <div class="info-item">
      <span class="info-label">任务UUID</span>
      <span class="info-value" style="font-family: monospace; font-size: 12px;"><%= @jianying_task.task_uuid %></span>
    </div>
    <div class="info-item">
      <span class="info-label">任务组ID</span>
      <span class="info-value" style="font-family: monospace; font-size: 12px;"><%= @jianying_task.group_id || "-" %></span>
    </div>
    <div class="info-item">
      <span class="info-label">创建时间</span>
      <span class="info-value"><%= @jianying_task.created_at&.strftime("%Y-%m-%d %H:%M") %></span>
    </div>
  </div>

  <div class="info-item" style="padding-bottom: 16px;">
    <span class="info-label">发布标题</span>
    <span class="info-value" style="font-size: 13px; color: #cbd5e1;"><%= @jianying_task.title %></span>
  </div>
</div>

<!-- 视频下载 -->
<div class="admin-card" style="margin-top: 16px;">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">视频文件</div>
      <div class="admin-card-subtitle"><%= @jianying_task.oss_url %></div>
    </div>
    <div class="admin-card-header-right">
      <% if @video_url %>
        <a href="<%= @video_url %>" class="admin-button-primary" style="text-decoration: none;">下载视频</a>
        <button class="admin-button-secondary rn-copy-btn" data-url="<%= @video_url %>" style="margin-left: 8px;">复制链接</button>
      <% end %>
    </div>
  </div>
  <% if @video_url %>
    <div style="padding-top: 12px;">
      <video src="<%= @video_url %>" controls preload="metadata" crossorigin="anonymous"
             style="width: 100%; max-height: 640px; border-radius: 8px; background: #000;"></video>
      <div style="font-size: 11px; color: #64748b; margin-top: 6px;">如画面全黑有声音，请点击上方"下载视频"按钮下载后播放</div>
    </div>
  <% else %>
    <div class="admin-empty-state">暂无视频数据</div>
  <% end %>
</div>

<!-- 关联图片 -->
<div class="admin-card" style="margin-top: 16px;">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">关联图片</div>
      <div class="admin-card-subtitle">
        <% if @image_names.any? %>
          共 <%= @image_names.size %> 张
        <% else %>
          暂无关联图片
        <% end %>
      </div>
    </div>
  </div>
  <% if @image_names.any? %>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px; padding-top: 12px;">
      <% @image_names.each_with_index do |name, idx| %>
        <%
          url_data = @image_urls.find { |u| u[:name] == name }
          img_url = url_data ? url_data[:url] : nil
        %>
        <div style="border: 1px solid #334155; border-radius: 8px; overflow: hidden; background: rgba(15,23,42,0.5); transition: border-color 0.2s;" onmouseover="this.style.borderColor='#3b82f6'" onmouseout="this.style.borderColor='#334155'">
          <% if img_url %>
            <a href="<%= img_url %>" target="_blank" style="display: block; background: #000; height: 160px; overflow: hidden;">
              <img src="<%= img_url %>" alt="<%= name %>" loading="lazy"
                   style="width: 100%; height: 100%; object-fit: cover; display: block;"
                   onerror="this.parentElement.innerHTML='<div style=\'display:flex;align-items:center;justify-content:center;height:160px;color:#64748b;font-size:12px;\'>加载失败</div>'">
            </a>
          <% else %>
            <div style="display: flex; align-items: center; justify-content: center; height: 160px; color: #64748b; font-size: 12px; background: #000;">
              无签名
            </div>
          <% end %>
          <div style="padding: 8px 10px; display: flex; align-items: center; justify-content: space-between;">
            <code style="font-size: 11px; color: #94a3b8; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1;" title="<%= name %>"><%= name %></code>
            <% if img_url %>
              <button class="copy-link-btn" data-url="<%= img_url %>" style="flex-shrink: 0; background: rgba(59,130,246,0.12); border: 1px solid rgba(59,130,246,0.25); color: #60a5fa; border-radius: 4px; padding: 3px 6px; cursor: pointer;" title="复制链接">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
              </button>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="admin-empty-state">暂无关联图片</div>
  <% end %>
</div>

<style>
  .info-item { display: flex; flex-direction: column; gap: 2px; }
  .info-label { color: #64748b; font-size: 12px; }
  .info-value { color: #e2e8f0; font-size: 14px; }
</style>

<script>
document.addEventListener('click', function(e) {
  var btn = e.target.closest('.rn-copy-btn') || e.target.closest('.copy-link-btn');
  if (!btn) return;
  var url = btn.getAttribute('data-url') || '';
  var ta = document.createElement('textarea');
  ta.value = url;
  ta.style.position = 'fixed';
  ta.style.opacity = '0';
  document.body.appendChild(ta);
  ta.select();
  try {
    document.execCommand('copy');
    var orig = btn.textContent;
    btn.textContent = '已复制';
    setTimeout(function() { btn.textContent = orig; }, 1500);
  } catch(err) {}
  document.body.removeChild(ta);
});
</script>
