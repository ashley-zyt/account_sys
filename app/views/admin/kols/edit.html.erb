<% content_for :page_title, "编辑KOL" %>
<% content_for :page_subtitle, "修改KOL信息" %>

<div class="admin-card">
  <div class="admin-card-header">
    <div class="admin-card-title">
      <span class="admin-card-icon">👥</span>
      编辑KOL
    </div>
    <div class="admin-card-actions">
      <%= link_to "返回列表", admin_kols_path, class: "admin-btn admin-btn-outline" %>
    </div>
  </div>
  
  <div class="admin-card-body">
    <%= form_for [:admin, @kol] do |f| %>
      <div class="admin-form">
        <div class="admin-form-row">
          <div class="admin-form-group">
            <%= f.label :kol_name, class: "admin-form-label" %>
            <%= f.text_field :kol_name, class: "admin-input", placeholder: "KOL名称", required: true %>
          </div>
          <div class="admin-form-group">
            <%= f.label :nick_name, class: "admin-form-label" %>
            <%= f.text_field :nick_name, class: "admin-input", placeholder: "昵称" %>
          </div>
        </div>
        
        <div class="admin-form-row">
          <div class="admin-form-group">
            <%= f.label :location, class: "admin-form-label" %>
            <%= f.text_field :location, class: "admin-input", placeholder: "地区" %>
          </div>
          <div class="admin-form-group">
            <%= f.label :category, class: "admin-form-label" %>
            <%= f.text_field :category, class: "admin-input", placeholder: "类别" %>
          </div>
        </div>
        
        <div class="admin-form-group">
          <%= f.label :notes, class: "admin-form-label" %>
          <%= f.text_area :notes, rows: 4, class: "admin-textarea", placeholder: "备注信息" %>
        </div>
        
        <div class="admin-form-actions">
          <%= f.submit "保存修改", class: "admin-btn admin-btn-primary" %>
          <%= link_to "取消", admin_kols_path, class: "admin-btn admin-btn-outline" %>
        </div>
      </div>
    <% end %>
  </div>
</div>