<% content_for :page_title do %>
  编辑KOL
<% end %>
<% content_for :page_subtitle do %>
  修改 <%= @kol.kol_name %> 的信息
<% end %>

<%= form_with model: [:admin, @kol], class: "admin-form", id: "kol-form" do |f| %>
  <div class="admin-card">
    <div class="admin-card-header">
      <div>
        <div class="admin-card-title">
          KOL信息
        </div>
        <div class="admin-card-subtitle">
          修改KOL基础信息
        </div>
      </div>
    </div>

    <% if @kol.errors.any? %>
      <div class="admin-empty-state" style="margin-bottom: 12px;">
        <ul class="admin-list">
          <% @kol.errors.full_messages.each do |msg| %>
            <li class="admin-list-item">
              <div class="admin-list-title"><%= msg %></div>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="admin-two-column">
      <div>
        <div class="admin-field-label">KOL名称</div>
        <%= f.text_field :kol_name, class: "admin-input", placeholder: "输入KOL名称", required: true %>
      </div>
      <div>
        <div class="admin-field-label">昵称</div>
        <%= f.text_field :nick_name, class: "admin-input", placeholder: "输入昵称" %>
      </div>
      <div>
        <div class="admin-field-label">地区</div>
        <%= f.text_field :location, class: "admin-input", placeholder: "输入地区" %>
      </div>
      <div>
        <div class="admin-field-label">类别</div>
        <%= f.text_field :category, class: "admin-input", placeholder: "输入类别" %>
      </div>
    </div>

    <div style="margin-top: 16px;">
      <div class="admin-field-label">备注</div>
      <%= f.text_area :notes, rows: 4, class: "admin-input", placeholder: "输入备注信息" %>
    </div>
  </div>

  <div class="admin-card" style="margin-top: 20px;">
    <div class="admin-card-header">
      <div>
        <div class="admin-card-title">
          平台账号信息
        </div>
        <div class="admin-card-subtitle">
          管理KOL在各平台的账号信息
        </div>
      </div>
    </div>

    <div id="platform-accounts-wrapper">
      <%= f.fields_for :kol_platform_accounts do |account| %>
        <div class="platform-account-row" style="padding: 12px; margin-bottom: 12px; background: rgba(15, 23, 42, 0.5); border-radius: 8px; border: 1px solid rgba(31, 41, 55, 0.9);">
          <div class="admin-two-column">
            <div>
              <div class="admin-field-label">平台</div>
              <%= account.select :platform, KolPlatformAccount.platforms.map { |k, v| [k.humanize, k] }, {}, class: "admin-input" %>
            </div>
            <div>
              <div class="admin-field-label">平台昵称</div>
              <%= account.text_field :nick_name, class: "admin-input", placeholder: "输入平台昵称" %>
            </div>
            <div>
              <div class="admin-field-label">主页链接</div>
              <%= account.text_field :profile_url, class: "admin-input", placeholder: "输入主页链接" %>
            </div>
            <div>
              <div class="admin-field-label">粉丝数</div>
              <%= account.text_field :follower_count, class: "admin-input", placeholder: "输入粉丝数" %>
            </div>
          </div>
          <div style="margin-top: 8px;">
            <%= account.hidden_field :_destroy, value: 0 %>
            <button type="button" class="admin-button-secondary" style="padding: 4px 10px; margin-left: 0; color: var(--danger); border-color: rgba(239, 68, 68, 0.5);" onclick="removePlatformAccount(this)">删除</button>
          </div>
        </div>
      <% end %>
    </div>

    <div style="margin-top: 16px;">
      <button type="button" class="admin-button-secondary" onclick="addPlatformAccount()">+ 添加平台账号</button>
    </div>

    <template id="platform-account-template">
      <div class="platform-account-row" style="padding: 12px; margin-bottom: 12px; background: rgba(15, 23, 42, 0.5); border-radius: 8px; border: 1px solid rgba(31, 41, 55, 0.9);">
        <div class="admin-two-column">
          <div>
            <div class="admin-field-label">平台</div>
            <select class="admin-input" name="kol[kol_platform_accounts_attributes][INDEX][platform]">
              <option value="">选择平台</option>
              <% KolPlatformAccount.platforms.each do |k, v| %>
                <option value="<%= k %>"><%= k.humanize %></option>
              <% end %>
            </select>
          </div>
          <div>
            <div class="admin-field-label">平台昵称</div>
            <input type="text" class="admin-input" placeholder="输入平台昵称" name="kol[kol_platform_accounts_attributes][INDEX][nick_name]">
          </div>
          <div>
            <div class="admin-field-label">主页链接</div>
            <input type="text" class="admin-input" placeholder="输入主页链接" name="kol[kol_platform_accounts_attributes][INDEX][profile_url]">
          </div>
          <div>
            <div class="admin-field-label">粉丝数</div>
            <input type="text" class="admin-input" placeholder="输入粉丝数" name="kol[kol_platform_accounts_attributes][INDEX][follower_count]">
          </div>
        </div>
        <div style="margin-top: 8px;">
          <input type="hidden" value="0" name="kol[kol_platform_accounts_attributes][INDEX][_destroy]">
          <button type="button" class="admin-button-secondary" style="padding: 4px 10px; margin-left: 0; color: var(--danger); border-color: rgba(239, 68, 68, 0.5);" onclick="removePlatformAccount(this)">删除</button>
        </div>
      </div>
    </template>

    <div style="margin-top: 20px;">
      <button type="submit" class="admin-button-primary">保存修改</button>
      <%= link_to "取消", admin_kol_path(@kol), class: "admin-button-secondary" %>
    </div>
  </div>
<% end %>

<script>
  let platformAccountIndex = <%= @kol.kol_platform_accounts.count %>;

  function addPlatformAccount() {
    const wrapper = document.getElementById('platform-accounts-wrapper');
    const template = document.getElementById('platform-account-template');
    if (!template) return;

    const newRow = template.content.cloneNode(true);
    const html = newRow.firstElementChild.outerHTML.replace(/INDEX/g, platformAccountIndex++);

    wrapper.insertAdjacentHTML('beforeend', html);
  }

  function removePlatformAccount(btn) {
    const row = btn.closest('.platform-account-row');
    const wrapper = document.getElementById('platform-accounts-wrapper');
    const rows = wrapper.querySelectorAll('.platform-account-row:not([style*="display: none"])');

    if (rows.length > 1) {
      const destroyInput = row.querySelector('input[type="hidden"][value="0"]');
      if (destroyInput) {
        destroyInput.value = '1';
        row.style.display = 'none';
      } else {
        row.remove();
      }
    } else {
      row.querySelectorAll('input[type="text"]').forEach(input => input.value = '');
      row.querySelectorAll('select').forEach(select => select.selectedIndex = 0);
    }
  }
</script>