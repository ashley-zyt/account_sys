<% content_for :page_title do %>
  KOL列表
<% end %>
<% content_for :page_subtitle do %>
  管理KOL资源
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        KOL列表
      </div>
      <div class="admin-card-subtitle">
        管理和筛选KOL信息
      </div>
    </div>
    <div class="admin-card-header-right">
      <%= link_to "新增KOL", new_admin_kol_path, class: "admin-button-secondary" %>
      <span class="admin-tag">
        共 <%= @kols.total_count %> 条
      </span>
    </div>
  </div>

  <div class="admin-filter-form">
    <%= search_form_for @q, url: admin_kols_path, class: "admin-filter-form" do |f| %>
      <div class="admin-filter-group">
        <label class="admin-filter-label">KOL名称</label>
        <%= f.search_field :kol_name_cont, class: "admin-input admin-filter-input", placeholder: "搜索KOL名称..." %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">类别</label>
        <%= f.select :category_eq, @categories.map { |c| [c, c] }, { include_blank: "所有类别" }, class: "admin-input admin-filter-input" %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">地区</label>
        <%= f.select :location_eq, @locations.map { |l| [l, l] }, { include_blank: "所有地区" }, class: "admin-input admin-filter-input" %>
      </div>
      <div style="margin-left: auto; display: flex; gap: 8px; align-items: center;">
        <%= f.submit "筛选", class: "admin-button-primary" %>
        <%= link_to "重置", admin_kols_path, class: "admin-button-secondary" %>
        <button type="button" class="admin-button-primary" onclick="batchInitiateContact()">
          一键发起联系
        </button>
      </div>
    <% end %>
  </div>

  <% if @kols.any? %>
    <div class="admin-table-wrapper admin-table-scroll">
      <table class="admin-table">
        <thead>
          <tr>
            <th>KOL名称</th>
            <th>昵称</th>
            <th>地区</th>
            <th>类别</th>
            <th>平台数</th>
            <th>会话数</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @kols.each do |kol| %>
            <tr>
              <td>
                <%= link_to kol.kol_name, admin_kol_path(kol), class: "admin-link-quiet", style: "color: var(--accent);" %>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= kol.nick_name.presence || "-" %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= kol.location.presence || "-" %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= kol.category.presence || "-" %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= kol.kol_platform_accounts.count %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= kol.conversations.count %>
                </span>
              </td>
              <td>
                <div style="display: flex; gap: 8px; align-items: center;">
                  <%= link_to "详情", admin_kol_path(kol), class: "admin-link-quiet", style: "color: var(--accent);" %>
                  <form action="<%= admin_kol_path(kol) %>" method="POST" style="display: inline;" onsubmit="return confirm('确定要删除该KOL吗？这将同时删除相关的会话和消息，此操作不可撤销。')">
                    <input type="hidden" name="_method" value="DELETE">
                    <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
                    <button type="submit" style="padding: 4px 10px; font-size: 11px; background-color: #dc2626; color: white; border-radius: 4px; text-decoration: none; font-weight: 500; border: none; cursor: pointer;">
                      删除
                    </button>
                  </form>
                  <% if kol.kol_platform_accounts.any? && !kol.conversations.any? %>
                    <button type="button" class="admin-button-primary" style="padding: 4px 10px; font-size: 11px;" onclick="openInitiateModal(<%= kol.id %>)">
                      发起联系
                    </button>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="admin-pagination">
      <%= paginate @kols %>
    </div>
  <% else %>
    <div class="admin-empty-state">
      暂无KOL数据。
    </div>
  <% end %>
</div>

<div id="initiate-modal" class="admin-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.7); z-index: 1000; justify-content: center; align-items: center;">
  <div class="admin-modal-content" style="background: #1e293b; border-radius: 12px; width: 500px; max-width: 90%; max-height: 90%; overflow: hidden;">
    <iframe id="modal-iframe" style="width: 100%; height: 100%; border: none; min-height: 500px;" src=""></iframe>
  </div>
</div>

<script>
  function batchInitiateContact() {
    // 一键发起联系功能，待实现
    alert('一键发起联系功能开发中...');
  }

  function openInitiateModal(kolId) {
    const modal = document.getElementById('initiate-modal');
    const iframe = document.getElementById('modal-iframe');
    iframe.src = '/admin/kols/' + kolId + '/initiate_contact';
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeInitiateModal() {
    const modal = document.getElementById('initiate-modal');
    const iframe = document.getElementById('modal-iframe');
    modal.style.display = 'none';
    iframe.src = '';
    document.body.style.overflow = '';
  }

  function submitContactRequest(data) {
    closeInitiateModal();

    setTimeout(() => {
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = data.actionUrl;

      const csrfInput = document.createElement('input');
      csrfInput.type = 'hidden';
      csrfInput.name = 'authenticity_token';
      csrfInput.value = data.authenticity_token;
      form.appendChild(csrfInput);

      const kolAccountInput = document.createElement('input');
      kolAccountInput.type = 'hidden';
      kolAccountInput.name = 'kol_platform_account_id';
      kolAccountInput.value = data.kol_platform_account_id;
      form.appendChild(kolAccountInput);

      const templateInput = document.createElement('input');
      templateInput.type = 'hidden';
      templateInput.name = 'template_id';
      templateInput.value = data.template_id;
      form.appendChild(templateInput);

      document.body.appendChild(form);
      form.submit();
    }, 300);
  }

  document.getElementById('initiate-modal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeInitiateModal();
    }
  });
</script>