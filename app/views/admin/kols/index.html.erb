<% content_for :page_title, "KOL列表" %>
<% content_for :page_subtitle, "管理KOL资源" %>

<div class="admin-card">
  <div class="admin-card-header">
    <div class="admin-card-title">
      <span class="admin-card-icon">👥</span>
      KOL列表
    </div>
    <div class="admin-card-actions">
      <%= link_to "新增KOL", new_admin_kol_path, class: "admin-btn admin-btn-primary" %>
    </div>
  </div>
  
  <div class="admin-card-body">
    <div class="admin-search-bar">
      <%= search_form_for @q, url: admin_kols_path do |f| %>
        <div class="admin-search-row">
          <div class="admin-search-group">
            <%= f.label :kol_name_cont, class: "admin-search-label" %>
            <%= f.text_field :kol_name_cont, placeholder: "搜索KOL名称", class: "admin-input" %>
          </div>
          <div class="admin-search-group">
            <%= f.label :category_eq, class: "admin-search-label" %>
            <%= f.select :category_eq, options_for_select([["全部", ""]] + @categories.map { |c| [c, c] }), class: "admin-select" %>
          </div>
          <div class="admin-search-group">
            <%= f.label :location_eq, class: "admin-search-label" %>
            <%= f.select :location_eq, options_for_select([["全部", ""]] + @locations.map { |l| [l, l] }), class: "admin-select" %>
          </div>
          <div class="admin-search-group admin-search-submit">
            <%= f.submit "搜索", class: "admin-btn admin-btn-secondary" %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="admin-table-wrapper">
      <table class="admin-table">
        <thead>
          <tr>
            <th>KOL名称</th>
            <th>昵称</th>
            <th>地区</th>
            <th>类别</th>
            <th>平台数</th>
            <th>会话数</th>
            <th>状态</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @kols.each do |kol| %>
            <tr>
              <td><%= link_to kol.kol_name, admin_kol_path(kol), class: "admin-link" %></td>
              <td><%= kol.nick_name.presence || "-" %></td>
              <td><%= kol.location.presence || "-" %></td>
              <td><%= kol.category.presence || "-" %></td>
              <td><%= kol.kol_platform_accounts.count %></td>
              <td><%= kol.conversations.count %></td>
              <td>
                <% if kol.conversations.any? %>
                  <span class="admin-badge admin-badge-success">活跃</span>
                <% else %>
                  <span class="admin-badge admin-badge-secondary">待联系</span>
                <% end %>
              </td>
              <td>
                <div class="admin-actions">
                  <%= link_to "详情", admin_kol_path(kol), class: "admin-action-btn" %>
                  <%= link_to "编辑", edit_admin_kol_path(kol), class: "admin-action-btn" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @kols.empty? %>
      <div class="admin-empty-state">
        <div class="admin-empty-icon">👤</div>
        <div class="admin-empty-text">暂无KOL数据</div>
      </div>
    <% end %>

    <%= paginate @kols %>
  </div>
</div>