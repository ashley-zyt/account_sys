<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>发起联系</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: rgba(15, 23, 42, 0.95);
      color: #e2e8f0;
      padding: 20px;
    }
    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(71, 85, 105, 0.5);
    }
    .modal-title {
      font-size: 16px;
      font-weight: 600;
      color: #f1f5f9;
    }
    .modal-subtitle {
      font-size: 12px;
      color: #94a3b8;
      margin-top: 2px;
    }
    .close-btn {
      background: transparent;
      border: none;
      color: #64748b;
      font-size: 20px;
      cursor: pointer;
      padding: 4px 8px;
    }
    .close-btn:hover { color: #94a3b8; }
    .form-group {
      margin-bottom: 16px;
    }
    .form-label {
      display: block;
      font-size: 12px;
      font-weight: 500;
      color: #94a3b8;
      margin-bottom: 6px;
    }
    .form-select, .form-input {
      width: 100%;
      padding: 8px 12px;
      background: rgba(15, 23, 42, 0.8);
      border: 1px solid rgba(71, 85, 105, 0.8);
      border-radius: 6px;
      color: #e2e8f0;
      font-size: 13px;
    }
    .form-select:focus, .form-input:focus {
      outline: none;
      border-color: #3b82f6;
    }
    .platform-accounts {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
      max-height: 180px;
      overflow-y: auto;
      padding: 4px;
    }
    .platform-account-item {
      display: flex;
      align-items: center;
      padding: 8px 12px;
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid rgba(71, 85, 105, 0.6);
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.2s;
    }
    .platform-account-item:hover {
      border-color: #3b82f6;
      background: rgba(59, 130, 246, 0.1);
    }
    .platform-account-item.selected {
      border-color: #3b82f6;
      background: rgba(59, 130, 246, 0.2);
    }
    .platform-account-item input {
      display: none;
    }
    .platform-radio {
      width: 14px;
      height: 14px;
      border: 2px solid #64748b;
      border-radius: 50%;
      margin-right: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .platform-account-item.selected .platform-radio {
      border-color: #3b82f6;
    }
    .platform-account-item.selected .platform-radio::after {
      content: '';
      width: 6px;
      height: 6px;
      background: #3b82f6;
      border-radius: 50%;
    }
    .platform-info {
      flex: 1;
    }
    .platform-name {
      font-size: 12px;
      font-weight: 500;
      color: #e2e8f0;
    }
    .platform-nick {
      font-size: 11px;
      color: #64748b;
    }
    .message-preview {
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid rgba(71, 85, 105, 0.6);
      border-radius: 6px;
      padding: 12px;
      font-size: 13px;
      color: #cbd5e1;
      max-height: 120px;
      overflow-y: auto;
      line-height: 1.5;
    }
    .modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 8px;
      margin-top: 20px;
      padding-top: 16px;
      border-top: 1px solid rgba(71, 85, 105, 0.5);
    }
    .btn {
      padding: 8px 16px;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-secondary {
      background: transparent;
      border: 1px solid rgba(71, 85, 105, 0.8);
      color: #94a3b8;
    }
    .btn-secondary:hover {
      background: rgba(71, 85, 105, 0.2);
      color: #e2e8f0;
    }
    .btn-primary {
      background: #3b82f6;
      border: 1px solid #3b82f6;
      color: #fff;
    }
    .btn-primary:hover {
      background: #2563eb;
    }
    .btn-primary:disabled {
      background: #1e3a5f;
      border-color: #1e3a5f;
      color: #64748b;
      cursor: not-allowed;
    }
  </style>
</head>
<body>
  <div class="modal-header">
    <div>
      <div class="modal-title">发起联系</div>
      <div class="modal-subtitle">为 <%= @kol.kol_name %> 创建新的会话</div>
    </div>
    <button class="close-btn" onclick="closeModal()">&times;</button>
  </div>

  <form id="contact-form" action="<%= start_conversation_admin_kol_path(@kol) %>" method="POST">
    <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

    <div class="form-group">
      <label class="form-label">选择平台账号</label>
      <div class="platform-accounts">
        <% @platform_accounts.each do |account| %>
          <label class="platform-account-item">
            <input type="radio" name="kol_platform_account_id" value="<%= account.id %>" required>
            <div class="platform-radio"></div>
            <div class="platform-info">
              <div class="platform-name"><%= account.platform.humanize %></div>
              <div class="platform-nick">@<%= account.nick_name %></div>
            </div>
          </label>
        <% end %>
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">选择消息模板</label>
      <select name="template_id" id="template-select" class="form-select" required onchange="updatePreview()">
        <option value="">选择消息模板</option>
        <% @templates.each do |template| %>
          <option value="<%= template.id %>" data-content="<%= template.content %>">
            <%= template.platform.humanize %> - <%= template.template_type.humanize %> (<%= template.language.upcase %>)
          </option>
        <% end %>
      </select>
    </div>

    <div class="form-group">
      <label class="form-label">消息预览</label>
      <div id="message-preview" class="message-preview">请选择消息模板查看预览</div>
    </div>

    <div class="modal-footer">
      <button type="button" class="btn btn-secondary" onclick="closeModal()">取消</button>
      <button type="button" class="btn btn-primary" id="submit-btn" disabled onclick="submitForm()">发起会话</button>
    </div>
  </form>

  <script>
    const radios = document.querySelectorAll('input[name="kol_platform_account_id"]');
    radios.forEach(radio => {
      radio.addEventListener('change', updateSubmitState);
    });

    function updateSubmitState() {
      const accountSelected = document.querySelector('input[name="kol_platform_account_id"]:checked');
      const templateSelect = document.querySelector('select[name="template_id"]').value;
      const submitBtn = document.getElementById('submit-btn');
      submitBtn.disabled = !(accountSelected && templateSelect);
    }

    document.getElementById('template-select').addEventListener('change', updateSubmitState);

    function updatePreview() {
      const select = document.getElementById('template-select');
      const preview = document.getElementById('message-preview');
      const option = select.options[select.selectedIndex];
      if (option && option.dataset.content) {
        preview.textContent = option.dataset.content;
      } else {
        preview.textContent = '请选择消息模板查看预览';
      }
      updateSubmitState();
    }

    document.querySelectorAll('.platform-account-item').forEach(item => {
      item.addEventListener('click', function() {
        this.querySelector('input').checked = true;
        this.classList.add('selected');
        document.querySelectorAll('.platform-account-item').forEach(other => {
          if (other !== this) other.classList.remove('selected');
        });
        updateSubmitState();
      });
    });

    function closeModal() {
      if (window.parent && window.parent.closeInitiateModal) {
        window.parent.closeInitiateModal();
      } else {
        window.close();
      }
    }

    function submitForm() {
      const form = document.getElementById('contact-form');
      const kolPlatformAccountId = document.querySelector('input[name="kol_platform_account_id"]:checked').value;
      const templateId = document.getElementById('template-select').value;
      const actionUrl = form.action;
      const csrfToken = document.querySelector('input[name="authenticity_token"]').value;

      if (window.parent && window.parent.submitContactRequest) {
        window.parent.submitContactRequest({
          actionUrl: actionUrl,
          authenticity_token: csrfToken,
          kol_platform_account_id: kolPlatformAccountId,
          template_id: templateId
        });
      } else {
        const submitFormElement = document.createElement('form');
        submitFormElement.method = 'POST';
        submitFormElement.action = actionUrl;

        const csrfInput = document.createElement('input');
        csrfInput.type = 'hidden';
        csrfInput.name = 'authenticity_token';
        csrfInput.value = csrfToken;
        submitFormElement.appendChild(csrfInput);

        const kolAccountInput = document.createElement('input');
        kolAccountInput.type = 'hidden';
        kolAccountInput.name = 'kol_platform_account_id';
        kolAccountInput.value = kolPlatformAccountId;
        submitFormElement.appendChild(kolAccountInput);

        const templateInput = document.createElement('input');
        templateInput.type = 'hidden';
        templateInput.name = 'template_id';
        templateInput.value = templateId;
        submitFormElement.appendChild(templateInput);

        document.body.appendChild(submitFormElement);
        submitFormElement.submit();
      }
    }
  </script>
</body>
</html>