<% content_for :page_title do %>
  KOL详情
<% end %>
<% content_for :page_subtitle do %>
  <%= @kol.kol_name %> 的基础信息与平台账号
<% end %>

<div class="admin-grid">
  <div class="admin-card">
    <div class="admin-card-header">
      <div>
        <div class="admin-card-title">
          基本信息
        </div>
        <div class="admin-card-subtitle">
          KOL基础资料
        </div>
      </div>
      <div class="admin-card-header-right">
        <%= link_to "编辑KOL", edit_admin_kol_path(@kol), class: "admin-button-secondary" %>
      </div>
    </div>

    <div class="admin-two-column">
      <div>
        <div class="admin-field-label">KOL名称</div>
        <div class="admin-field-value"><%= @kol.kol_name %></div>
      </div>
      <div>
        <div class="admin-field-label">昵称</div>
        <div class="admin-field-value"><%= @kol.nick_name.presence || "-" %></div>
      </div>
      <div>
        <div class="admin-field-label">地区</div>
        <div class="admin-field-value"><%= @kol.location.presence || "-" %></div>
      </div>
      <div>
        <div class="admin-field-label">类别</div>
        <div class="admin-field-value"><%= @kol.category.presence || "-" %></div>
      </div>
      <div>
        <div class="admin-field-label">创建时间</div>
        <div class="admin-field-value"><%= @kol.created_at&.strftime("%Y-%m-%d %H:%M") %></div>
      </div>
      <div>
        <div class="admin-field-label">会话数</div>
        <div class="admin-field-value"><%= @kol.conversations.count %></div>
      </div>
      <div class="admin-two-column" style="grid-column: span 2;">
        <div>
          <div class="admin-field-label">备注</div>
          <div class="admin-field-value"><%= @kol.notes.presence || "无" %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="admin-card">
    <div class="admin-card-header">
      <div>
        <div class="admin-card-title">
          历史会话
        </div>
        <div class="admin-card-subtitle">
          该KOL关联的会话记录
        </div>
      </div>
    </div>

    <% if @conversations.any? %>
      <div class="admin-table-wrapper admin-table-scroll">
        <table class="admin-table">
          <thead>
            <tr>
              <th>平台</th>
              <th>状态</th>
              <th>最后消息</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @conversations.each do |conv| %>
              <tr>
                <td><span class="admin-label-muted"><%= conv.platform.humanize %></span></td>
                <td><span class="admin-badge"><%= conv.status.humanize %></span></td>
                <td><span class="admin-label-muted"><%= conv.last_message_at&.strftime("%m-%d %H:%M") || "暂无" %></span></td>
                <td><%= link_to "查看", admin_conversation_path(conv), class: "admin-link-quiet", style: "color: var(--accent);" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="admin-empty-state">暂无会话记录。</div>
    <% end %>
  </div>
</div>

<div class="admin-card" style="margin-top: 20px;">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        平台账号列表
      </div>
      <div class="admin-card-subtitle">
        KOL在各平台的账号信息
      </div>
    </div>
  </div>

  <% if @platform_accounts.any? %>
    <div class="admin-table-wrapper admin-table-scroll">
      <table class="admin-table">
        <thead>
          <tr>
            <th>平台</th>
            <th>昵称</th>
            <th>粉丝数</th>
            <th>主页链接</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @platform_accounts.each do |account| %>
            <tr>
              <td><span class="admin-label-muted"><%= account.platform.humanize %></span></td>
              <td><span class="admin-label-muted">@<%= account.nick_name %></span></td>
              <td><span class="admin-label-muted"><%= account.follower_count.presence || "-" %></span></td>
              <td>
                <% if account.profile_url.present? %>
                  <%= link_to "访问主页", account.profile_url, class: "admin-link-quiet", style: "color: var(--accent);", target: "_blank" %>
                <% else %>
                  <span class="admin-label-muted">-</span>
                <% end %>
              </td>
              <td>
                <% if @kol.conversations.where(kol_platform_account_id: account.id).none? %>
                  <button type="button" class="admin-button-primary" style="padding: 4px 10px; font-size: 11px;" onclick="openContactModal('<%= account.platform %>', <%= account.id %>, '<%= account.nick_name %>')">发起联系</button>
                <% else %>
                  <span class="admin-label-muted">已有会话</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="admin-empty-state">暂无平台账号。</div>
  <% end %>
</div>

<div id="contact-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1000;">
  <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7);" onclick="closeContactModal()"></div>
  <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 500px; background: #1e293b; border-radius: 12px; padding: 24px; box-sizing: border-box;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
      <div style="font-size: 16px; font-weight: 600; color: #f1f5f9;">发起联系</div>
      <button onclick="closeContactModal()" style="background: none; border: none; color: #64748b; cursor: pointer; font-size: 20px;">&times;</button>
    </div>
    <input type="hidden" id="contact-kol-platform-account-id">
    <div style="margin-bottom: 12px;">
      <div style="font-size: 12px; color: #94a3b8; margin-bottom: 4px;">KOL</div>
      <div style="font-size: 14px; color: #e2e8f0;"><%= @kol.kol_name %></div>
    </div>
    <div style="margin-bottom: 12px;">
      <div style="font-size: 12px; color: #94a3b8; margin-bottom: 4px;">平台账号</div>
      <div style="font-size: 14px; color: #e2e8f0;" id="contact-account-display">-</div>
    </div>
    <div style="margin-bottom: 12px;">
      <div style="font-size: 12px; color: #94a3b8; margin-bottom: 6px;">消息模式</div>
      <div style="display: flex; gap: 8px; background: rgba(15, 23, 42, 0.6); border: 1px solid rgba(71, 85, 105, 0.6); border-radius: 6px; padding: 4px;">
        <button type="button" id="mode-template-btn" style="flex: 1; padding: 6px 12px; background: #3b82f6; border: none; border-radius: 4px; color: #fff; font-size: 12px; cursor: pointer;" onclick="switchContactMode('template')">使用模板</button>
        <button type="button" id="mode-custom-btn" style="flex: 1; padding: 6px 12px; background: transparent; border: none; border-radius: 4px; color: #94a3b8; font-size: 12px; cursor: pointer;" onclick="switchContactMode('custom')">自定义消息</button>
      </div>
    </div>
    <div id="contact-template-section" style="margin-bottom: 12px;">
      <div style="font-size: 12px; color: #94a3b8; margin-bottom: 6px;">选择模板</div>
      <select id="contact-template" class="admin-input" style="width: 100%; padding: 8px 12px; background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(71, 85, 105, 0.8); border-radius: 6px; color: #e2e8f0; font-size: 13px;">
        <option value="">请选择模板</option>
        <% @templates.each do |template| %>
          <option value="<%= template.id %>" data-content="<%= template.content %>"><%= template.platform.humanize %> - <%= template.template_type.humanize %></option>
        <% end %>
      </select>
    </div>
    <div id="contact-custom-section" style="margin-bottom: 12px; display: none;">
      <div style="font-size: 12px; color: #94a3b8; margin-bottom: 6px;">自定义消息</div>
      <textarea id="contact-custom-message" style="width: 100%; padding: 8px 12px; background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(71, 85, 105, 0.8); border-radius: 6px; color: #e2e8f0; font-size: 13px; min-height: 100px; resize: vertical;" placeholder="请输入自定义消息内容..."></textarea>
    </div>
    <div style="margin-bottom: 16px;">
      <div style="font-size: 12px; color: #94a3b8; margin-bottom: 6px;">消息预览</div>
      <div id="contact-preview" style="padding: 12px; background: rgba(15, 23, 42, 0.6); border: 1px solid rgba(71, 85, 105, 0.6); border-radius: 6px; font-size: 13px; color: #cbd5e1; line-height: 1.5;">请选择模板或输入自定义消息</div>
    </div>
    <div style="display: flex; gap: 8px; justify-content: flex-end;">
      <button onclick="closeContactModal()" style="padding: 8px 16px; background: transparent; border: 1px solid rgba(71, 85, 105, 0.8); border-radius: 6px; color: #94a3b8; cursor: pointer; font-size: 13px;">取消</button>
      <button onclick="sendContact()" id="send-btn" disabled style="padding: 8px 16px; background: #1e3a5f; border: 1px solid #1e3a5f; border-radius: 6px; color: #64748b; cursor: not-allowed; font-size: 13px;">发起会话</button>
    </div>
  </div>
</div>

<script>
  function openContactModal(platform, accountId, nickName) {
    document.getElementById('contact-kol-platform-account-id').value = accountId;
    document.getElementById('contact-account-display').textContent = platform.replace('_', ' ').toUpperCase() + ' @' + nickName;
    document.getElementById('contact-preview').textContent = '请选择模板或输入自定义消息';
    document.getElementById('contact-template').value = '';
    document.getElementById('contact-custom-message').value = '';
    document.getElementById('send-btn').disabled = true;
    document.getElementById('send-btn').style.background = '#1e3a5f';
    document.getElementById('send-btn').style.borderColor = '#1e3a5f';
    document.getElementById('send-btn').style.color = '#64748b';
    document.getElementById('send-btn').style.cursor = 'not-allowed';
    document.getElementById('contact-template-section').style.display = 'block';
    document.getElementById('contact-custom-section').style.display = 'none';
    document.getElementById('mode-template-btn').style.background = '#3b82f6';
    document.getElementById('mode-template-btn').style.color = '#fff';
    document.getElementById('mode-custom-btn').style.background = 'transparent';
    document.getElementById('mode-custom-btn').style.color = '#94a3b8';
    document.getElementById('contact-modal').style.display = 'block';
  }

  function closeContactModal() {
    document.getElementById('contact-modal').style.display = 'none';
  }

  function switchContactMode(mode) {
    const templateBtn = document.getElementById('mode-template-btn');
    const customBtn = document.getElementById('mode-custom-btn');
    const templateSection = document.getElementById('contact-template-section');
    const customSection = document.getElementById('contact-custom-section');

    if (mode === 'template') {
      templateBtn.style.background = '#3b82f6';
      templateBtn.style.color = '#fff';
      customBtn.style.background = 'transparent';
      customBtn.style.color = '#94a3b8';
      templateSection.style.display = 'block';
      customSection.style.display = 'none';
      document.getElementById('contact-custom-message').value = '';
    } else {
      templateBtn.style.background = 'transparent';
      templateBtn.style.color = '#94a3b8';
      customBtn.style.background = '#3b82f6';
      customBtn.style.color = '#fff';
      templateSection.style.display = 'none';
      customSection.style.display = 'block';
      document.getElementById('contact-template').value = '';
    }
    updateSendBtnState();
  }

  function updateSendBtnState() {
    const templateBtn = document.getElementById('mode-template-btn');
    const templateSelected = document.getElementById('contact-template').value;
    const customMessage = document.getElementById('contact-custom-message').value.trim();
    const sendBtn = document.getElementById('send-btn');
    
    let valid = false;
    if (templateBtn.style.background === 'rgb(59, 130, 246)') {
      valid = templateSelected !== '';
    } else {
      valid = customMessage !== '';
    }
    
    if (valid) {
      sendBtn.disabled = false;
      sendBtn.style.background = '#3b82f6';
      sendBtn.style.borderColor = '#3b82f6';
      sendBtn.style.color = '#fff';
      sendBtn.style.cursor = 'pointer';
    } else {
      sendBtn.disabled = true;
      sendBtn.style.background = '#1e3a5f';
      sendBtn.style.borderColor = '#1e3a5f';
      sendBtn.style.color = '#64748b';
      sendBtn.style.cursor = 'not-allowed';
    }
  }

  document.getElementById('contact-template').addEventListener('change', function() {
    const preview = document.getElementById('contact-preview');
    const selectedOption = this.options[this.selectedIndex];
    if (this.value && selectedOption && selectedOption.dataset.content) {
      preview.textContent = selectedOption.dataset.content;
    } else {
      preview.textContent = '请选择模板查看预览';
    }
    updateSendBtnState();
  });

  document.getElementById('contact-custom-message').addEventListener('input', function() {
    const preview = document.getElementById('contact-preview');
    preview.textContent = this.value || '请输入自定义消息';
    updateSendBtnState();
  });

  function sendContact() {
    const templateId = document.getElementById('contact-template').value;
    const customMessage = document.getElementById('contact-custom-message').value.trim();
    const kolPlatformAccountId = document.getElementById('contact-kol-platform-account-id').value;

    closeContactModal();

    setTimeout(() => {
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = '<%= start_conversation_admin_kol_path(@kol) %>';

      const csrfToken = document.createElement('input');
      csrfToken.type = 'hidden';
      csrfToken.name = 'authenticity_token';
      csrfToken.value = '<%= form_authenticity_token %>';
      form.appendChild(csrfToken);

      const templateInput = document.createElement('input');
      templateInput.type = 'hidden';
      templateInput.name = 'template_id';
      templateInput.value = templateId;
      form.appendChild(templateInput);

      const customInput = document.createElement('input');
      customInput.type = 'hidden';
      customInput.name = 'custom_message';
      customInput.value = customMessage;
      form.appendChild(customInput);

      const kolAccountInput = document.createElement('input');
      kolAccountInput.type = 'hidden';
      kolAccountInput.name = 'kol_platform_account_id';
      kolAccountInput.value = kolPlatformAccountId;
      form.appendChild(kolAccountInput);

      document.body.appendChild(form);
      form.submit();
    }, 300);
  }
</script>