<% content_for :page_title do %>
  编辑消息模板
<% end %>
<% content_for :page_subtitle do %>
  修改模板信息
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        模板信息
      </div>
      <div class="admin-card-subtitle">
        修改模板内容
      </div>
    </div>
  </div>

  <%= form_with model: [:admin, @template], class: "admin-form" do |f| %>
    <% if @template.errors.any? %>
      <div class="admin-empty-state" style="margin-bottom: 12px;">
        <ul class="admin-list">
          <% @template.errors.full_messages.each do |msg| %>
            <li class="admin-list-item">
              <div class="admin-list-title"><%= msg %></div>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="admin-two-column">
      <div>
        <div class="admin-field-label">平台</div>
        <%= f.select :platform, @platforms.map { |k, v| [k.humanize, k] }, {}, class: "admin-input", required: true %>
      </div>
      <div>
        <div class="admin-field-label">模板类型</div>
        <%= f.select :template_type, @template_types.map { |k, v| [k.humanize, k] }, {}, class: "admin-input", required: true %>
      </div>
      <div>
        <div class="admin-field-label">语言</div>
        <%= f.text_field :language, class: "admin-input", placeholder: "语言代码" %>
      </div>
    </div>

    <div style="margin-top: 16px;">
      <div class="admin-field-label">模板内容</div>
      <%= f.text_area :content, rows: 6, class: "admin-input", placeholder: "输入消息模板内容", required: true %>
    </div>

    <div style="margin-top: 20px;">
      <button type="submit" class="admin-button-primary">保存修改</button>
      <%= link_to "取消", admin_message_templates_path, class: "admin-button-secondary" %>
    </div>
  <% end %>
</div>