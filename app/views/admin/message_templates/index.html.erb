<% content_for :page_title do %>
  消息模板
<% end %>
<% content_for :page_subtitle do %>
  管理消息模板
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        模板列表
      </div>
      <div class="admin-card-subtitle">
        管理和筛选消息模板
      </div>
    </div>
    <div class="admin-card-header-right">
      <%= link_to "新建模板", new_admin_message_template_path, class: "admin-button-secondary" %>
      <span class="admin-tag">
        共 <%= @templates.total_count %> 条
      </span>
    </div>
  </div>

  <div class="admin-filter-form">
    <%= search_form_for @q, url: admin_message_templates_path, class: "admin-filter-form" do |f| %>
      <div class="admin-filter-group">
        <label class="admin-filter-label">平台</label>
        <%= f.select :platform_eq, @platforms.map { |p| [p.humanize, p] }, { include_blank: "所有平台" }, class: "admin-input admin-filter-input" %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">类型</label>
        <%= f.select :template_type_eq, @template_types.map { |t| [t.humanize, t] }, { include_blank: "所有类型" }, class: "admin-input admin-filter-input" %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">语言</label>
        <%= f.select :language_eq, @languages.map { |l| [l.upcase, l] }, { include_blank: "所有语言" }, class: "admin-input admin-filter-input" %>
      </div>
      <div style="margin-left: auto;">
        <%= f.submit "筛选", class: "admin-button-primary" %>
        <%= link_to "重置", admin_message_templates_path, class: "admin-button-secondary" %>
      </div>
    <% end %>
  </div>

  <% if @templates.any? %>
    <div class="admin-table-wrapper admin-table-scroll">
      <table class="admin-table">
        <thead>
          <tr>
            <th>平台</th>
            <th>类型</th>
            <th>语言</th>
            <th>内容预览</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @templates.each do |template| %>
            <tr>
              <td><span class="admin-label-muted"><%= template.platform.humanize %></span></td>
              <td><span class="admin-label-muted"><%= template.template_type.humanize %></span></td>
              <td><span class="admin-label-muted"><%= template.language.upcase %></span></td>
              <td><span class="admin-label-muted"><%= template.content.truncate(50) %></span></td>
              <td>
                <div style="display: flex; gap: 8px;">
                  <%= link_to "编辑", edit_admin_message_template_path(template), class: "admin-link-quiet", style: "color: var(--accent);" %>
                  <%= link_to "删除", admin_message_template_path(template), method: :delete, data: { confirm: "确定删除此模板？" }, class: "admin-link-quiet", style: "color: var(--danger);" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="admin-pagination">
      <%= paginate @templates %>
    </div>
  <% else %>
    <div class="admin-empty-state">
      暂无消息模板。
    </div>
  <% end %>
</div>