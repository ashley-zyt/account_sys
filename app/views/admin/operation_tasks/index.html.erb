<% content_for :page_title do %>
  运营任务储备
<% end %>
<% content_for :page_subtitle do %>
  运营人员剪辑的视频资源队列
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        任务列表
      </div>
      <div class="admin-card-subtitle">
        监控和筛选运营任务队列
      </div>
    </div>
    <div class="admin-card-header-right">
      <%= link_to "新增", new_admin_operation_task_path, class: "admin-button-primary" %>
      <span class="admin-tag">
        共 <%= @operation_tasks.total_count %> 条
      </span>
    </div>
  </div>

  <div class="admin-filter-form">
    <%= search_form_for [:admin, @q], class: "admin-filter-form" do |f| %>
      <div class="admin-filter-group">
        <label class="admin-filter-label">标题/UUID</label>
        <%= f.search_field :title_or_task_uuid_cont, class: "admin-input admin-filter-input", placeholder: "搜索标题或UUID..." %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">主题</label>
        <%= f.search_field :theme_cont, class: "admin-input admin-filter-input", placeholder: "搜索主题..." %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">平台</label>
        <%= f.select :platform_eq, OperationTask.platforms.map { |k, v| [k.to_s.titleize, k] }, { include_blank: "所有平台" }, class: "admin-input admin-filter-input" %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">状态</label>
        <%= f.select :status_eq, OperationTask.statuses.map { |k, v| [k.to_s.titleize, k] }, { include_blank: "所有状态" }, class: "admin-input admin-filter-input" %>
      </div>
      <div style="margin-left: auto;">
        <%= f.submit "筛选", class: "admin-button-primary" %>
        <%= link_to "重置", admin_operation_tasks_path, class: "admin-button-secondary" %>
      </div>
    <% end %>
  </div>

  <% if @operation_tasks.any? %>
    <div class="admin-table-wrapper admin-table-scroll">
      <table class="admin-table">
        <thead>
          <tr>
            <th>
              ID
            </th>
            <th>
              任务标题
            </th>
            <th>
              内容主题
            </th>
            <th>
              平台
            </th>
            <th>
              状态
            </th>
            <th>
              账号
            </th>
            <th>
              创建时间
            </th>
            <th>
              操作
            </th>
          </tr>
        </thead>
        <tbody>
          <% @operation_tasks.each do |task| %>
            <tr>
              <td>
                <span class="admin-label-muted">
                  <%= task.id %>
                </span>
              </td>
              <td>
                <%= link_to truncate(task.title.presence || task.oss_url, length: 40), admin_operation_task_path(task), class: "admin-link-quiet" %>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= task.theme %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= task.platform %>
                </span>
              </td>
              <td>
                <% case task.status %>
                <% when "pending" %>
                  <span class="admin-pill-status admin-pill-status-pending">
                    <span class="admin-pill-status-dot"></span>
                    待发布
                  </span>
                <% when "processing" %>
                  <span class="admin-pill-status admin-pill-status-pending">
                    <span class="admin-pill-status-dot"></span>
                    处理中
                  </span>
                <% when "completed" %>
                  <span class="admin-pill-status admin-pill-status-success">
                    <span class="admin-pill-status-dot"></span>
                    已完成
                  </span>
                <% when "failed" %>
                  <span class="admin-pill-status admin-pill-status-failed">
                    <span class="admin-pill-status-dot"></span>
                    失败
                  </span>
                <% end %>
              </td>
              <td>
                <% if task.account %>
                  <%= link_to task.account.account_name, admin_account_path(task.account), class: "admin-link-quiet" %>
                <% else %>
                  <span class="admin-label-muted">
                    未分配
                  </span>
                <% end %>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= task.created_at&.strftime("%m-%d %H:%M") %>
                </span>
              </td>
              <td>
                <div style="display: flex; gap: 8px;">
                  <%= link_to "详情", admin_operation_task_path(task), class: "admin-link-quiet", style: "color: var(--accent);" %>
                  <%= link_to "日志", admin_task_logs_path(q: { task_uuid_eq: task.task_uuid }), class: "admin-link-quiet", style: "color: var(--accent);" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="admin-pagination">
      <%= paginate @operation_tasks %>
    </div>
  <% else %>
    <div class="admin-empty-state">
      暂无任务数据。
    </div>
  <% end %>
</div>