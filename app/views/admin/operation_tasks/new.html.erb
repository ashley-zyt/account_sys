<% content_for :page_title do %>
  添加运营资源
<% end %>
<% content_for :page_subtitle do %>
  上传运营剪辑的视频到资源队列
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        新增运营视频
      </div>
      <div class="admin-card-subtitle">
        填写主题、标题并上传视频文件
      </div>
    </div>
  </div>

  <%= form_with(model: [:admin, @operation_task], url: admin_operation_tasks_path, html: { multipart: true }) do |form| %>
    <div class="admin-form-group">
      <label class="admin-form-label">
        主题 <span style="color: #ef4444;">*</span>
      </label>
      <%= form.text_field :theme, class: "admin-input", placeholder: "请输入主题，如：中国美食制作", required: true %>
    </div>

    <div class="admin-form-group">
      <label class="admin-form-label">
        标题 <span style="color: #ef4444;">*</span>
      </label>
      <%= form.text_field :title, class: "admin-input", placeholder: "请输入发布标题", required: true %>
    </div>

    <div class="admin-form-group">
      <label class="admin-form-label">
        视频文件 <span style="color: #ef4444;">*</span>
      </label>
      <div class="upload-container">
        <input type="file" name="video_file" id="video-upload-input" accept="video/*" class="video-upload-input" required>
        <label for="video-upload-input" class="upload-label" id="upload-label">
          <div class="upload-icon">🎬</div>
          <div class="upload-text" id="upload-text">点击选择视频文件</div>
          <div class="upload-hint">支持 MP4、MOV、AVI 等格式</div>
        </label>
      </div>
      <div id="selected-file-info" style="margin-top: 8px; display: none;">
        <span style="color: #22c55e;">✓</span>
        <span id="file-name" style="margin-left: 8px; color: #cbd5e1;"></span>
        <button type="button" id="clear-file" style="margin-left: 12px; color: #ef4444; font-size: 12px; background: none; border: none; cursor: pointer;">清除</button>
      </div>
    </div>

    <div class="admin-form-actions">
      <%= link_to "取消", admin_operation_tasks_path, class: "admin-button-secondary" %>
      <%= form.submit "提交", class: "admin-button-primary" %>
    </div>
  <% end %>
</div>

<style>
  .upload-container {
    position: relative;
  }

  .video-upload-input {
    display: none;
  }

  .upload-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 2px dashed #475569;
    border-radius: 8px;
    padding: 32px;
    cursor: pointer;
    transition: all 0.2s;
    background: rgba(30, 41, 59, 0.5);
    min-height: 140px;
  }

  .upload-label:hover {
    border-color: #3b82f6;
    background: rgba(59, 130, 246, 0.1);
  }

  .upload-label.dragover {
    border-color: #3b82f6;
    background: rgba(59, 130, 246, 0.15);
  }

  .upload-icon {
    font-size: 48px;
    margin-bottom: 12px;
  }

  .upload-text {
    font-size: 14px;
    color: #cbd5e1;
    margin-bottom: 4px;
  }

  .upload-hint {
    font-size: 12px;
    color: #64748b;
  }

  .admin-form-group {
    margin-bottom: 16px;
  }

  .admin-form-label {
    display: block;
    margin-bottom: 6px;
    font-size: 13px;
    color: #94a3b8;
  }

  .admin-form-actions {
    display: flex;
    gap: 12px;
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid #334155;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const fileInput = document.getElementById('video-upload-input');
    const uploadLabel = document.getElementById('upload-label');
    const uploadText = document.getElementById('upload-text');
    const selectedFileInfo = document.getElementById('selected-file-info');
    const fileName = document.getElementById('file-name');
    const clearFile = document.getElementById('clear-file');

    // 拖拽相关事件
    uploadLabel.addEventListener('dragover', function(e) {
      e.preventDefault();
      e.stopPropagation();
      uploadLabel.classList.add('dragover');
    });

    uploadLabel.addEventListener('dragleave', function(e) {
      e.preventDefault();
      e.stopPropagation();
      uploadLabel.classList.remove('dragover');
    });

    uploadLabel.addEventListener('drop', function(e) {
      e.preventDefault();
      e.stopPropagation();
      uploadLabel.classList.remove('dragover');
      
      const files = e.dataTransfer.files;
      if (files.length > 0 && files[0].type.startsWith('video/')) {
        fileInput.files = files;
        updateFileInfo(files[0]);
      } else if (files.length > 0) {
        alert('请选择视频文件');
      }
    });

    // 文件选择事件
    fileInput.addEventListener('change', function(e) {
      if (this.files.length > 0) {
        updateFileInfo(this.files[0]);
      }
    });

    // 清除文件
    clearFile.addEventListener('click', function() {
      fileInput.value = '';
      uploadLabel.style.borderColor = '#475569';
      uploadText.textContent = '点击选择视频文件';
      uploadLabel.innerHTML = `
        <div class="upload-icon">🎬</div>
        <div class="upload-text" id="upload-text">点击选择视频文件</div>
        <div class="upload-hint">支持 MP4、MOV、AVI 等格式</div>
      `;
      selectedFileInfo.style.display = 'none';
    });

    function updateFileInfo(file) {
      uploadLabel.style.borderColor = '#22c55e';
      uploadLabel.innerHTML = `
        <div class="upload-icon">✓</div>
        <div class="upload-text" id="upload-text">已选择: ${file.name}</div>
        <div class="upload-hint">点击可更换文件</div>
      `;
      fileName.textContent = file.name;
      selectedFileInfo.style.display = 'flex';
      selectedFileInfo.style.alignItems = 'center';
    }
  });
</script>