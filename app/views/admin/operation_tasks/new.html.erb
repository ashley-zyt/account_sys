<% content_for :page_title do %>
  添加运营资源
<% end %>
<% content_for :page_subtitle do %>
  上传运营剪辑的视频到资源队列
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        新增运营视频
      </div>
      <div class="admin-card-subtitle">
        填写主题、标题并上传视频文件
      </div>
    </div>
  </div>

  <%= form_with(model: [:admin, @operation_task], url: admin_operation_tasks_path, html: { multipart: true }) do |form| %>
    <div class="admin-form-group">
      <label class="admin-form-label">
        主题 <span style="color: #ef4444;">*</span>
      </label>
      <%= form.text_field :theme, class: "admin-input", placeholder: "请输入主题，如：中国美食制作", required: true %>
    </div>

    <div class="admin-form-group">
      <label class="admin-form-label">
        标题 <span style="color: #ef4444;">*</span>
      </label>
      <%= form.text_field :title, class: "admin-input", placeholder: "请输入发布标题", required: true %>
    </div>

    <div class="admin-form-group">
      <label class="admin-form-label">
        视频文件 <span style="color: #ef4444;">*</span>
      </label>
      <div class="upload-wrapper">
        <label for="video-upload-input" class="upload-box">
          <div class="upload-content" id="upload-content">
            <div class="upload-icon">🎬</div>
            <div class="upload-title">点击选择视频文件</div>
            <div class="upload-hint">支持 MP4、MOV、AVI 等格式</div>
          </div>
        </label>
        <input type="file" name="video_file" id="video-upload-input" accept="video/*" class="hidden-input" required>
        <div class="file-info" id="file-info" style="display: none;">
          <span class="file-check">✓</span>
          <span class="file-name" id="file-name"></span>
        </div>
        <button type="button" class="clear-btn" id="clear-btn" style="display: none;">清除</button>
      </div>
    </div>

    <div class="admin-form-actions">
      <%= link_to "取消", admin_operation_tasks_path, class: "admin-button-secondary" %>
      <%= form.submit "提交", class: "admin-button-primary" %>
    </div>
  <% end %>
</div>

<style>
  .upload-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .upload-box {
    flex: 1;
    min-width: 200px;
    border: 2px dashed #475569;
    border-radius: 8px;
    padding: 24px;
    cursor: pointer;
    transition: all 0.2s;
    background: rgba(30, 41, 59, 0.5);
    text-align: center;
  }

  .upload-box:hover {
    border-color: #3b82f6;
    background: rgba(59, 130, 246, 0.1);
  }

  .upload-box.selected {
    border-color: #22c55e;
    border-style: solid;
  }

  .hidden-input {
    display: none;
  }

  .upload-content {
    pointer-events: none;
  }

  .upload-icon {
    font-size: 36px;
    margin-bottom: 8px;
  }

  .upload-title {
    font-size: 14px;
    color: #cbd5e1;
    margin-bottom: 4px;
  }

  .upload-hint {
    font-size: 12px;
    color: #64748b;
  }

  .file-info {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 6px;
  }

  .file-check {
    color: #22c55e;
    font-size: 14px;
  }

  .file-name {
    color: #cbd5e1;
    font-size: 13px;
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .clear-btn {
    padding: 8px 12px;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 6px;
    color: #ef4444;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .clear-btn:hover {
    background: rgba(239, 68, 68, 0.2);
  }

  .admin-form-group {
    margin-bottom: 16px;
  }

  .admin-form-label {
    display: block;
    margin-bottom: 6px;
    font-size: 13px;
    color: #94a3b8;
  }

  .admin-form-actions {
    display: flex;
    gap: 12px;
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid #334155;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const input = document.getElementById('video-upload-input');
    const uploadBox = document.querySelector('.upload-box');
    const uploadContent = document.getElementById('upload-content');
    const fileInfo = document.getElementById('file-info');
    const fileName = document.getElementById('file-name');
    const clearBtn = document.getElementById('clear-btn');

    input.addEventListener('change', function() {
      if (this.files && this.files.length > 0) {
        var file = this.files[0];
        fileName.textContent = file.name;
        fileInfo.style.display = 'flex';
        clearBtn.style.display = 'block';
        uploadBox.classList.add('selected');
        uploadContent.innerHTML = '' +
          '<div class="upload-icon">✓</div>' +
          '<div class="upload-title">已选择: ' + file.name + '</div>' +
          '<div class="upload-hint">点击可更换文件</div>';
      }
    });

    clearBtn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      input.value = '';
      fileInfo.style.display = 'none';
      clearBtn.style.display = 'none';
      uploadBox.classList.remove('selected');
      uploadContent.innerHTML = '' +
        '<div class="upload-icon">🎬</div>' +
        '<div class="upload-title">点击选择视频文件</div>' +
        '<div class="upload-hint">支持 MP4、MOV、AVI 等格式</div>';
    });
  });
</script>