<% content_for :page_title do %>
  添加运营资源
<% end %>
<% content_for :page_subtitle do %>
  上传运营剪辑的视频到资源队列
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        新增运营视频
      </div>
      <div class="admin-card-subtitle">
        填写主题、标题并上传视频文件，系统将为 facebook、twitter、tiktok、youtube、instagram 五个平台各创建一条待分配任务
      </div>
    </div>
  </div>

  <%= form_with(model: [:admin, @operation_task], url: admin_operation_tasks_path, html: { multipart: true }) do |form| %>
    <div class="admin-form-group">
      <label class="admin-form-label">
        主题 <span style="color: #ef4444;">*</span>
      </label>
      <%= form.text_field :theme, class: "admin-input", placeholder: "请输入主题，如：中国美食制作", required: true %>
    </div>

    <div class="admin-form-group">
      <label class="admin-form-label">
        标题 <span style="color: #ef4444;">*</span>
      </label>
      <%= form.text_field :title, class: "admin-input", placeholder: "请输入发布标题", required: true %>
    </div>

    <div class="admin-form-group">
      <label class="admin-form-label">
        视频文件 <span style="color: #ef4444;">*</span>
      </label>
      <div class="custom-upload-wrapper">
        <label for="video_file" class="custom-upload-box">
          <div class="upload-icon-wrapper">
            <svg class="upload-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="17 8 12 3 7 8"></polyline>
              <line x1="12" y1="3" x2="12" y2="15"></line>
            </svg>
          </div>
          <div class="upload-text">
            <div class="upload-title">点击选择视频文件</div>
            <div class="upload-hint">支持 MP4、MOV、AVI 等格式</div>
          </div>
        </label>
        <input type="file" name="video_file" id="video_file" accept="video/*" required class="hidden-file-input">
        
        <div id="file_info" style="display: none;" class="file-info">
          <div class="file-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 10h-10V7a6 6 0 0 0-12 0v12a4 4 0 0 0 4 4h14a2 2 0 0 0 2-2v-8z"></path>
              <polyline points="22,10 12,15 12,3 22,10"></polyline>
            </svg>
          </div>
          <div class="file-details">
            <div class="file-name" id="file_name"></div>
            <div class="file-size" id="file_size"></div>
          </div>
          <button type="button" id="clear_file" class="clear-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="admin-form-actions">
      <%= link_to "取消", admin_operation_tasks_path, class: "admin-button-secondary" %>
      <%= form.submit "提交", class: "admin-button-primary" %>
    </div>
  <% end %>
</div>

<style>
  .custom-upload-wrapper {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .custom-upload-box {
    border: 2px dashed #475569;
    border-radius: 8px;
    padding: 24px;
    cursor: pointer;
    transition: all 0.2s ease;
    background: rgba(30, 41, 59, 0.5);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 120px;
  }

  .custom-upload-box:hover {
    border-color: #3b82f6;
    background: rgba(59, 130, 246, 0.1);
  }

  .custom-upload-box.selected {
    border-color: #22c55e;
    border-style: solid;
    background: rgba(34, 197, 94, 0.05);
  }

  .upload-icon-wrapper {
    margin-bottom: 12px;
  }

  .upload-icon {
    width: 48px;
    height: 48px;
    color: #64748b;
    transition: color 0.2s;
  }

  .custom-upload-box:hover .upload-icon {
    color: #3b82f6;
  }

  .upload-text {
    text-align: center;
  }

  .upload-title {
    font-size: 14px;
    color: #cbd5e1;
    margin-bottom: 4px;
  }

  .upload-hint {
    font-size: 12px;
    color: #64748b;
  }

  .hidden-file-input {
    display: none;
  }

  .file-info {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 8px;
  }

  .file-icon {
    width: 32px;
    height: 32px;
    color: #22c55e;
    flex-shrink: 0;
  }

  .file-details {
    flex: 1;
    min-width: 0;
  }

  .file-name {
    font-size: 13px;
    color: #cbd5e1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .file-size {
    font-size: 11px;
    color: #64748b;
    margin-top: 2px;
  }

  .clear-btn {
    background: transparent;
    border: none;
    color: #64748b;
    cursor: pointer;
    padding: 6px;
    border-radius: 4px;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .clear-btn:hover {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
  }

  .clear-btn svg {
    width: 18px;
    height: 18px;
  }

  .admin-form-group {
    margin-bottom: 16px;
  }

  .admin-form-label {
    display: block;
    margin-bottom: 6px;
    font-size: 13px;
    color: #94a3b8;
  }

  .admin-form-actions {
    display: flex;
    gap: 12px;
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid #334155;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var fileInput = document.getElementById('video_file');
    var uploadBox = document.querySelector('.custom-upload-box');
    var fileInfo = document.getElementById('file_info');
    var fileNameEl = document.getElementById('file_name');
    var fileSizeEl = document.getElementById('file_size');
    var clearBtn = document.getElementById('clear_file');

    fileInput.addEventListener('change', function(e) {
      var file = e.target.files[0];
      if (file) {
        fileNameEl.textContent = file.name;
        fileSizeEl.textContent = formatFileSize(file.size);
        fileInfo.style.display = 'flex';
        uploadBox.classList.add('selected');
        uploadBox.innerHTML = '' +
          '<div class="upload-icon-wrapper">' +
          '<svg class="upload-icon" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2">' +
          '<polyline points="20 6 9 17 4 12"></polyline>' +
          '</svg>' +
          '</div>' +
          '<div class="upload-text">' +
          '<div class="upload-title">已选择: ' + file.name + '</div>' +
          '<div class="upload-hint">点击可更换文件</div>' +
          '</div>';
      }
    });

    clearBtn.addEventListener('click', function(e) {
      e.preventDefault();
      fileInput.value = '';
      fileInfo.style.display = 'none';
      uploadBox.classList.remove('selected');
      uploadBox.innerHTML = '' +
        '<div class="upload-icon-wrapper">' +
        '<svg class="upload-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">' +
        '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>' +
        '<polyline points="17 8 12 3 7 8"></polyline>' +
        '<line x1="12" y1="3" x2="12" y2="15"></line>' +
        '</svg>' +
        '</div>' +
        '<div class="upload-text">' +
        '<div class="upload-title">点击选择视频文件</div>' +
        '<div class="upload-hint">支持 MP4、MOV、AVI 等格式</div>' +
        '</div>';
    });
  });

  function formatFileSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(2) + ' KB';
    return (bytes / 1024 / 1024).toFixed(2) + ' MB';
  }
</script>