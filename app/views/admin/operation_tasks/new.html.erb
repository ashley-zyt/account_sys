<% content_for :page_title do %>
  添加运营资源
<% end %>
<% content_for :page_subtitle do %>
  上传运营剪辑的视频到资源队列
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        新增运营视频
      </div>
      <div class="admin-card-subtitle">
        填写主题、文案并上传视频文件，系统将为 facebook、twitter、tiktok、youtube、instagram 五个平台各创建一条待分配任务
      </div>
    </div>
  </div>

  <form id="upload_form" enctype="multipart/form-data">
    <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

    <div class="admin-form-group">
      <label class="admin-form-label">
        主题 <span style="color: #ef4444;">*</span>
      </label>
      <%= render 'admin/shared/searchable_theme_select',
        name: 'operation_task[theme]',
        themes: @themes,
        selected: nil,
        placeholder: '请选择主题',
        include_blank: '请选择主题' %>
    </div>

    <div class="admin-form-group">
      <label class="admin-form-label">
        文案 <span style="color: #ef4444;">*</span>
        <span id="title_counter" class="char-counter">0 / 280</span>
      </label>
      <textarea name="operation_task[title]" id="title" class="admin-input" placeholder="请输入发布文案" rows="4" maxlength="280" required></textarea>
    </div>

    <div class="admin-form-group">
      <label class="admin-form-label">
        简介
        <span id="description_counter" class="char-counter">0 / 100</span>
      </label>
      <textarea name="operation_task[description]" id="description" class="admin-input" placeholder="请输入视频简介（可选）" rows="4" maxlength="100"></textarea>
    </div>

    <div class="admin-form-group">
      <label class="admin-form-label">
        视频文件 <span style="color: #ef4444;">*</span>
      </label>
      <div class="file-upload-container">
        <label class="file-upload-label" id="upload_label" for="video_file">
          <div class="upload-icon">🎬</div>
          <div class="upload-text" id="upload_text">点击选择视频文件</div>
          <div class="upload-hint">支持 MP4、MOV、AVI 等格式</div>
        </label>
        <input type="file" name="video_file" id="video_file" accept="video/*" class="file-input">
        <div class="file-selected-info" id="file_info" style="display: none;">
          <span class="file-name" id="file_name"></span>
          <button type="button" class="clear-btn" id="clear_btn">×</button>
        </div>
      </div>
    </div>

    <div class="admin-form-actions">
      <a href="/admin/operation_tasks" class="admin-button-secondary">取消</a>
      <button type="submit" id="submit_btn" class="admin-button-primary">提交</button>
    </div>
  </form>
</div>

<div id="upload_modal" class="modal-overlay" style="display: none;">
  <div class="modal-content">
    <div class="modal-header">
      <h3>正在上传...</h3>
    </div>
    <div class="modal-body">
      <div class="upload-status">
        <div class="status-icon" id="status_icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
          </svg>
        </div>
        <div class="status-text" id="status_text">正在上传视频...</div>
      </div>
      <div class="progress-container">
        <div class="progress-bar">
          <div class="progress-fill" id="progress_fill"></div>
        </div>
        <div class="progress-percent" id="progress_percent">0%</div>
      </div>
      <div class="upload-info" id="upload_info"></div>
    </div>
  </div>
</div>

<style>
  .file-upload-container {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .file-input {
    display: none;
  }

  .file-upload-label {
    border: 2px dashed #475569;
    border-radius: 8px;
    padding: 32px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    background: rgba(30, 41, 59, 0.5);
  }

  .file-upload-label:hover {
    border-color: #3b82f6;
    background: rgba(59, 130, 246, 0.1);
  }

  .upload-icon {
    font-size: 36px;
    margin-bottom: 8px;
  }

  .upload-text {
    font-size: 14px;
    color: #cbd5e1;
    margin-bottom: 4px;
  }

  .upload-hint {
    font-size: 12px;
    color: #64748b;
  }

  .file-selected-info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 8px;
  }

  .file-name {
    color: #cbd5e1;
    font-size: 13px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .clear-btn {
    background: transparent;
    border: none;
    color: #64748b;
    font-size: 20px;
    cursor: pointer;
    padding: 0 8px;
    line-height: 1;
  }

  .clear-btn:hover {
    color: #ef4444;
  }

  .admin-form-group {
    margin-bottom: 16px;
  }

  .admin-form-label {
    display: block;
    margin-bottom: 6px;
    font-size: 13px;
    color: #94a3b8;
  }

  .admin-form-actions {
    display: flex;
    gap: 12px;
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid #334155;
  }

  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }

  .modal-content {
    background: #1e293b;
    border-radius: 12px;
    width: 90%;
    max-width: 400px;
  }

  .modal-header {
    padding: 16px 20px;
    border-bottom: 1px solid #334155;
  }

  .modal-header h3 {
    margin: 0;
    font-size: 15px;
    color: #f1f5f9;
  }

  .modal-body {
    padding: 24px 20px;
  }

  .upload-status {
    text-align: center;
    margin-bottom: 20px;
  }

  .status-icon {
    margin-bottom: 8px;
  }

  .status-icon svg {
    width: 40px;
    height: 40px;
    color: #3b82f6;
  }

  .status-icon.success svg {
    color: #22c55e;
  }

  .status-icon.error svg {
    color: #ef4444;
  }

  .status-icon.loading svg {
    animation: spin 1.5s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .status-text {
    font-size: 13px;
    color: #94a3b8;
  }

  .progress-container {
    margin-bottom: 16px;
  }

  .progress-bar {
    background: #334155;
    border-radius: 4px;
    height: 6px;
    overflow: hidden;
    margin-bottom: 6px;
  }

  .progress-fill {
    background: linear-gradient(90deg, #3b82f6, #22c55e);
    height: 100%;
    width: 0%;
    transition: width 0.3s;
  }

  .progress-fill.success {
    background: #22c55e;
  }

  .progress-fill.error {
    background: #ef4444;
  }

  .progress-percent {
    font-size: 12px;
    color: #64748b;
    text-align: center;
  }

  .upload-info {
    font-size: 12px;
    color: #64748b;
    text-align: center;
    padding: 10px;
    background: rgba(30, 41, 59, 0.8);
    border-radius: 6px;
    display: none;
  }

  .upload-info.success {
    color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
  }

  .upload-info.error {
    color: #ef4444;
    background: rgba(239, 68, 68, 0.1);
  }

  /* 字符计数器样式 */
  .char-counter {
    float: right;
    font-size: 12px;
    color: #999;
    font-weight: normal;
    margin-left: 8px;
  }

  .char-counter.warning {
    color: #f59e0b;
  }

  .char-counter.danger {
    color: #ef4444;
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var fileInput = document.getElementById('video_file');
  var fileInfo = document.getElementById('file_info');
  var fileName = document.getElementById('file_name');
  var clearBtn = document.getElementById('clear_btn');
  var form = document.getElementById('upload_form');
  var submitBtn = document.getElementById('submit_btn');
  var modal = document.getElementById('upload_modal');
  var statusIcon = document.getElementById('status_icon');
  var statusText = document.getElementById('status_text');

  // 字符计数器功能
  var titleTextarea = document.getElementById('title');
  var descriptionTextarea = document.getElementById('description');
  var titleCounter = document.getElementById('title_counter');
  var descriptionCounter = document.getElementById('description_counter');

  var titleMax = 280;
  var descriptionMax = 100;

  function updateCounter(textarea, counter, max) {
    var length = textarea.value.length;
    counter.textContent = length + ' / ' + max;

    // 根据剩余字符数量改变颜色
    counter.classList.remove('warning', 'danger');
    if (length >= max) {
      counter.classList.add('danger');
    } else if (length >= max * 0.9) {
      counter.classList.add('warning');
    }
  }

  if (titleTextarea && titleCounter) {
    titleTextarea.addEventListener('input', function() {
      updateCounter(titleTextarea, titleCounter, titleMax);
    });
    // 初始化计数器
    updateCounter(titleTextarea, titleCounter, titleMax);
  }

  if (descriptionTextarea && descriptionCounter) {
    descriptionTextarea.addEventListener('input', function() {
      updateCounter(descriptionTextarea, descriptionCounter, descriptionMax);
    });
    // 初始化计数器
    updateCounter(descriptionTextarea, descriptionCounter, descriptionMax);
  }
  var progressFill = document.getElementById('progress_fill');
  var progressPercent = document.getElementById('progress_percent');
  var uploadInfo = document.getElementById('upload_info');

  if (!form) return; // 如果没有表单元素，直接返回

  fileInput.addEventListener('change', function() {
    if (this.files && this.files.length > 0) {
      var file = this.files[0];
      fileName.textContent = file.name + ' (' + formatSize(file.size) + ')';
      fileInfo.style.display = 'flex';
    }
  });

  clearBtn.addEventListener('click', function(e) {
    e.preventDefault();
    fileInput.value = '';
    fileInfo.style.display = 'none';
  });

  form.addEventListener('submit', function(e) {
    e.preventDefault();

    var themeInput = document.querySelector('input[name="operation_task[theme]"]');
    var theme = themeInput ? themeInput.value.trim() : '';
    var title = document.getElementById('title').value.trim();
    var videoFile = fileInput.files[0];

    if (!theme) { alert('请选择主题'); return; }
    if (!title) { alert('请输入文案'); return; }
    if (!videoFile) { alert('请选择视频文件'); return; }

    submitBtn.disabled = true;
    submitBtn.textContent = '上传中...';
    showModal();
    resetProgress();

    // 第一步：获取 OSS 签名（携带文件名以便后端生成正确的 key）
    fetch('/admin/operation_tasks/oss_signature?filename=' + encodeURIComponent(videoFile.name))
      .then(function(response) {
        if (!response.ok) throw new Error('获取签名失败');
        return response.json();
      })
      .then(function(signatureData) {
        // 直接使用后端返回的 key（已包含正确的文件扩展名）
        // 第二步：直传文件到 OSS
        return uploadToOss(videoFile, signatureData);
      })
      .then(function(ossKey) {
        // 第三步：创建运营任务（传递 key，后端生成签名 URL）
        updateProgress(95, '正在创建任务...');
        return createOperationTask(ossKey);
      })
      .then(function() {
        updateProgress(100, '完成！');
        statusIcon.className = 'status-icon success';
        progressFill.classList.add('success');
        uploadInfo.textContent = '视频已成功上传，已为5个平台创建任务';
        uploadInfo.className = 'upload-info success';
        uploadInfo.style.display = 'block';
        setTimeout(function() {
          window.location.href = '/admin/operation_tasks';
        }, 1500);
      })
      .catch(function(error) {
        showError('上传失败: ' + error.message);
      });
  });

  // 直传文件到 OSS
  function uploadToOss(file, signatureData) {
    return new Promise(function(resolve, reject) {
      var formData = new FormData();
      formData.append('key', signatureData.key);
      formData.append('OSSAccessKeyId', signatureData.accessKeyId);
      formData.append('policy', signatureData.policy);
      formData.append('Signature', signatureData.signature);
      formData.append('file', file);

      var xhr = new XMLHttpRequest();
      xhr.open('POST', signatureData.endpoint, true);

      xhr.upload.addEventListener('progress', function(ev) {
        if (ev.lengthComputable) {
          var percent = Math.round((ev.loaded / ev.total) * 90); // 前90%用于上传
          updateProgress(percent, '正在上传视频到 OSS...');
        }
      });

      xhr.addEventListener('load', function() {
        if (xhr.status === 204 || xhr.status === 200) {
          // 返回 key，让后端生成签名 URL
          resolve(signatureData.key);
        } else {
          reject(new Error('OSS 上传失败: ' + xhr.statusText));
        }
      });

      xhr.addEventListener('error', function() {
        reject(new Error('网络错误'));
      });

      xhr.send(formData);
    });
  }

  // 创建运营任务
  function createOperationTask(ossKey) {
    return new Promise(function(resolve, reject) {
      var formData = new FormData(form);
      formData.append('oss_key', ossKey);

      var xhr = new XMLHttpRequest();
      xhr.open('POST', '/admin/operation_tasks', true);

      xhr.addEventListener('load', function() {
        if (xhr.status === 302 || xhr.status === 200) {
          resolve();
        } else {
          reject(new Error('创建任务失败'));
        }
      });

      xhr.addEventListener('error', function() {
        reject(new Error('网络错误'));
      });

      xhr.send(formData);
    });
  }

  function showModal() {
    modal.style.display = 'flex';
    statusIcon.className = 'status-icon loading';
  }

  function resetProgress() {
    statusIcon.className = 'status-icon loading';
    statusText.textContent = '正在准备上传...';
    progressFill.className = 'progress-fill';
    progressFill.style.width = '0%';
    progressPercent.textContent = '0%';
    uploadInfo.className = 'upload-info';
    uploadInfo.style.display = 'none';
  }

  function updateProgress(percent, text) {
    progressFill.style.width = percent + '%';
    progressPercent.textContent = percent + '%';
    statusText.textContent = text;
  }

  function showError(msg) {
    statusIcon.className = 'status-icon error';
    progressFill.classList.add('error');
    uploadInfo.textContent = msg;
    uploadInfo.className = 'upload-info error';
    uploadInfo.style.display = 'block';
    submitBtn.disabled = false;
    submitBtn.textContent = '提交';
  }

  function formatSize(bytes) {
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / 1024 / 1024).toFixed(1) + ' MB';
  }
});
</script>