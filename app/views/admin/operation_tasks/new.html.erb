<% content_for :page_title do %>
  添加运营资源
<% end %>
<% content_for :page_subtitle do %>
  上传运营剪辑的视频到资源队列
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        新增运营视频
      </div>
      <div class="admin-card-subtitle">
        填写主题、标题并上传视频文件，系统将为 facebook、twitter、tiktok、youtube、instagram 五个平台各创建一条待分配任务
      </div>
    </div>
  </div>

  <form id="upload_form" enctype="multipart/form-data">
    <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
    
    <div class="admin-form-group">
      <label class="admin-form-label">
        主题 <span style="color: #ef4444;">*</span>
      </label>
      <input type="text" name="operation_task[theme]" id="theme" class="admin-input" placeholder="请输入主题，如：中国美食制作" required>
    </div>

    <div class="admin-form-group">
      <label class="admin-form-label">
        标题 <span style="color: #ef4444;">*</span>
      </label>
      <input type="text" name="operation_task[title]" id="title" class="admin-input" placeholder="请输入发布标题" required>
    </div>

    <div class="admin-form-group">
      <label class="admin-form-label">
        视频文件 <span style="color: #ef4444;">*</span>
      </label>
      <div class="custom-upload-wrapper">
        <label for="video_file" class="custom-upload-box">
          <div class="upload-icon-wrapper">
            <svg class="upload-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="17 8 12 3 7 8"></polyline>
              <line x1="12" y1="3" x2="12" y2="15"></line>
            </svg>
          </div>
          <div class="upload-text">
            <div class="upload-title">点击选择视频文件</div>
            <div class="upload-hint">支持 MP4、MOV、AVI 等格式</div>
          </div>
        </label>
        <input type="file" name="video_file" id="video_file" accept="video/*" required class="hidden-file-input">
        
        <div id="file_info" style="display: none;" class="file-info">
          <div class="file-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 10h-10V7a6 6 0 0 0-12 0v12a4 4 0 0 0 4 4h14a2 2 0 0 0 2-2v-8z"></path>
              <polyline points="22,10 12,15 12,3 22,10"></polyline>
            </svg>
          </div>
          <div class="file-details">
            <div class="file-name" id="file_name"></div>
            <div class="file-size" id="file_size"></div>
          </div>
          <button type="button" id="clear_file" class="clear-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="admin-form-actions">
      <a href="/admin/operation_tasks" class="admin-button-secondary">取消</a>
      <button type="submit" id="submit_btn" class="admin-button-primary">提交</button>
    </div>
  </form>
</div>

<!-- 上传进度弹窗 -->
<div id="upload_modal" class="modal-overlay" style="display: none;">
  <div class="modal-content">
    <div class="modal-header">
      <h3>正在上传...</h3>
    </div>
    <div class="modal-body">
      <div class="upload-status">
        <div class="status-icon" id="status_icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
          </svg>
        </div>
        <div class="status-text" id="status_text">正在上传视频...</div>
      </div>
      <div class="progress-container">
        <div class="progress-bar">
          <div class="progress-fill" id="progress_fill"></div>
        </div>
        <div class="progress-percent" id="progress_percent">0%</div>
      </div>
      <div class="upload-info" id="upload_info"></div>
    </div>
    <div class="modal-footer">
      <button type="button" id="cancel_upload" class="modal-btn modal-btn-cancel" style="display: none;">取消</button>
    </div>
  </div>
</div>

<style>
  .custom-upload-wrapper {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .custom-upload-box {
    border: 2px dashed #475569;
    border-radius: 8px;
    padding: 24px;
    cursor: pointer;
    transition: all 0.2s ease;
    background: rgba(30, 41, 59, 0.5);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 120px;
  }

  .custom-upload-box:hover {
    border-color: #3b82f6;
    background: rgba(59, 130, 246, 0.1);
  }

  .custom-upload-box.selected {
    border-color: #22c55e;
    border-style: solid;
    background: rgba(34, 197, 94, 0.05);
  }

  .upload-icon-wrapper {
    margin-bottom: 12px;
  }

  .upload-icon {
    width: 48px;
    height: 48px;
    color: #64748b;
    transition: color 0.2s;
  }

  .custom-upload-box:hover .upload-icon {
    color: #3b82f6;
  }

  .upload-text {
    text-align: center;
  }

  .upload-title {
    font-size: 14px;
    color: #cbd5e1;
    margin-bottom: 4px;
  }

  .upload-hint {
    font-size: 12px;
    color: #64748b;
  }

  .hidden-file-input {
    display: none;
  }

  .file-info {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 8px;
  }

  .file-icon {
    width: 32px;
    height: 32px;
    color: #22c55e;
    flex-shrink: 0;
  }

  .file-details {
    flex: 1;
    min-width: 0;
  }

  .file-name {
    font-size: 13px;
    color: #cbd5e1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .file-size {
    font-size: 11px;
    color: #64748b;
    margin-top: 2px;
  }

  .clear-btn {
    background: transparent;
    border: none;
    color: #64748b;
    cursor: pointer;
    padding: 6px;
    border-radius: 4px;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .clear-btn:hover {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
  }

  .clear-btn svg {
    width: 18px;
    height: 18px;
  }

  .admin-form-group {
    margin-bottom: 16px;
  }

  .admin-form-label {
    display: block;
    margin-bottom: 6px;
    font-size: 13px;
    color: #94a3b8;
  }

  .admin-form-actions {
    display: flex;
    gap: 12px;
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid #334155;
  }

  /* 弹窗样式 */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    backdrop-filter: blur(4px);
  }

  .modal-content {
    background: #1e293b;
    border-radius: 12px;
    width: 90%;
    max-width: 450px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }

  .modal-header {
    padding: 20px 24px;
    border-bottom: 1px solid #334155;
  }

  .modal-header h3 {
    margin: 0;
    font-size: 16px;
    color: #f1f5f9;
    font-weight: 600;
  }

  .modal-body {
    padding: 24px;
  }

  .upload-status {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 20px;
  }

  .status-icon {
    margin-bottom: 12px;
  }

  .status-icon svg {
    width: 48px;
    height: 48px;
  }

  .status-icon.success svg {
    stroke: #22c55e;
  }

  .status-icon.error svg {
    stroke: #ef4444;
  }

  .status-icon.loading svg {
    animation: spin 1.5s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .status-text {
    font-size: 14px;
    color: #94a3b8;
    text-align: center;
  }

  .progress-container {
    margin-bottom: 16px;
  }

  .progress-bar {
    background: #334155;
    border-radius: 4px;
    height: 8px;
    overflow: hidden;
    margin-bottom: 8px;
  }

  .progress-fill {
    background: linear-gradient(90deg, #3b82f6, #22c55e);
    height: 100%;
    width: 0%;
    border-radius: 4px;
    transition: width 0.3s ease;
  }

  .progress-fill.success {
    background: #22c55e;
  }

  .progress-fill.error {
    background: #ef4444;
  }

  .progress-percent {
    font-size: 13px;
    color: #94a3b8;
    text-align: center;
  }

  .upload-info {
    font-size: 12px;
    color: #64748b;
    text-align: center;
    padding: 12px;
    background: rgba(30, 41, 59, 0.8);
    border-radius: 6px;
    display: none;
  }

  .upload-info.success {
    color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
  }

  .upload-info.error {
    color: #ef4444;
    background: rgba(239, 68, 68, 0.1);
  }

  .modal-footer {
    padding: 16px 24px;
    border-top: 1px solid #334155;
    display: flex;
    justify-content: flex-end;
  }

  .modal-btn {
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
  }

  .modal-btn-cancel {
    background: rgba(100, 116, 139, 0.2);
    color: #94a3b8;
  }

  .modal-btn-cancel:hover {
    background: rgba(100, 116, 139, 0.3);
  }

  .modal-btn-confirm {
    background: #3b82f6;
    color: white;
  }

  .modal-btn-confirm:hover {
    background: #2563eb;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var fileInput = document.getElementById('video_file');
    var uploadBox = document.querySelector('.custom-upload-box');
    var fileInfo = document.getElementById('file_info');
    var fileNameEl = document.getElementById('file_name');
    var fileSizeEl = document.getElementById('file_size');
    var clearBtn = document.getElementById('clear_file');
    var form = document.getElementById('upload_form');
    var submitBtn = document.getElementById('submit_btn');
    var modal = document.getElementById('upload_modal');
    var statusIcon = document.getElementById('status_icon');
    var statusText = document.getElementById('status_text');
    var progressFill = document.getElementById('progress_fill');
    var progressPercent = document.getElementById('progress_percent');
    var uploadInfo = document.getElementById('upload_info');

    fileInput.addEventListener('change', function(e) {
      var file = e.target.files[0];
      if (file) {
        fileNameEl.textContent = file.name;
        fileSizeEl.textContent = formatFileSize(file.size);
        fileInfo.style.display = 'flex';
        uploadBox.classList.add('selected');
        uploadBox.innerHTML = '' +
          '<div class="upload-icon-wrapper">' +
          '<svg class="upload-icon" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2">' +
          '<polyline points="20 6 9 17 4 12"></polyline>' +
          '</svg>' +
          '</div>' +
          '<div class="upload-text">' +
          '<div class="upload-title">已选择: ' + file.name + '</div>' +
          '<div class="upload-hint">点击可更换文件</div>' +
          '</div>';
      }
    });

    clearBtn.addEventListener('click', function(e) {
      e.preventDefault();
      fileInput.value = '';
      fileInfo.style.display = 'none';
      uploadBox.classList.remove('selected');
      uploadBox.innerHTML = '' +
        '<div class="upload-icon-wrapper">' +
        '<svg class="upload-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">' +
        '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>' +
        '<polyline points="17 8 12 3 7 8"></polyline>' +
        '<line x1="12" y1="3" x2="12" y2="15"></line>' +
        '</svg>' +
        '</div>' +
        '<div class="upload-text">' +
        '<div class="upload-title">点击选择视频文件</div>' +
        '<div class="upload-hint">支持 MP4、MOV、AVI 等格式</div>' +
        '</div>';
    });

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      
      var theme = document.getElementById('theme').value.trim();
      var title = document.getElementById('title').value.trim();
      var videoFile = fileInput.files[0];

      if (!theme) {
        alert('请输入主题');
        return;
      }
      if (!title) {
        alert('请输入标题');
        return;
      }
      if (!videoFile) {
        alert('请选择视频文件');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = '上传中...';

      showModal();
      resetProgress();

      var formData = new FormData(form);

      var xhr = new XMLHttpRequest();
      xhr.open('POST', '/admin/operation_tasks', true);

      xhr.upload.addEventListener('progress', function(e) {
        if (e.lengthComputable) {
          var percent = Math.round((e.loaded / e.total) * 100);
          updateProgress(percent, '正在上传视频...');
        }
      });

      xhr.addEventListener('load', function() {
        if (xhr.status === 302 || xhr.status === 200) {
          updateProgress(100, '上传完成！');
          statusIcon.classList.add('success');
          statusIcon.classList.remove('loading');
          progressFill.classList.add('success');
          uploadInfo.textContent = '视频已成功上传，正在为5个平台创建任务...';
          uploadInfo.classList.add('success');
          uploadInfo.style.display = 'block';

          setTimeout(function() {
            window.location.href = '/admin/operation_tasks';
          }, 1500);
        } else {
          statusIcon.classList.add('error');
          statusIcon.classList.remove('loading');
          progressFill.classList.add('error');
          uploadInfo.textContent = '上传失败: ' + xhr.statusText;
          uploadInfo.classList.add('error');
          uploadInfo.style.display = 'block';
          submitBtn.disabled = false;
          submitBtn.textContent = '提交';
        }
      });

      xhr.addEventListener('error', function() {
        statusIcon.classList.add('error');
        statusIcon.classList.remove('loading');
        progressFill.classList.add('error');
        uploadInfo.textContent = '上传失败: 网络错误';
        uploadInfo.classList.add('error');
        uploadInfo.style.display = 'block';
        submitBtn.disabled = false;
        submitBtn.textContent = '提交';
      });

      xhr.send(formData);
    });

    function showModal() {
      modal.style.display = 'flex';
      statusIcon.classList.add('loading');
    }

    function resetProgress() {
      statusIcon.className = 'status-icon loading';
      statusText.textContent = '正在上传视频...';
      progressFill.className = 'progress-fill';
      progressFill.style.width = '0%';
      progressPercent.textContent = '0%';
      uploadInfo.className = 'upload-info';
      uploadInfo.style.display = 'none';
    }

    function updateProgress(percent, text) {
      progressFill.style.width = percent + '%';
      progressPercent.textContent = percent + '%';
      statusText.textContent = text;
    }
  });

  function formatFileSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(2) + ' KB';
    return (bytes / 1024 / 1024).toFixed(2) + ' MB';
  }
</script>