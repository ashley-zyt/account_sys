<div class="admin-form">
  <%= form_for [:admin, @post_stat], html: { class: "admin-form-content" } do |f| %>
    <% if @post_stat.errors.any? %>
      <div style="padding: 12px 16px; background: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.4); border-radius: 6px; margin-bottom: 16px;">
        <ul>
          <% @post_stat.errors.full_messages.each do |msg| %>
            <li style="color: #fca5a5; font-size: 13px;"><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="admin-form-group">
      <%= f.label :account_id, "账号", class: "admin-form-label" %>
      <%= f.select :account_id, @accounts.map { |a| [a.account_name, a.id] }, { include_blank: "请选择账号" }, class: "admin-input" %>
    </div>

    <div class="admin-form-group">
      <%= f.label :post_date, "发文日期", class: "admin-form-label" %>
      <%= f.date_field :post_date, class: "admin-input", required: true %>
    </div>

    <div class="admin-form-group">
      <%= f.label :title, "发文标题", class: "admin-form-label" %>
      <%= f.text_field :title, class: "admin-input", placeholder: "输入发文标题" %>
    </div>

    <div class="admin-form-group">
      <%= f.label :url, "发文链接", class: "admin-form-label" %>
      <%= f.text_field :url, class: "admin-input", placeholder: "输入发文链接" %>
    </div>

    <div class="admin-form-row">
      <div class="admin-form-group" style="flex: 1;">
        <%= f.label :likes_count, "点赞数量", class: "admin-form-label" %>
        <%= f.number_field :likes_count, class: "admin-input", placeholder: "0", min: 0 %>
      </div>
      <div class="admin-form-group" style="flex: 1;">
        <%= f.label :shares_count, "转发数量", class: "admin-form-label" %>
        <%= f.number_field :shares_count, class: "admin-input", placeholder: "0", min: 0 %>
      </div>
    </div>

    <div class="admin-form-row">
      <div class="admin-form-group" style="flex: 1;">
        <%= f.label :comments_count, "评论数量", class: "admin-form-label" %>
        <%= f.number_field :comments_count, class: "admin-input", placeholder: "0", min: 0 %>
      </div>
      <div class="admin-form-group" style="flex: 1;">
        <%= f.label :views_count, "浏览数量", class: "admin-form-label" %>
        <%= f.number_field :views_count, class: "admin-input", placeholder: "0", min: 0 %>
      </div>
    </div>

    <div class="admin-form-group">
      <%= f.label :data_updated_at, "数据更新时间", class: "admin-form-label" %>
      <%= f.datetime_local_field :data_updated_at, class: "admin-input" %>
    </div>

    <div class="admin-form-actions">
      <%= f.submit "保存", class: "admin-button-primary" %>
      <%= link_to "取消", admin_post_stats_path, class: "admin-button-secondary" %>
    </div>
  <% end %>
</div>