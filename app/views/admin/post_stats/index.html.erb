<% content_for :page_title do %>
  发文数据统计
<% end %>
<% content_for :page_subtitle do %>
  记录每个账号的发文数据
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        发文数据列表
      </div>
      <div class="admin-card-subtitle">
        查看账号发文统计数据
      </div>
    </div>
    <div class="admin-card-header-right">
      <span class="admin-tag">
        共 <%= @post_stats.total_count %> 条
      </span>
      <%= link_to '趋势分析', trends_admin_post_stats_path, class: "admin-button-secondary", style: "margin-left: 8px;" %>
      <%= link_to '导出 CSV', "/admin/post_stats/export#{request.query_string.present? ? '?' + request.query_string : ''}", class: "admin-button-secondary", style: "margin-left: 8px;" %>
    </div>
  </div>

  <div class="admin-filter-form">
    <%= search_form_for [:admin, @q], class: "admin-filter-form" do |f| %>
      <div class="admin-filter-group">
        <label class="admin-filter-label">账号</label>
        <%= f.search_field :account_account_name_cont, class: "admin-input admin-filter-input", placeholder: "搜索账号..." %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">工作模式</label>
        <%= f.select :account_work_type_eq, @work_types, { include_blank: "所有模式" }, class: "admin-input admin-filter-input" %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">平台</label>
        <%= f.select :account_platform_eq, @platforms, { include_blank: "所有平台" }, class: "admin-input admin-filter-input" %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">发文日期</label>
        <div style="display: flex; gap: 8px;">
          <%= f.date_field :post_date_gteq, class: "admin-input admin-filter-input", placeholder: "开始日期" %>
          <span style="margin-top: 8px;">~</span>
          <%= f.date_field :post_date_lteq, class: "admin-input admin-filter-input", placeholder: "结束日期" %>
        </div>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">标题</label>
        <%= f.search_field :title_cont, class: "admin-input admin-filter-input", placeholder: "搜索标题..." %>
      </div>
      <div style="margin-left: auto;">
        <%= f.submit "筛选", class: "admin-button-primary" %>
        <%= link_to "重置", admin_post_stats_path, class: "admin-button-secondary" %>
      </div>
    <% end %>
  </div>

  <% if @post_stats.any? %>
    <div class="admin-table-wrapper admin-table-scroll">
      <table class="admin-table">
        <thead>
          <tr>
            <th>账号</th>
            <th>平台</th>
            <th>发文日期 <%= link_to '↑↓', request.params.merge(sort: 'post_date', direction: @current_sort == 'post_date' && @current_direction == 'desc' ? 'asc' : 'desc') %></th>
            <th>标题</th>
            <th>链接</th>
            <th>点赞数 <%= link_to '↑↓', request.params.merge(sort: 'likes_count', direction: @current_sort == 'likes_count' && @current_direction == 'desc' ? 'asc' : 'desc') %></th>
            <th>转发数 <%= link_to '↑↓', request.params.merge(sort: 'shares_count', direction: @current_sort == 'shares_count' && @current_direction == 'desc' ? 'asc' : 'desc') %></th>
            <th>评论数 <%= link_to '↑↓', request.params.merge(sort: 'comments_count', direction: @current_sort == 'comments_count' && @current_direction == 'desc' ? 'asc' : 'desc') %></th>
            <th>浏览数 <%= link_to '↑↓', request.params.merge(sort: 'views_count', direction: @current_sort == 'views_count' && @current_direction == 'desc' ? 'asc' : 'desc') %></th>
            <th>数据更新时间</th>
            <th>运营人员</th>
          </tr>
        </thead>
        <tbody>
          <% @post_stats.each do |stat| %>
            <tr>
              <td>
                <%= link_to stat.account&.account_name, admin_account_path(stat.account), class: "admin-link-quiet" %>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= stat.account&.platform || "-" %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= stat.post_date.strftime("%Y-%m-%d") %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= truncate(stat.title, length: 30) || "-" %>
                </span>
              </td>
              <td>
                <% if stat.url.present? %>
                  <%= link_to "查看", stat.url, class: "admin-link-quiet", target: "_blank", style: "color: var(--accent);" %>
                <% else %>
                  <span class="admin-label-muted">-</span>
                <% end %>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= stat.likes_count || 0 %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= stat.shares_count || 0 %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= stat.comments_count || 0 %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= stat.views_count || 0 %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= stat.data_updated_at&.strftime("%Y-%m-%d %H:%M") || "-" %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <% case stat.account&.work_type %>
                  <% when "人工运营" %>
                    <%= stat.account&.operator || "-" %>
                  <% when "Grok" %>
                    Grok
                  <% else %>
                    视频搬运
                  <% end %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="admin-pagination">
      <%= paginate @post_stats %>
    </div>
  <% else %>
    <div class="admin-empty-state">
      暂无发文数据。
    </div>
  <% end %>
</div>