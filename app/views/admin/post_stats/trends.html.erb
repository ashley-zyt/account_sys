<% content_for :page_title do %>
  发文数据趋势
<% end %>
<% content_for :page_subtitle do %>
  查看各平台发文数据的互动趋势
<% end %>

<% content_for :head do %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" data-turbo-track="reload"></script>
<% end %>

<%# 顶部操作栏 %>
<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">数据概览</div>
      <div class="admin-card-subtitle">筛选并查看各平台互动数据趋势</div>
    </div>
    <div class="admin-card-header-right">
      <%= link_to "返回列表", admin_post_stats_path, class: "admin-button-secondary" %>
    </div>
  </div>

  <%# 筛选表单 %>
  <%= form_with url: trends_admin_post_stats_path, method: :get, class: "admin-filter-form", data: { turbo: false } do |f| %>
    <div class="admin-filter-group">
      <label class="admin-filter-label">平台</label>
      <%= select_tag "q[account_platform_eq]", options_for_select(@platforms, params.dig(:q, :account_platform_eq)), include_blank: "全部平台", class: "admin-input admin-filter-input" %>
    </div>
    <div class="admin-filter-group">
      <label class="admin-filter-label">工作模式</label>
      <%= select_tag "q[account_work_type_eq]", options_for_select(@work_types, params.dig(:q, :account_work_type_eq)), include_blank: "全部模式", class: "admin-input admin-filter-input" %>
    </div>
    <div class="admin-filter-group">
      <label class="admin-filter-label">日期范围</label>
      <div style="display: flex; gap: 8px; align-items: center;">
        <%= date_field_tag "q[post_date_gteq]", params.dig(:q, :post_date_gteq), class: "admin-input admin-filter-input", placeholder: "开始" %>
        <span>~</span>
        <%= date_field_tag "q[post_date_lteq]", params.dig(:q, :post_date_lteq), class: "admin-input admin-filter-input", placeholder: "结束" %>
      </div>
    </div>
    <div style="margin-left: auto; display: flex; gap: 8px;">
      <%= f.submit "筛选", class: "admin-button-primary" %>
      <%= link_to "重置", trends_admin_post_stats_path, class: "admin-button-secondary" %>
    </div>
  <% end %>
</div>

<%# 统计卡片 %>
<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 20px;">
  <div class="admin-card" style="padding: 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
      <span style="font-size: 13px; color: var(--text-secondary);">总浏览量</span>
      <span style="font-size: 18px;">👁️</span>
    </div>
    <div style="font-size: 24px; font-weight: 600; color: #3b82f6;"><%= number_with_delimiter(@summary[:views]) %></div>
  </div>
  <div class="admin-card" style="padding: 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
      <span style="font-size: 13px; color: var(--text-secondary);">总点赞数</span>
      <span style="font-size: 18px;">❤️</span>
    </div>
    <div style="font-size: 24px; font-weight: 600; color: #ec4899;"><%= number_with_delimiter(@summary[:likes]) %></div>
  </div>
  <div class="admin-card" style="padding: 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
      <span style="font-size: 13px; color: var(--text-secondary);">总评论数</span>
      <span style="font-size: 18px;">💬</span>
    </div>
    <div style="font-size: 24px; font-weight: 600; color: #8b5cf6;"><%= number_with_delimiter(@summary[:comments]) %></div>
  </div>
  <div class="admin-card" style="padding: 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
      <span style="font-size: 13px; color: var(--text-secondary);">总转发数</span>
      <span style="font-size: 18px;">🔄</span>
    </div>
    <div style="font-size: 24px; font-weight: 600; color: #22c55e;"><%= number_with_delimiter(@summary[:shares]) %></div>
  </div>
</div>

<%# 趋势图表 %>
<div class="admin-card" style="margin-top: 20px;">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">趋势变化</div>
      <div class="admin-card-subtitle">按日期展示各平台数据走势</div>
    </div>
    <div class="admin-card-header-right" style="display: flex; gap: 6px;">
      <button type="button" class="metric-btn active" data-metric="views">浏览量</button>
      <button type="button" class="metric-btn" data-metric="likes">点赞数</button>
      <button type="button" class="metric-btn" data-metric="comments">评论数</button>
      <button type="button" class="metric-btn" data-metric="shares">转发数</button>
    </div>
  </div>

  <% if @trend_views.present? || @trend_likes.present? || @trend_comments.present? || @trend_shares.present? %>
    <div style="position: relative; height: 400px; padding: 20px;">
      <canvas id="trendChart"></canvas>
    </div>
  <% else %>
    <div class="admin-empty-state">
      <div style="font-size: 48px; margin-bottom: 12px;">📊</div>
      <div>暂无趋势数据，请先添加发文统计记录</div>
    </div>
  <% end %>
</div>

<style>
.metric-btn {
  background: transparent;
  color: var(--text-secondary);
  border: 1px solid var(--border-color);
  padding: 6px 14px;
  border-radius: 6px;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.2s;
}
.metric-btn:hover {
  background: var(--bg-secondary);
  color: var(--text-primary);
}
.metric-btn.active {
  background: var(--accent);
  color: #fff;
  border-color: var(--accent);
}
</style>

<script data-turbo-eval="true">
(function() {
  // 等待 Chart.js 加载
  function waitForChart(callback, attempts) {
    attempts = attempts || 0;
    if (typeof Chart !== 'undefined') {
      callback();
    } else if (attempts < 50) {
      setTimeout(function() { waitForChart(callback, attempts + 1); }, 100);
    }
  }

  // 解析趋势数据
  function parseTrendData(rawData) {
    var result = {};
    Object.keys(rawData).forEach(function(key) {
      var parts = key.split(',');
      var date = parts[0];
      var platform = parts[1];
      var value = rawData[key];
      if (!result[date]) result[date] = {};
      result[date][platform] = value;
    });
    return result;
  }

  var trendData = {
    views: parseTrendData(<%= @trend_views.to_json.html_safe %>),
    likes: parseTrendData(<%= @trend_likes.to_json.html_safe %>),
    comments: parseTrendData(<%= @trend_comments.to_json.html_safe %>),
    shares: parseTrendData(<%= @trend_shares.to_json.html_safe %>)
  };

  var platformConfig = {
    '1': { label: 'Facebook', color: '#3b82f6' },
    '2': { label: 'Twitter', color: '#06b6d4' },
    '3': { label: 'TikTok', color: '#ec4899' },
    '4': { label: 'YouTube', color: '#ef4444' },
    '5': { label: 'Instagram', color: '#a855f7' }
  };

  var currentMetric = 'views';
  var trendChart = null;

  function getChartData(metric) {
    var data = trendData[metric];
    var dates = Object.keys(data).sort();
    var platforms = {};
    
    dates.forEach(function(date) {
      Object.keys(data[date]).forEach(function(platform) {
        platforms[platform] = true;
      });
    });
    
    var platformList = Object.keys(platforms);
    
    var datasets = platformList.map(function(platform) {
      var config = platformConfig[platform] || { label: platform, color: '#94a3b8' };
      var platformData = dates.map(function(date) {
        return data[date][platform] || 0;
      });
      
      return {
        label: config.label,
        data: platformData,
        borderColor: config.color,
        backgroundColor: config.color + '33',
        borderWidth: 2,
        pointRadius: 4,
        pointHoverRadius: 6,
        tension: 0.3,
        fill: false
      };
    });

    return { labels: dates, datasets: datasets };
  }

  function renderChart() {
    var ctx = document.getElementById('trendChart');
    if (!ctx) return;
    
    if (trendChart) trendChart.destroy();
    
    trendChart = new Chart(ctx.getContext('2d'), {
      type: 'line',
      data: getChartData(currentMetric),
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: {
            position: 'top',
            labels: { color: '#94a3b8', usePointStyle: true, padding: 20, font: { size: 12 } }
          },
          tooltip: {
            backgroundColor: 'rgba(15, 23, 42, 0.95)',
            titleColor: '#e2e8f0',
            bodyColor: '#cbd5e1',
            borderColor: 'rgba(255,255,255,0.1)',
            borderWidth: 1,
            padding: 12
          }
        },
        scales: {
          x: {
            grid: { color: 'rgba(255,255,255,0.05)' },
            ticks: { color: '#64748b', maxTicksLimit: 15, font: { size: 11 } }
          },
          y: {
            beginAtZero: true,
            grid: { color: 'rgba(255,255,255,0.05)' },
            ticks: { color: '#64748b', font: { size: 11 } }
          }
        }
      }
    });
  }

  // 切换指标按钮
  document.addEventListener('click', function(e) {
    if (e.target.classList.contains('metric-btn')) {
      var metric = e.target.getAttribute('data-metric');
      if (!metric) return;
      
      currentMetric = metric;
      
      // 更新按钮active状态
      document.querySelectorAll('.metric-btn').forEach(function(btn) {
        btn.classList.remove('active');
      });
      e.target.classList.add('active');
      
      renderChart();
    }
  });

  // 初始化图表
  waitForChart(renderChart);
})();
</script>
