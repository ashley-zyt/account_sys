<% content_for :page_title do %>
  RedNote照片
<% end %>
<% content_for :page_subtitle do %>
  管理小红书关键词采集任务
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        关键词列表
      </div>
      <div class="admin-card-subtitle">
        管理关键词及对应的采集任务
      </div>
    </div>
    <div class="admin-card-header-right" style="display: flex; gap: 8px;">
      <button type="button" id="settings_btn" class="admin-button-secondary">设置</button>
      <%= button_to "同步状态", sync_status_admin_red_note_keywords_path, method: :post, class: "admin-button-secondary", form: { style: "display: inline;" } %>
      <button type="button" id="batch_add_btn" class="admin-button-primary">批量添加关键词</button>
    </div>
  </div>

  <div class="admin-filter-form">
    <%= search_form_for [:admin, @q], class: "admin-filter-form" do |f| %>
      <div class="admin-filter-group">
        <label class="admin-filter-label">主题</label>
        <%= f.select :theme_eq,
              options_for_select(@themes, @q.theme_eq),
              { include_blank: "全部主题" },
              { class: "admin-input admin-filter-input" } %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">状态</label>
        <%= f.select :status_eq,
              options_for_select(RedNoteKeyword::STATUS_NAMES.invert.to_a, @q.status_eq),
              { include_blank: "全部状态" },
              { class: "admin-input admin-filter-input" } %>
      </div>
      <div style="margin-left: auto;">
        <%= f.submit "筛选", class: "admin-button-primary" %>
        <%= link_to "重置", admin_red_note_keywords_path, class: "admin-button-secondary" %>
      </div>
    <% end %>
  </div>

  <% if @red_note_keywords.any? %>
    <%= form_tag batch_create_task_admin_red_note_keywords_path, method: :post, id: "batch_task_form" do %>
      <div class="admin-table-wrapper admin-table-scroll">
        <table class="admin-table">
          <thead>
            <tr>
              <th style="width: 40px;">
                <input type="checkbox" id="select_all" title="全选">
              </th>
              <th>主题</th>
              <th>关键词</th>
              <th>关键词编码</th>
              <th>状态</th>
              <th>创建时间</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @red_note_keywords.each do |kw| %>
              <tr>
                <td>
                  <input type="checkbox" name="keyword_ids[]" value="<%= kw.id %>" class="keyword-checkbox" <%= "disabled" unless kw.status == 0 %>>
                </td>
                <td>
                  <span class="admin-label-muted"><%= kw.theme %></span>
                </td>
                <td>
                  <span class="admin-label-muted"><%= kw.keyword %></span>
                </td>
                <td>
                  <code style="font-size: 12px; color: #93c5fd; background: rgba(59,130,246,0.1); padding: 2px 6px; border-radius: 3px;">
                    <%= kw.keyword_code %>
                  </code>
                </td>
                <td>
                  <%= status_badge(kw.status) %>
                </td>
                <td>
                  <span class="admin-label-muted">
                    <%= kw.created_at&.strftime('%Y-%m-%d %H:%M') %>
                  </span>
                </td>
                <td>
                  <div style="display: flex; gap: 8px; align-items: center;">
                    <% if kw.status == 0 %>
                      <%= button_to "创建任务", create_task_admin_red_note_keyword_path(kw),
                            method: :post,
                            class: "admin-button-secondary",
                            style: "font-size: 11px; padding: 3px 10px;",
                            form: { style: "display: inline;" } %>
                    <% elsif kw.status == 1 || kw.status == 2 %>
                      <%= button_to "同步", create_task_admin_red_note_keyword_path(kw),
                            method: :post,
                            class: "admin-button-secondary",
                            style: "font-size: 11px; padding: 3px 10px;",
                            form: { style: "display: inline;" } %>
                    <% end %>
                    <button type="button"
                            class="admin-link-quiet view-detail-btn"
                            style="font-size: 11px; color: #60a5fa; background: none; border: none; cursor: pointer;"
                            data-id="<%= kw.id %>">查看</button>
                    <%= link_to "删除", admin_red_note_keyword_path(kw),
                          data: { turbo_method: :delete, turbo_confirm: "确定删除该关键词吗？" },
                          class: "admin-link-quiet",
                          style: "color: #ef4444; font-size: 11px;" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 12px;">
        <button type="submit" class="admin-button-primary" style="font-size: 12px;" id="batch_create_task_btn">
          批量创建任务
        </button>
        <div class="admin-pagination">
          <%= paginate @red_note_keywords %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="admin-empty-state">
      暂无关键词数据。
    </div>
  <% end %>
</div>

<!-- 设置弹窗 -->
<div id="settings_modal" class="modal-overlay" style="display: none;">
  <div class="modal-content" style="max-width: 480px; width: 94%;">
    <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center;">
      <h3>采集参数设置</h3>
      <button type="button" id="settings_close_btn" style="background: transparent; border: none; color: #94a3b8; font-size: 22px; cursor: pointer; line-height: 1;">×</button>
    </div>
    <div class="modal-body">
      <%= form_tag update_settings_admin_red_note_keywords_path, method: :patch, id: "settings_form" do %>
        <div class="admin-form-group">
          <label class="admin-form-label">
            search_max_results <span style="color: #ef4444;">*</span>
          </label>
          <input type="number" name="red_note_setting[search_max_results]" id="setting_search_max_results"
                 class="admin-input" min="1" max="100" value="<%= @setting.search_max_results %>"
                 style="width: 100%;">
          <div style="font-size: 11px; color: #64748b; margin-top: 4px;">
            获取搜索结果的前 N 条帖子，默认 20
          </div>
        </div>

        <div class="admin-form-group">
          <label class="admin-form-label">
            top_n_by_likes <span style="color: #ef4444;">*</span>
          </label>
          <input type="number" name="red_note_setting[top_n_by_likes]" id="setting_top_n_by_likes"
                 class="admin-input" min="1" max="100" value="<%= @setting.top_n_by_likes %>"
                 style="width: 100%;">
          <div style="font-size: 11px; color: #64748b; margin-top: 4px;">
            在前 N 条帖子里按点赞量排序，下载点赞量高的前 M 条，默认 3
          </div>
        </div>

        <div class="admin-form-actions" style="display: flex; gap: 12px; justify-content: flex-end; margin-top: 16px; padding-top: 16px; border-top: 1px solid #334155;">
          <button type="button" id="settings_cancel_btn" class="admin-button-secondary">取消</button>
          <button type="submit" class="admin-button-primary">保存设置</button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- 批量添加关键词弹窗 -->
<div id="batch_add_modal" class="modal-overlay" style="display: none;">
  <div class="modal-content" style="max-width: 560px; width: 94%;">
    <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center;">
      <h3>批量添加关键词</h3>
      <button type="button" id="modal_close_btn" style="background: transparent; border: none; color: #94a3b8; font-size: 22px; cursor: pointer; line-height: 1;">×</button>
    </div>
    <div class="modal-body">
      <%= form_tag admin_red_note_keywords_path, method: :post, id: "batch_add_form" do %>
        <div class="admin-form-group">
          <label class="admin-form-label">
            选择主题 <span style="color: #ef4444;">*</span>
          </label>
          <%= render "admin/shared/searchable_theme_select",
                name: "theme",
                themes: @themes,
                selected: nil,
                placeholder: "请选择主题",
                include_blank: "请选择主题" %>
        </div>

        <div class="admin-form-group">
          <label class="admin-form-label">
            关键词列表 <span style="color: #ef4444;">*</span>
          </label>
          <textarea name="keywords_text" id="keywords_text" rows="8" class="admin-input"
                    placeholder="每行一个关键词，格式：关键词 编码（空格或 / 分割）&#10;例如：&#10;#北海#涠洲岛海景竖图素材 A0002&#10;桂林山水风景图片 B0003"
                    style="width: 100%; resize: vertical; font-size: 13px; line-height: 1.6;"></textarea>
          <div style="font-size: 11px; color: #64748b; margin-top: 4px;">
            每行输入一个关键词，关键词和编码之间用空格或 "/" 分割
          </div>
        </div>

        <div class="admin-form-actions" style="display: flex; gap: 12px; justify-content: flex-end; margin-top: 16px; padding-top: 16px; border-top: 1px solid #334155;">
          <button type="button" id="modal_cancel_btn" class="admin-button-secondary">取消</button>
          <button type="submit" class="admin-button-primary">确认添加</button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- 查看详情弹窗 -->
<div id="detail_modal" class="modal-overlay" style="display: none;">
  <div class="modal-content" style="max-width: 640px; width: 94%;">
    <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center;">
      <h3 id="detail_title">关键词详情</h3>
      <button type="button" id="detail_close_btn" style="background: transparent; border: none; color: #94a3b8; font-size: 22px; cursor: pointer; line-height: 1;">×</button>
    </div>
    <div class="modal-body" id="detail_body" style="max-height: 65vh; overflow-y: auto;">
      加载中...
    </div>
  </div>
</div>

<script>
(function() {
  if (document.getElementById('red_note_keywords_initialized')) return;
  var marker = document.createElement('div');
  marker.id = 'red_note_keywords_initialized';
  marker.style.display = 'none';
  document.body.appendChild(marker);

  function init() {
    // 设置弹窗
    var settingsBtn = document.getElementById('settings_btn');
    var settingsModal = document.getElementById('settings_modal');
    if (settingsBtn && settingsModal) {
      settingsBtn.addEventListener('click', function() {
        settingsModal.style.display = 'flex';
      });
      document.getElementById('settings_close_btn').addEventListener('click', function() {
        settingsModal.style.display = 'none';
      });
      document.getElementById('settings_cancel_btn').addEventListener('click', function() {
        settingsModal.style.display = 'none';
      });
      settingsModal.addEventListener('click', function(e) {
        if (e.target === settingsModal) settingsModal.style.display = 'none';
      });
    }

    // 批量添加弹窗
    var batchAddBtn = document.getElementById('batch_add_btn');
    var batchAddModal = document.getElementById('batch_add_modal');
    if (batchAddBtn && batchAddModal) {
      batchAddBtn.addEventListener('click', function() {
        batchAddModal.style.display = 'flex';
      });
      document.getElementById('modal_close_btn').addEventListener('click', function() {
        batchAddModal.style.display = 'none';
      });
      document.getElementById('modal_cancel_btn').addEventListener('click', function() {
        batchAddModal.style.display = 'none';
      });
      batchAddModal.addEventListener('click', function(e) {
        if (e.target === batchAddModal) batchAddModal.style.display = 'none';
      });
    }

    // 查看详情弹窗
    var detailModal = document.getElementById('detail_modal');
    if (detailModal) {
      document.getElementById('detail_close_btn').addEventListener('click', function() {
        detailModal.style.display = 'none';
      });
      detailModal.addEventListener('click', function(e) {
        if (e.target === detailModal) detailModal.style.display = 'none';
      });
    }

    // 全选/取消全选
    var selectAll = document.getElementById('select_all');
    if (selectAll) {
      selectAll.addEventListener('change', function() {
        var checked = this.checked;
        document.querySelectorAll('.keyword-checkbox:not([disabled])').forEach(function(cb) {
          cb.checked = checked;
        });
      });
    }

    // 查看详情按钮
    document.querySelectorAll('.view-detail-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = this.getAttribute('data-id');
        var body = document.getElementById('detail_body');
        detailModal.style.display = 'flex';
        body.innerHTML = '<div style="text-align:center;color:#94a3b8;padding:24px;">加载中...</div>';

        fetch('/admin/red_note_keywords/' + id)
          .then(function(r) { return r.text(); })
          .then(function(html) {
            var temp = document.createElement('div');
            temp.innerHTML = html;
            var infoEl = temp.querySelector('.keyword-detail-info');
            var resultEl = temp.querySelector('.keyword-result-data');
            if (infoEl) {
              body.innerHTML = infoEl.outerHTML + (resultEl ? resultEl.outerHTML : '');
            } else {
              body.innerHTML = html;
            }
          })
          .catch(function() {
            body.innerHTML = '<div style="text-align:center;color:#fca5a5;padding:24px;">加载失败</div>';
          });
      });
    });

    // ESC 关闭弹窗
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        var modals = document.querySelectorAll('.modal-overlay');
        modals.forEach(function(m) { m.style.display = 'none'; });
      }
    });

    // 批量创建任务确认
    var batchForm = document.getElementById('batch_task_form');
    if (batchForm) {
      batchForm.addEventListener('submit', function(e) {
        var checked = document.querySelectorAll('.keyword-checkbox:checked');
        if (checked.length === 0) {
          e.preventDefault();
          alert('请先选择需要创建任务的关键词');
        }
      });
    }
  }

  document.addEventListener('turbo:load', init);
  // 首次加载（非 Turbo 导航）时也要初始化
  if (document.readyState === 'complete') {
    init();
  } else {
    window.addEventListener('load', init);
  }
})();
</script>
