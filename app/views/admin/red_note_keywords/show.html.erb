<% content_for :page_title do %>
  关键词详情
<% end %>
<% content_for :page_subtitle do %>
  <%= @red_note_keyword.keyword %> · <%= @red_note_keyword.keyword_code %>
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        <%= @red_note_keyword.keyword %>
      </div>
      <div class="admin-card-subtitle">
        编码：<%= @red_note_keyword.keyword_code %>
      </div>
    </div>
    <div class="admin-card-header-right" style="display: flex; gap: 8px;">
      <% if @red_note_keyword.status == 0 %>
        <%= button_to "创建任务", create_task_admin_red_note_keyword_path(@red_note_keyword),
              method: :post, class: "admin-button-primary",
              form: { style: "display: inline;" } %>
      <% elsif @red_note_keyword.status == 1 || @red_note_keyword.status == 2 %>
        <%= button_to "同步状态", sync_task_admin_red_note_keyword_path(@red_note_keyword),
              method: :post, class: "admin-button-primary",
              form: { style: "display: inline;" } %>
      <% end %>
      <%= link_to "返回列表", admin_red_note_keywords_path, class: "admin-button-secondary" %>
    </div>
  </div>

  <!-- 基本信息 -->
  <div style="padding: 20px 0; border-bottom: 1px solid #334155;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px 40px;">
      <div class="info-item">
        <span class="info-label">主题</span>
        <span class="info-value"><%= @red_note_keyword.theme %></span>
      </div>
      <div class="info-item">
        <span class="info-label">关键词</span>
        <span class="info-value"><%= @red_note_keyword.keyword %></span>
      </div>
      <div class="info-item">
        <span class="info-label">关键词编码</span>
        <span class="info-value">
          <code style="background: rgba(59,130,246,0.1); padding: 3px 10px; border-radius: 4px; color: #93c5fd; font-size: 13px;">
            <%= @red_note_keyword.keyword_code %>
          </code>
        </span>
      </div>
      <div class="info-item">
        <span class="info-label">任务状态</span>
        <span class="info-value"><%= status_badge(@red_note_keyword.status) %></span>
      </div>
      <% if @red_note_keyword.task_id.present? %>
      <div class="info-item">
        <span class="info-label">远程任务ID</span>
        <span class="info-value" style="font-family: monospace; font-size: 12px;"><%= @red_note_keyword.task_id %></span>
      </div>
      <% end %>
      <div class="info-item">
        <span class="info-label">创建时间</span>
        <span class="info-value"><%= @red_note_keyword.created_at&.strftime('%Y-%m-%d %H:%M:%S') %></span>
      </div>
      <div class="info-item">
        <span class="info-label">更新时间</span>
        <span class="info-value"><%= @red_note_keyword.updated_at&.strftime('%Y-%m-%d %H:%M:%S') %></span>
      </div>
    </div>
  </div>

  <!-- 图片文件 -->
  <%
    image_names = JSON.parse(@red_note_keyword.image_names) rescue []
    has_images = image_names.is_a?(Array) && image_names.any?
  %>
  <div style="padding: 20px 0; border-bottom: 1px solid #334155;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
      <div>
        <span style="font-size: 14px; color: #e2e8f0; font-weight: 600;">图片文件</span>
        <span style="color: #64748b; font-weight: 400; font-size: 12px; margin-left: 8px;">
          <% if has_images %>
            （共 <%= image_names.size %> 张）
          <% else %>
            （暂无图片）
          <% end %>
        </span>
      </div>
      <div style="display: flex; gap: 8px;">
        <% if @red_note_keyword.status == 3 && !has_images %>
          <%= button_to "同步状态", sync_task_admin_red_note_keyword_path(@red_note_keyword),
                method: :post, class: "admin-button-secondary", style: "font-size: 12px;",
                form: { style: "display: inline;" } %>
        <% end %>
        <% if @red_note_keyword.status == 1 || @red_note_keyword.status == 2 %>
          <%= button_to "同步状态", sync_task_admin_red_note_keyword_path(@red_note_keyword),
                method: :post, class: "admin-button-secondary", style: "font-size: 12px;",
                form: { style: "display: inline;" } %>
        <% end %>
      </div>
    </div>

    <% if has_images %>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px;">
        <% image_names.each_with_index do |name, idx| %>
          <%
            url_data = @oss_image_urls.find { |u| u[:name] == name }
            img_url = url_data ? url_data[:url] : nil
          %>
          <div style="border: 1px solid #334155; border-radius: 8px; overflow: hidden; background: rgba(15,23,42,0.5); transition: border-color 0.2s;" onmouseover="this.style.borderColor='#3b82f6'" onmouseout="this.style.borderColor='#334155'">
            <% if img_url %>
              <a href="<%= img_url %>" target="_blank" style="display: block; background: #000; height: 160px; overflow: hidden;">
                <img src="<%= img_url %>"
                     alt="<%= name %>" loading="lazy"
                     style="width: 100%; height: 100%; object-fit: cover; display: block;"
                     onerror="this.parentElement.innerHTML='<div style=\'display:flex;align-items:center;justify-content:center;height:160px;color:#64748b;font-size:12px;\'>加载失败</div>'">
              </a>
            <% else %>
              <div style="display: flex; align-items: center; justify-content: center; height: 160px; color: #64748b; font-size: 12px; background: #000;">
                OSS 未配置
              </div>
            <% end %>
            <div style="padding: 8px 10px; display: flex; align-items: center; justify-content: space-between;">
              <code style="font-size: 11px; color: #94a3b8; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; margin-right: 6px;" title="<%= name %>"><%= name %></code>
              <% if img_url %>
                <button class="rn-copy-btn" data-url="<%= img_url %>" style="flex-shrink: 0;" title="复制链接">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                </button>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% elsif @red_note_keyword.status == 3 %>
      <div style="text-align: center; padding: 32px 16px; color: #64748b;">
        <div style="font-size: 36px; margin-bottom: 8px;">🖼️</div>
        <div style="font-size: 13px;">任务执行完成但暂无图片数据，请尝试同步</div>
      </div>
    <% else %>
      <div style="text-align: center; padding: 32px 16px; color: #64748b;">
        <div style="font-size: 13px;">暂无图片数据</div>
      </div>
    <% end %>
  </div>

  <!-- 原始响应数据 -->
  <%
    result = JSON.parse(@red_note_keyword.result_data) rescue {}
  %>
  <% if @red_note_keyword.result_data.present? %>
  <div style="padding: 20px 0;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
      <span style="font-size: 14px; color: #e2e8f0; font-weight: 600;">API 原始响应</span>
      <button id="toggle_raw_btn" style="font-size: 11px; color: #64748b; background: transparent; border: 1px solid #334155; border-radius: 4px; padding: 3px 10px; cursor: pointer;">展开</button>
    </div>
    <pre id="raw_data_block" style="display: none; background: rgba(15,23,42,0.6); border: 1px solid #334155; border-radius: 6px; padding: 12px; color: #cbd5e1; font-size: 12px; line-height: 1.5; overflow-x: auto; white-space: pre-wrap; word-break: break-all; max-height: 400px; overflow-y: auto;"><%== JSON.pretty_generate(result) %></pre>
  </div>
  <% end %>
</div>

<style>
  .info-item { display: flex; flex-direction: column; gap: 2px; }
  .info-label { color: #64748b; font-size: 12px; }
  .info-value { color: #e2e8f0; font-size: 14px; }
  .rn-copy-btn {
    background: rgba(59, 130, 246, 0.12);
    border: 1px solid rgba(59, 130, 246, 0.25);
    color: #60a5fa;
    border-radius: 4px;
    padding: 3px 6px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    transition: all 0.15s;
  }
  .rn-copy-btn:hover {
    background: rgba(59, 130, 246, 0.25);
    color: #93c5fd;
  }
</style>

<script>
document.getElementById('toggle_raw_btn')?.addEventListener('click', function() {
  var block = document.getElementById('raw_data_block');
  if (block.style.display === 'none') {
    block.style.display = 'block';
    this.textContent = '收起';
  } else {
    block.style.display = 'none';
    this.textContent = '展开';
  }
});

document.addEventListener('click', function(e) {
  var btn = e.target.closest('.rn-copy-btn');
  if (!btn) return;
  var url = btn.getAttribute('data-url') || '';
  var ta = document.createElement('textarea');
  ta.value = url;
  ta.style.position = 'fixed';
  ta.style.opacity = '0';
  document.body.appendChild(ta);
  ta.select();
  try {
    document.execCommand('copy');
    btn.querySelector('svg')?.setAttribute('stroke', '#22c55e');
    setTimeout(function() { btn.querySelector('svg')?.setAttribute('stroke', 'currentColor'); }, 1500);
  } catch(err) {}
  document.body.removeChild(ta);
});
</script>
