<!-- 关键词详情片段，用于弹窗展示 -->
<div class="keyword-detail-info">
  <table style="width: 100%; border-collapse: collapse;">
    <tr>
      <td style="padding: 8px 12px; color: #94a3b8; font-size: 13px; width: 100px;">主题</td>
      <td style="padding: 8px 12px; color: #e2e8f0; font-size: 13px;"><%= @red_note_keyword.theme %></td>
    </tr>
    <tr>
      <td style="padding: 8px 12px; color: #94a3b8; font-size: 13px;">关键词</td>
      <td style="padding: 8px 12px; color: #e2e8f0; font-size: 13px;"><%= @red_note_keyword.keyword %></td>
    </tr>
    <tr>
      <td style="padding: 8px 12px; color: #94a3b8; font-size: 13px;">编码</td>
      <td style="padding: 8px 12px; color: #93c5fd; font-size: 13px;">
        <code style="background: rgba(59,130,246,0.1); padding: 2px 8px; border-radius: 3px;">
          <%= @red_note_keyword.keyword_code %>
        </code>
      </td>
    </tr>
    <tr>
      <td style="padding: 8px 12px; color: #94a3b8; font-size: 13px;">状态</td>
      <td style="padding: 8px 12px;"><%= status_badge(@red_note_keyword.status) %></td>
    </tr>
    <% if @red_note_keyword.task_id.present? %>
    <tr>
      <td style="padding: 8px 12px; color: #94a3b8; font-size: 13px;">任务ID</td>
      <td style="padding: 8px 12px; color: #e2e8f0; font-size: 13px;">
        <code style="font-size: 12px; color: #cbd5e1;"><%= @red_note_keyword.task_id %></code>
      </td>
    </tr>
    <% end %>
    <tr>
      <td style="padding: 8px 12px; color: #94a3b8; font-size: 13px;">创建时间</td>
      <td style="padding: 8px 12px; color: #e2e8f0; font-size: 13px;"><%= @red_note_keyword.created_at&.strftime('%Y-%m-%d %H:%M:%S') %></td>
    </tr>
    <tr>
      <td style="padding: 8px 12px; color: #94a3b8; font-size: 13px;">更新时间</td>
      <td style="padding: 8px 12px; color: #e2e8f0; font-size: 13px;"><%= @red_note_keyword.updated_at&.strftime('%Y-%m-%d %H:%M:%S') %></td>
    </tr>
  </table>
</div>

<% if @red_note_keyword.result_data.present? %>
<div class="keyword-result-data" style="margin-top: 16px; border-top: 1px solid #334155; padding-top: 16px;">
  <div style="color: #94a3b8; font-size: 13px; margin-bottom: 8px;">采集结果数据</div>
  <pre style="background: rgba(15,23,42,0.6); border: 1px solid #334155; border-radius: 6px; padding: 12px; color: #cbd5e1; font-size: 12px; line-height: 1.5; overflow-x: auto; white-space: pre-wrap; word-break: break-all; max-height: 300px; overflow-y: auto;"><%== JSON.pretty_generate(JSON.parse(@red_note_keyword.result_data) rescue { raw: @red_note_keyword.result_data }) %></pre>
</div>
<% end %>
