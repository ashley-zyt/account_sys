<div class="searchable-select-wrapper">
  <div class="searchable-select" data-select-name="<%= name %>">
    <div class="searchable-select-selected" tabindex="0">
      <span class="searchable-select-value">
        <%= selected.present? ? selected : placeholder %>
      </span>
      <span class="searchable-select-arrow">▼</span>
    </div>
    <div class="searchable-select-dropdown" style="display: none;">
      <input type="text" class="searchable-select-input" placeholder="搜索主题...">
      <ul class="searchable-select-list">
        <% if include_blank %>
          <li class="searchable-select-option" data-value="">
            <span class="searchable-select-option-text"><%= include_blank %></span>
          </li>
        <% end %>
        <% themes.each do |theme| %>
          <li class="searchable-select-option" data-value="<%= theme %>">
            <span class="searchable-select-option-text"><%= theme %></span>
          </li>
        <% end %>
      </ul>
    </div>
    <input type="hidden" name="<%= name %>" value="<%= selected %>" class="searchable-select-hidden">
  </div>
</div>

<style scoped>
  .searchable-select-wrapper {
    position: relative;
    width: 100%;
  }

  .searchable-select {
    position: relative;
    width: 100%;
    font-size: 14px;
  }

  .searchable-select-selected {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 6px;
    cursor: pointer;
    color: #e2e8f0;
    min-height: 40px;
  }

  .searchable-select-selected:hover {
    border-color: #475569;
  }

  .searchable-select-selected:focus {
    outline: none;
    border-color: #3b82f6;
  }

  .searchable-select-value {
    flex: 1;
    text-align: left;
  }

  .searchable-select-arrow {
    font-size: 10px;
    color: #64748b;
    margin-left: 8px;
  }

  .searchable-select-dropdown {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 6px;
    z-index: 100;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
  }

  .searchable-select-input {
    width: 100%;
    padding: 10px 12px;
    border: none;
    border-bottom: 1px solid #334155;
    background: #1e293b;
    color: #e2e8f0;
    font-size: 14px;
    box-sizing: border-box;
  }

  .searchable-select-input:focus {
    outline: none;
  }

  .searchable-select-list {
    list-style: none;
    padding: 0;
    margin: 0;
    max-height: 200px;
    overflow-y: auto;
  }

  .searchable-select-option {
    padding: 10px 12px;
    cursor: pointer;
    color: #e2e8f0;
  }

  .searchable-select-option:hover {
    background: #334155;
  }

  .searchable-select-option-text {
    display: block;
  }

  .searchable-select-hidden {
    display: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const selectWrappers = document.querySelectorAll('.searchable-select');
    
    selectWrappers.forEach(function(wrapper) {
      const selectedDiv = wrapper.querySelector('.searchable-select-selected');
      const dropdown = wrapper.querySelector('.searchable-select-dropdown');
      const input = wrapper.querySelector('.searchable-select-input');
      const list = wrapper.querySelector('.searchable-select-list');
      const hiddenInput = wrapper.querySelector('.searchable-select-hidden');
      const valueSpan = wrapper.querySelector('.searchable-select-value');
      const placeholder = valueSpan.textContent.trim();

      selectedDiv.addEventListener('click', function(e) {
        e.stopPropagation();
        dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
        if (dropdown.style.display === 'block') {
          input.focus();
        }
      });

      input.addEventListener('input', function() {
        const searchTerm = this.value.toLowerCase();
        const options = list.querySelectorAll('.searchable-select-option');
        
        options.forEach(function(option) {
          const text = option.textContent.toLowerCase();
          if (text.includes(searchTerm)) {
            option.style.display = 'block';
          } else {
            option.style.display = 'none';
          }
        });
      });

      list.addEventListener('click', function(e) {
        const option = e.target.closest('.searchable-select-option');
        if (option) {
          const value = option.getAttribute('data-value');
          const text = option.textContent.trim();
          
          hiddenInput.value = value;
          valueSpan.textContent = text || placeholder;
          dropdown.style.display = 'none';
        }
      });

      document.addEventListener('click', function(e) {
        if (!wrapper.contains(e.target)) {
          dropdown.style.display = 'none';
        }
      });

      selectedDiv.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          dropdown.style.display = 'block';
          input.focus();
        } else if (e.key === 'Escape') {
          dropdown.style.display = 'none';
        }
      });
    });
  });
</script>
