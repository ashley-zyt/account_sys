<% content_for :page_title do %>
  任务日志
<% end %>
<% content_for :page_subtitle do %>
  最近产生的任务执行日志
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        任务日志
      </div>
      <div class="admin-card-subtitle">
        按时间倒序展示系统运行日志
      </div>
    </div>
    <div class="admin-card-header-right">
      <span class="admin-tag">
        共 <%= @task_logs.total_count %> 条
      </span>
    </div>
  </div>

  <div class="admin-filter-form">
    <%= search_form_for [:admin, @q], class: "admin-filter-form" do |f| %>
      <div class="admin-filter-group">
        <label class="admin-filter-label">任务 UUID</label>
        <%= f.search_field :task_uuid_cont, class: "admin-input admin-filter-input", placeholder: "搜索任务 UUID..." %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">状态</label>
        <%= f.select :status_eq, TaskLog.statuses.map { |k, v| [k.to_s.titleize, v] }, { include_blank: "所有状态" }, class: "admin-input admin-filter-input" %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">任务类型</label>
        <%= f.select :task_type_eq, [["搬运任务", "move_task"], ["剪映任务", "jianying_task"], ["运营任务", "operation_task"], ["Grok任务", "grok_task"]], { include_blank: "所有类型" }, class: "admin-input admin-filter-input" %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">账号平台</label>
        <%= f.select :account_platform_eq, Account.platforms.keys.map { |k| [k.titleize, k] }, { include_blank: "所有平台" }, class: "admin-input admin-filter-input" %>
      </div>
      <div style="margin-left: auto;">
        <%= f.submit "筛选", class: "admin-button-primary" %>
        <%= link_to "重置", admin_task_logs_path, class: "admin-button-secondary" %>
      </div>
    <% end %>
  </div>

  <% if @task_logs.any? %>
    <div class="admin-table-wrapper admin-table-scroll">
      <table class="admin-table">
        <thead>
          <tr>
            <th>
              任务类型
            </th>
            <th>
              任务ID
            </th>
            <th>
              账号
            </th>
            <th>
              平台
            </th>
            <th>
              浏览器
            </th>
            <th>
              运营人员
            </th>
            <th>
              状态
            </th>
            <th>
              执行时间
            </th>
            <th>
              错误信息
            </th>
            <th>
              创建时间
            </th>
            <th>
              操作
            </th>
          </tr>
        </thead>
        <tbody>
          <% @task_logs.each do |log| %>
            <tr>
              <td>
                <% task_type = log.task_type %>
                <% if task_type == "搬运任务" %>
                  <span class="admin-pill-status" style="background: rgba(34, 197, 94, 0.1); color: #22c55e;">
                    搬运任务
                  </span>
                <% elsif task_type == "剪映任务" %>
                  <span class="admin-pill-status" style="background: rgba(59, 130, 246, 0.1); color: #3b82f6;">
                    剪映任务
                  </span>
                <% elsif task_type == "运营任务" %>
                  <span class="admin-pill-status" style="background: rgba(168, 85, 247, 0.1); color: #a855f7;">
                    运营任务
                  </span>
                <% elsif task_type == "Grok任务" %>
                  <span class="admin-pill-status" style="background: rgba(249, 115, 22, 0.1); color: #f97316;">
                    Grok任务
                  </span>
                <% else %>
                  <span class="admin-label-muted">
                    <%= task_type %>
                  </span>
                <% end %>
              </td>
              <td>
                <%= link_to log.id, admin_task_log_path(log), class: "admin-link-quiet", title: log.task_uuid %>
              </td>
              <td>
                <% acc = log.display_account %>
                <% if acc %>
                  <%= link_to acc.account_name, admin_account_path(acc), class: "admin-link-quiet", style: "color: var(--accent);" %>
                <% else %>
                  <span class="admin-label-muted">未分配</span>
                <% end %>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= log.display_platform %>
                </span>
              </td>
              <td>
                <% br = log.display_browser %>
                <% if br %>
                  <%= link_to br.profile_name, admin_browser_path(br), class: "admin-link-quiet", style: "color: var(--accent);" %>
                <% else %>
                  <span class="admin-label-muted">未绑定</span>
                <% end %>
              </td>
              <td>
                <span class="admin-label-muted">
                  <% if log.task_type == "运营任务" && log.display_account %>
                    <%= log.display_account.operator || "-" %>
                  <% elsif log.task_type == "Grok任务" %>
                    Grok
                  <% else %>
                    -
                  <% end %>
                </span>
              </td>
              <td>
                <% if log.status == "success" %>
                  <span class="admin-pill-status admin-pill-status-success">
                    <span class="admin-pill-status-dot"></span>
                    成功
                  </span>
                <% else %>
                  <span class="admin-pill-status admin-pill-status-failed">
                    <span class="admin-pill-status-dot"></span>
                    失败
                  </span>
                <% end %>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= log.run_at&.strftime("%Y-%m-%d %H:%M") %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= truncate(log.error_msg.to_s, length: 40) %>
                </span>
              </td>
              <td>
                <span class="admin-label-muted">
                  <%= log.created_at&.strftime("%m-%d %H:%M") %>
                </span>
              </td>
              <td>
                <% t = log.task %>
                <% if t %>
                  <% if t.is_a?(MoveTask) %>
                    <%= link_to "查看搬运任务", admin_move_task_path(t), class: "admin-link-quiet", style: "color: var(--success);" %>
                  <% elsif t.is_a?(JianyingTask) %>
                    <%= link_to "查看剪映任务", admin_jianying_task_path(t), class: "admin-link-quiet", style: "color: var(--accent);" %>
                  <% elsif t.is_a?(OperationTask) %>
                    <%= link_to "查看运营任务", admin_operation_task_path(t), class: "admin-link-quiet", style: "color: #a855f7;" %>
                  <% elsif t.is_a?(GrokTask) %>
                    <%= link_to "查看 Grok 任务", admin_grok_task_path(t), class: "admin-link-quiet", style: "color: #f97316;" %>
                  <% end %>
                <% else %>
                  <span class="admin-label-muted">任务不存在</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="admin-pagination">
      <%= paginate @task_logs %>
    </div>
  <% else %>
    <div class="admin-empty-state">
      暂无日志数据。
    </div>
  <% end %>
</div>

