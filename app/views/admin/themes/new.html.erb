<% content_for :page_title do %>
  新增主题
<% end %>
<% content_for :page_subtitle do %>
  创建新的内容主题
<% end %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">
        新增主题
      </div>
      <div class="admin-card-subtitle">
        填写主题信息
      </div>
    </div>
  </div>

  <%= form_for [:admin, @theme] do |f| %>
    <div class="admin-form">
      <div class="admin-form-group">
        <%= f.label :name, class: "admin-form-label" %>
        <div class="admin-form-hint">必填</div>
        <%= f.text_field :name, class: "admin-input", placeholder: "主题名称" %>
      </div>

      <div class="admin-form-group">
        <%= f.label :oss_directory, class: "admin-form-label" %>
        <div class="admin-form-hint">OSS存储目录名称</div>
        <%= f.text_field :oss_directory, class: "admin-input", placeholder: "oss_directory_name" %>
      </div>

      <div class="admin-form-group">
        <%= f.label :titles, class: "admin-form-label" %>
        <div class="admin-form-hint">待选标题列表，每行一个标题</div>
        <%= f.text_area :titles, class: "admin-input", placeholder: "标题1\n标题2\n标题3", rows: 8 %>
      </div>

      <div class="admin-form-group">
        <%= f.label :remark, class: "admin-form-label" %>
        <div class="admin-form-hint">备注信息</div>
        <%= f.text_area :remark, class: "admin-input", placeholder: "备注说明", rows: 3 %>
      </div>

      <div class="admin-form-actions">
        <%= link_to "取消", admin_themes_path, class: "admin-button-secondary" %>
        <%= f.submit "创建", class: "admin-button-primary" %>
      </div>
    </div>
  <% end %>
</div>
