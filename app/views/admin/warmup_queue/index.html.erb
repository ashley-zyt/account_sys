<% content_for :page_title do %>
  养号配置
<% end %>
<% content_for :page_subtitle do %>
  管理账号养号状态，按养号紧急程度排序
<% end %>

<%# --- 调度状态概览 --- %>
<div class="admin-card" style="padding: 20px; margin-bottom: 24px;">
  <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
    <div style="width: 32px; height: 32px; border-radius: 8px; background: rgba(59, 130, 246, 0.1); display: flex; align-items: center; justify-content: center; font-size: 16px;">
      ⚙️
    </div>
    <div>
      <div style="font-size: 15px; font-weight: 600; color: var(--text-primary);">调度配置</div>
      <div style="font-size: 12px; color: var(--text-secondary);">两台机器独立运行，各自控制时长</div>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
    <%# 可用账号 %>
    <div style="padding: 14px; border-radius: 10px; background: var(--bg-secondary, #f8f9fa); border: 1px solid var(--border-color, #e5e7eb);">
      <div style="font-size: 12px; color: var(--text-secondary); margin-bottom: 12px;">可用账号</div>
      <div style="display: flex; gap: 20px; align-items: baseline;">
        <div>
          <div style="font-size: 22px; font-weight: 700; color: #3b82f6;"><%= @move_total %></div>
          <div style="font-size: 11px; color: var(--text-tertiary);">搬运机器</div>
        </div>
        <div style="width: 1px; height: 32px; background: var(--border-color, #e5e7eb);"></div>
        <div>
          <div style="font-size: 22px; font-weight: 700; color: #8b5cf6;"><%= @other_total %></div>
          <div style="font-size: 11px; color: var(--text-tertiary);">运营机器</div>
        </div>
      </div>
    </div>
    <%# 养号启用 %>
    <div style="padding: 14px; border-radius: 10px; background: var(--bg-secondary, #f8f9fa); border: 1px solid var(--border-color, #e5e7eb);">
      <div style="font-size: 12px; color: var(--text-secondary); margin-bottom: 12px;">养号启用</div>
      <div style="display: flex; gap: 20px; align-items: baseline;">
        <div>
          <div style="font-size: 22px; font-weight: 700; color: #3b82f6;"><%= @move_enabled %></div>
          <div style="font-size: 11px; color: var(--text-tertiary);">搬运机器</div>
        </div>
        <div style="width: 1px; height: 32px; background: var(--border-color, #e5e7eb);"></div>
        <div>
          <div style="font-size: 22px; font-weight: 700; color: #8b5cf6;"><%= @other_enabled %></div>
          <div style="font-size: 11px; color: var(--text-tertiary);">运营机器</div>
        </div>
      </div>
    </div>
    <%# 待养号 %>
    <div style="padding: 14px; border-radius: 10px; background: var(--bg-secondary, #f8f9fa); border: 1px solid var(--border-color, #e5e7eb);">
      <div style="font-size: 12px; color: var(--text-secondary); margin-bottom: 12px;">待养号（>48h）</div>
      <div style="display: flex; gap: 20px; align-items: baseline;">
        <div>
          <div style="font-size: 22px; font-weight: 700; color: #3b82f6;"><%= @move_due %></div>
          <div style="font-size: 11px; color: var(--text-tertiary);">搬运机器</div>
        </div>
        <div style="width: 1px; height: 32px; background: var(--border-color, #e5e7eb);"></div>
        <div>
          <div style="font-size: 22px; font-weight: 700; color: #8b5cf6;"><%= @other_due %></div>
          <div style="font-size: 11px; color: var(--text-tertiary);">运营机器</div>
        </div>
      </div>
    </div>
  </div>
</div>

<%# --- 配置列表 --- %>
<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <div class="admin-card-title">配置列表</div>
      <div class="admin-card-subtitle">按养号紧急程度排序（从未养号优先，其次按上次养号时间升序）</div>
    </div>
    <div class="admin-card-header-right">
      <span class="admin-tag">共 <%= @accounts.total_count %> 个账号</span>
    </div>
  </div>

  <div class="admin-filter-form">
    <%= search_form_for [:admin, @q], url: admin_warmup_queue_index_path, class: "admin-filter-form" do |f| %>
      <div class="admin-filter-group">
        <label class="admin-filter-label">账号名</label>
        <%= f.search_field :account_name_cont, class: "admin-input admin-filter-input", placeholder: "搜索账号名..." %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">平台</label>
        <%= f.select :platform_eq, Account.platforms.map { |k, v| [k.to_s.titleize, v] }, { include_blank: "所有平台" }, class: "admin-input admin-filter-input" %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">工作模式</label>
        <%= f.select :work_type_eq, Account.work_types.map { |k, v| [k, v] }, { include_blank: "所有模式" }, class: "admin-input admin-filter-input" %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">状态</label>
        <%= f.select :status_eq, Account.statuses.map { |k, v| [k, v] }, { include_blank: "所有状态" }, class: "admin-input admin-filter-input" %>
      </div>
      <div class="admin-filter-group">
        <label class="admin-filter-label">养号开关</label>
        <%= f.select :warmup_profile_warmup_enabled_eq, [["启用", true], ["停用", false]], { include_blank: "全部" }, class: "admin-input admin-filter-input" %>
      </div>
      <div style="margin-left: auto;">
        <%= f.submit "筛选", class: "admin-button-primary" %>
        <%= link_to "重置", admin_warmup_queue_index_path, class: "admin-button-secondary" %>
      </div>
    <% end %>
  </div>

  <% if @accounts.any? %>
    <div class="admin-table-wrapper admin-table-scroll">
      <table class="admin-table">
        <thead>
          <tr>
            <th>账号</th>
            <th>平台</th>
            <th>状态</th>
            <th>养号开关</th>
            <th>机器</th>
            <th>上次养号</th>
            <th>浏览器</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @accounts.each do |account| %>
            <% profile = account.warmup_profile %>
            <% is_never = profile&.last_warmup_at.nil? %>
            <% is_due = profile&.warmup_enabled && !is_never && profile.last_warmup_at < 12.hours.ago %>
            <% row_bg = is_never ? 'background: rgba(245, 158, 11, 0.06);' : (is_due ? 'background: rgba(239, 68, 68, 0.04);' : '') %>
            <tr style="<%= row_bg %>">
              <%# 账号名 %>
              <td>
                <div style="display: flex; flex-direction: column; gap: 2px;">
                  <%= link_to account.account_name, admin_account_path(account), class: "admin-link-quiet", style: "color: var(--accent); font-weight: 500;" %>
                  <% if account.theme.present? %>
                    <div style="font-size: 11px; color: var(--text-tertiary);"><%= account.theme %></div>
                  <% end %>
                </div>
              </td>

              <%# 平台 %>
              <td>
                <% platform_colors = { 'facebook' => '#1877f2', 'twitter' => '#1da1f2', 'tiktok' => '#000000', 'youtube' => '#ff0000', 'instagram' => '#e4405f' } %>
                <span style="display: inline-flex; align-items: center; gap: 6px;">
                  <span style="width: 8px; height: 8px; border-radius: 50%; background: <%= platform_colors[account.platform] || '#9ca3af' %>;"></span>
                  <span style="font-size: 13px; color: var(--text-secondary);"><%= account.platform.to_s.titleize %></span>
                </span>
              </td>

              <%# 状态 %>
              <td>
                <% status_colors = { '正常' => '#22c55e', '未登录' => '#f59e0b', '封禁/停用' => '#ef4444', '浏览养护' => '#3b82f6' } %>
                <% color = status_colors[account.status] || '#9ca3af' %>
                <span class="admin-pill-status" style="background: <%= color %>1a; color: <%= color %>;">
                  <%= account.status %>
                </span>
              </td>

              <%# 养号开关 %>
              <td>
                <%= link_to toggle_warmup_admin_warmup_queue_path(account), data: { turbo_method: :post, turbo_confirm: "确定要#{ profile&.warmup_enabled ? '停止' : '启用' }养号吗？" }, style: "text-decoration: none;" do %>
                  <% if profile&.warmup_enabled %>
                    <span style="display: inline-flex; align-items: center; gap: 6px; cursor: pointer;">
                      <span style="width: 8px; height: 8px; border-radius: 50%; background: #22c55e; box-shadow: 0 0 6px rgba(34,197,94,0.4);"></span>
                      <span style="color: #22c55e; font-size: 13px; font-weight: 500;">启用</span>
                    </span>
                  <% else %>
                    <span style="display: inline-flex; align-items: center; gap: 6px; cursor: pointer;">
                      <span style="width: 8px; height: 8px; border-radius: 50%; background: #9ca3af;"></span>
                      <span style="color: #9ca3af; font-size: 13px;">停用</span>
                    </span>
                  <% end %>
                <% end %>
              </td>

              <%# 机器 %>
              <td>
                <% if profile %>
                  <% if profile.machine == 'move' %>
                    <span style="display: inline-flex; align-items: center; gap: 6px;">
                      <span style="width: 6px; height: 6px; border-radius: 50%; background: #3b82f6;"></span>
                      <span style="color: #3b82f6; font-size: 13px;">搬运</span>
                    </span>
                  <% else %>
                    <span style="display: inline-flex; align-items: center; gap: 6px;">
                      <span style="width: 6px; height: 6px; border-radius: 50%; background: #8b5cf6;"></span>
                      <span style="color: #8b5cf6; font-size: 13px;">运营</span>
                    </span>
                  <% end %>
                <% else %>
                  <span class="admin-label-muted">-</span>
                <% end %>
              </td>

              <%# 上次养号 %>
              <td>
                <% if profile&.last_warmup_at %>
                  <% hours_ago = ((Time.current - profile.last_warmup_at) / 3600).round(1) %>
                  <div style="display: flex; flex-direction: column; gap: 2px;">
                    <div style="font-size: 13px; color: var(--text-primary);"><%= profile.last_warmup_at.strftime("%m-%d %H:%M") %></div>
                    <% if hours_ago < 1 %>
                      <div style="font-size: 11px; color: #22c55e;">刚刚</div>
                    <% elsif hours_ago < 24 %>
                      <div style="font-size: 11px; color: #22c55e;"><%= hours_ago %>小时前</div>
                    <% elsif hours_ago < 48 %>
                      <div style="font-size: 11px; color: #f59e0b;"><%= hours_ago %>小时前</div>
                    <% else %>
                      <div style="font-size: 11px; color: #ef4444;"><%= hours_ago %>小时前</div>
                    <% end %>
                  </div>
                <% else %>
                  <span style="display: inline-flex; align-items: center; gap: 6px; color: #f59e0b; font-size: 13px; font-weight: 500;">
                    <span style="width: 6px; height: 6px; border-radius: 50%; background: #f59e0b;"></span>
                    从未养号
                  </span>
                <% end %>
              </td>

              <%# 浏览器 %>
              <td>
                <% if account.browser %>
                  <%= link_to account.browser.profile_name, admin_browser_path(account.browser), class: "admin-link-quiet", style: "font-size: 13px;" %>
                <% else %>
                  <span class="admin-label-muted">未绑定</span>
                <% end %>
              </td>

              <%# 操作 %>
              <td>
                <%= link_to "详情", admin_warmup_queue_path(account), class: "admin-link-quiet", style: "color: var(--accent);" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="admin-pagination">
      <%= paginate @accounts %>
    </div>
  <% else %>
    <div class="admin-empty-state">
      暂无账号数据。
    </div>
  <% end %>
</div>
