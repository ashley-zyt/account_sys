<!DOCTYPE html>
<html>
  <head>
    <title>Admin · AccountSys</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="admin">
    <div class="admin-layout">
      <aside class="admin-sidebar">
        <div class="admin-logo">
          <div class="admin-logo-badge">
            <div class="admin-logo-inner">
              AS
            </div>
          </div>
          <div class="admin-logo-text">
            <div class="admin-logo-title">
              AccountSys
            </div>
            <div class="admin-logo-subtitle">
              Admin Console
            </div>
          </div>
        </div>

        <div class="admin-sidebar-section-title">
          概览
        </div>
        <ul class="admin-nav">
          <% dashboard_active = controller_path == "admin/dashboard" %>
          <li class="admin-nav-item <%= "active" if dashboard_active %>">
            <%= link_to admin_root_path, class: "admin-nav-link" do %>
              <div class="admin-nav-link-main">
                <div class="admin-nav-icon">
                  📊
                </div>
                <div class="admin-nav-label">
                  仪表盘
                </div>
              </div>
              <div class="admin-nav-meta">
                Dashboard
              </div>
            <% end %>
          </li>
        </ul>

        <div class="admin-sidebar-section-title">
          账号管理
        </div>
        <ul class="admin-nav">
          <% browsers_active = controller_path == "admin/browsers" %>
          <li class="admin-nav-item <%= "active" if browsers_active %>">
            <%= link_to admin_browsers_path, class: "admin-nav-link" do %>
              <div class="admin-nav-link-main">
                <div class="admin-nav-icon">
                  🌐
                </div>
                <div class="admin-nav-label">
                  浏览器池
                </div>
              </div>
              <div class="admin-nav-meta">
                Browsers
              </div>
            <% end %>
          </li>
          
          <% accounts_active = controller_path == "admin/accounts" %>
          <li class="admin-nav-item <%= "active" if accounts_active %>">
            <%= link_to admin_accounts_path, class: "admin-nav-link" do %>
              <div class="admin-nav-link-main">
                <div class="admin-nav-icon">
                  👤
                </div>
                <div class="admin-nav-label">
                  账号管理
                </div>
              </div>
              <div class="admin-nav-meta">
                Accounts
              </div>
            <% end %>
          </li>
          
          <% post_stats_active = controller_path == "admin/post_stats" %>
          <li class="admin-nav-item <%= "active" if post_stats_active %>">
            <%= link_to admin_post_stats_path, class: "admin-nav-link" do %>
              <div class="admin-nav-link-main">
                <div class="admin-nav-icon">
                  📈
                </div>
                <div class="admin-nav-label">
                  发文数据统计
                </div>
              </div>
              <div class="admin-nav-meta">
                Post Stats
              </div>
            <% end %>
          </li>
        </ul>

        <div class="admin-sidebar-section-title">
          任务管理
        </div>
        <ul class="admin-nav">
          <% tasks_active = controller_path == "admin/move_tasks" %>
          <li class="admin-nav-item <%= "active" if tasks_active %>">
            <%= link_to admin_move_tasks_path, class: "admin-nav-link" do %>
              <div class="admin-nav-link-main">
                <div class="admin-nav-icon">
                  🎬
                </div>
                <div class="admin-nav-label">
                  搬运资源队列
                </div>
              </div>
              <div class="admin-nav-meta">
                Move Tasks
              </div>
            <% end %>
          </li>

          <% jianying_active = controller_path == "admin/jianying_tasks" %>
          <li class="admin-nav-item <%= "active" if jianying_active %>">
            <%= link_to admin_jianying_tasks_path, class: "admin-nav-link" do %>
              <div class="admin-nav-link-main">
                <div class="admin-nav-icon">
                  ✂️
                </div>
                <div class="admin-nav-label">
                  剪映资源队列
                </div>
              </div>
              <div class="admin-nav-meta">
                Jianying Tasks
              </div>
            <% end %>
          </li>
          
          <% logs_active = controller_path == "admin/task_logs" %>
          <li class="admin-nav-item <%= "active" if logs_active %>">
            <%= link_to admin_task_logs_path, class: "admin-nav-link" do %>
              <div class="admin-nav-link-main">
                <div class="admin-nav-icon">
                  📜
                </div>
                <div class="admin-nav-label">
                  任务日志
                </div>
              </div>
              <div class="admin-nav-meta">
                Logs
              </div>
            <% end %>
          </li>
        </ul>

        <div class="admin-sidebar-section-title">
          KOL管理
        </div>
        <ul class="admin-nav">
          <% kols_active = controller_path == "admin/kols" %>
          <li class="admin-nav-item <%= "active" if kols_active %>">
            <%= link_to admin_kols_path, class: "admin-nav-link" do %>
              <div class="admin-nav-link-main">
                <div class="admin-nav-icon">
                  👥
                </div>
                <div class="admin-nav-label">
                  KOL列表
                </div>
              </div>
              <div class="admin-nav-meta">
                KOL
              </div>
            <% end %>
          </li>
          
          <% conversations_active = controller_path == "admin/conversations" %>
          <li class="admin-nav-item <%= "active" if conversations_active %>">
            <%= link_to admin_conversations_path, class: "admin-nav-link" do %>
              <div class="admin-nav-link-main">
                <div class="admin-nav-icon">
                  💬
                </div>
                <div class="admin-nav-label">
                  会话中心
                </div>
              </div>
              <div class="admin-nav-meta">
                Conversations
              </div>
            <% end %>
          </li>
          
          <% templates_active = controller_path == "admin/message_templates" %>
          <li class="admin-nav-item <%= "active" if templates_active %>">
            <%= link_to admin_message_templates_path, class: "admin-nav-link" do %>
              <div class="admin-nav-link-main">
                <div class="admin-nav-icon">
                  📝
                </div>
                <div class="admin-nav-label">
                  消息模板
                </div>
              </div>
              <div class="admin-nav-meta">
                Templates
              </div>
            <% end %>
          </li>
        </ul>

        <div class="admin-sidebar-section-title">
          基础配置
        </div>
        <ul class="admin-nav">
          <% themes_active = controller_path == "admin/themes" %>
          <li class="admin-nav-item <%= "active" if themes_active %>">
            <%= link_to admin_themes_path, class: "admin-nav-link" do %>
              <div class="admin-nav-link-main">
                <div class="admin-nav-icon">
                  🏷️
                </div>
                <div class="admin-nav-label">
                  主题管理
                </div>
              </div>
              <div class="admin-nav-meta">
                Themes
              </div>
            <% end %>
          </li>
        </ul>

        <div class="admin-sidebar-footer">
          <div>
            已登录管理员:
          </div>
          <div>
            <%= current_admin&.email %>
          </div>
        </div>
      </aside>

      <main class="admin-main">
        <header class="admin-topbar">
          <div class="admin-topbar-left">
            <div class="admin-topbar-title">
              <%= content_for?(:page_title) ? yield(:page_title) : "控制台" %>
            </div>
            <div class="admin-topbar-subtitle">
              <%= content_for?(:page_subtitle) ? yield(:page_subtitle) : "账号与任务调度的可视化后台" %>
            </div>
          </div>
          <div class="admin-topbar-right">
            <div class="admin-pill">
              <span class="admin-pill-dot"></span>
              在线
            </div>
            <%= link_to "退出登录", destroy_admin_session_path, data: { "turbo-method": :delete }, class: "admin-link-quiet" %>
          </div>
        </header>

        <div class="admin-content">
          <% if notice %>
            <div style="padding: 12px 16px; background: rgba(34, 197, 94, 0.15); border: 1px solid rgba(34, 197, 94, 0.4); border-radius: 6px; margin-bottom: 16px; color: #86efac; font-size: 13px;">
              <%= notice %>
            </div>
          <% end %>
          <% if alert %>
            <div style="padding: 12px 16px; background: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.4); border-radius: 6px; margin-bottom: 16px; color: #fca5a5; font-size: 13px;">
              <%= alert %>
            </div>
          <% end %>
          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>